<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#050506">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Dashboard">
  <title>Dashboard</title>
  <link rel="stylesheet" href="styles.css">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <style>
    .kal-page {
      max-width: 1280px; margin: 0 auto;
      padding: 14px 16px 60px;
      display: flex; flex-direction: column; gap: 0;
    }

    /* ── Header ── */
    .kal-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 0 12px;
    }
    .kal-month-label {
      font-size: 20px; font-weight: 700; font-family: var(--font-mono);
      color: var(--text-primary); letter-spacing: -0.02em;
    }
    .kal-month-label span { color: var(--text-tertiary); font-weight: 400; font-size: 14px; margin-left: 6px; }
    .kal-header-right { display: flex; align-items: center; gap: 8px; }

    .view-toggle {
      display: flex; background: rgba(255,255,255,0.04); border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.08); padding: 2px; gap: 2px;
    }
    .vt-btn {
      padding: 4px 11px; border-radius: 6px; border: none; background: none;
      font-size: 10px; font-family: var(--font-mono); letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--text-tertiary); cursor: pointer;
      transition: all 0.14s;
    }
    .vt-btn.active { background: rgba(255,255,255,0.1); color: var(--text-primary); }
    .vt-btn:hover:not(.active) { color: var(--text-secondary); }

    .kal-nav { display: flex; align-items: center; gap: 5px; }
    .kal-nav-btn {
      width: 30px; height: 30px; border-radius: 7px;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      color: var(--text-secondary); cursor: pointer; font-size: 14px;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.14s;
    }
    .kal-nav-btn:hover { background: rgba(255,255,255,0.09); }
    .kal-today-btn {
      padding: 0 10px; height: 30px; border-radius: 7px;
      background: rgba(91,164,245,0.1); border: 1px solid rgba(91,164,245,0.22);
      color: #5BA4F5; cursor: pointer; font-size: 10px; font-family: var(--font-mono);
      letter-spacing: 0.06em; text-transform: uppercase; transition: background 0.14s;
    }
    .kal-today-btn:hover { background: rgba(91,164,245,0.2); }

    /* ── Week Strip ── */
    .week-strip-wrap {
      overflow-x: auto; scrollbar-width: none; margin-bottom: 12px;
    }
    .week-strip-wrap::-webkit-scrollbar { display: none; }
    .week-strip { display: flex; gap: 4px; min-width: 480px; }

    .week-day {
      flex: 1; padding: 8px 9px 7px; border-radius: 9px;
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.05);
      cursor: pointer; transition: all 0.14s; position: relative;
      display: flex; flex-direction: column; gap: 3px; overflow: hidden; min-width: 0;
    }
    .week-day:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); }
    .week-day.today { border-color: rgba(91,164,245,0.22); }
    .week-day.today::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, rgba(91,164,245,0.65), rgba(91,164,245,0.1));
    }
    .week-day.selected { background: rgba(255,255,255,0.065); border-color: rgba(255,255,255,0.18); }
    .week-day.selected.today { background: rgba(91,164,245,0.08); border-color: rgba(91,164,245,0.32); }

    .wd-top { display: flex; align-items: baseline; gap: 4px; }
    .wd-name {
      font-size: 8px; font-family: var(--font-mono); letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text-tertiary); line-height: 1;
    }
    .week-day.today .wd-name, .week-day.selected .wd-name { color: rgba(91,164,245,0.75); }
    .wd-num {
      font-size: 15px; font-weight: 700; font-family: var(--font-mono);
      color: var(--text-tertiary); line-height: 1;
    }
    .week-day.today .wd-num { color: var(--text-secondary); }
    .week-day.selected .wd-num { color: var(--text-primary); }
    .wd-ev {
      display: flex; align-items: center; gap: 4px;
      font-size: 9px; font-family: var(--font-mono); color: var(--text-tertiary);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;
    }
    .wd-ev-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
    .wd-dots { display: flex; gap: 3px; margin-top: 1px; }
    .wd-dot { width: 4px; height: 4px; border-radius: 50%; }

    /* ── Body layout ── */
    .kal-body { display: flex; gap: 12px; align-items: flex-start; }
    .kal-left { flex: 1; display: flex; flex-direction: column; gap: 10px; min-width: 0; }
    .kal-right {
      width: 268px; flex-shrink: 0; display: flex; flex-direction: column;
      gap: 8px; position: sticky; top: 64px;
    }
    @media (max-width: 840px) {
      .kal-body { flex-direction: column; }
      .kal-right { width: 100%; position: static; }
    }

    /* ── Day View Card ── */
    .day-view-card {
      background: rgba(255,255,255,0.022); border: 1px solid rgba(255,255,255,0.055);
      border-radius: 13px; overflow: hidden;
    }
    .dv-header {
      padding: 11px 16px 9px; border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex; align-items: baseline; gap: 10px;
    }
    .dv-date-big {
      font-size: 14px; font-weight: 700; font-family: var(--font-mono);
      color: var(--text-primary); letter-spacing: -0.01em;
    }
    .dv-meta {
      font-size: 9.5px; font-family: var(--font-mono); color: var(--text-tertiary);
      text-transform: uppercase; letter-spacing: 0.08em;
    }

    /* ── Agenda View ── */
    .agenda-empty {
      padding: 28px 16px; text-align: center;
      font-size: 11px; font-family: var(--font-mono);
      color: rgba(255,255,255,0.15); line-height: 1.9;
    }
    .ag-allday-strip {
      padding: 7px 16px 8px; border-bottom: 1px solid rgba(255,255,255,0.045);
      display: flex; flex-wrap: wrap; gap: 5px;
    }
    .ag-allday-pill {
      padding: 3px 9px; border-radius: 20px; font-size: 10.5px;
      font-family: var(--font-mono); cursor: pointer; transition: opacity 0.14s; white-space: nowrap;
    }
    .ag-allday-pill:hover { opacity: 0.78; }
    .agenda-section-label {
      font-size: 8px; font-family: var(--font-mono); letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text-tertiary);
      padding: 8px 16px 2px; opacity: 0.5;
    }
    .agenda-row {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 14px 8px 16px; cursor: pointer; transition: background 0.12s;
      border-left: 2px solid transparent; margin: 1px 0;
    }
    .agenda-row:hover { background: rgba(255,255,255,0.03); }
    .agenda-row.active { background: rgba(255,255,255,0.04); }
    .ag-time {
      font-size: 11px; font-family: var(--font-mono); color: var(--text-tertiary);
      width: 40px; flex-shrink: 0; text-align: right;
    }
    .ag-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .ag-title {
      flex: 1; font-size: 13px; color: var(--text-secondary); font-weight: 500;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .agenda-row.active .ag-title { color: var(--text-primary); }
    .ag-badge {
      font-size: 8px; font-family: var(--font-mono); letter-spacing: 0.07em;
      text-transform: uppercase; padding: 2px 6px; border-radius: 4px; flex-shrink: 0;
    }

    /* ── Timeline ── */
    .allday-strip {
      padding: 7px 16px; border-bottom: 1px solid rgba(255,255,255,0.045);
      display: flex; flex-wrap: wrap; gap: 5px; min-height: 32px; align-items: center;
    }
    .allday-strip:empty::before {
      content: 'Ingen heldagshendelser'; font-size: 10px;
      font-family: var(--font-mono); color: rgba(255,255,255,0.35);
    }
    .allday-pill {
      padding: 3px 9px; border-radius: 20px; font-size: 11px;
      font-family: var(--font-mono); cursor: pointer; transition: opacity 0.14s; white-space: nowrap;
    }
    .allday-pill:hover { opacity: 0.82; }
    .tl-grid {
      position: relative; padding: 0 16px 14px;
      overflow-y: auto; max-height: 460px;
    }
    .tl-grid::-webkit-scrollbar { width: 3px; }
    .tl-grid::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.09); border-radius: 2px; }
    .tl-inner { position: relative; }
    .tl-hour-row { display: flex; align-items: flex-start; position: relative; height: 60px; }
    .tl-hour-row::after {
      content: ''; position: absolute; left: 38px; right: 0; top: 0;
      height: 1px; background: rgba(255,255,255,0.04);
    }
    .tl-hour-label {
      font-size: 9px; font-family: var(--font-mono); color: rgba(255,255,255,0.18);
      width: 32px; flex-shrink: 0; text-align: right; padding-right: 6px;
      position: relative; top: -1px;
    }
    .tl-col { flex: 1; }
    .tl-events-layer { position: absolute; top: 0; left: 38px; right: 0; pointer-events: none; }
    .tl-event {
      position: absolute; left: 0; right: 0; border-radius: 7px; padding: 5px 9px;
      cursor: pointer; pointer-events: all; transition: opacity 0.14s, transform 0.13s;
      border-left: 3px solid; box-sizing: border-box; overflow: hidden; min-height: 24px;
    }
    .tl-event:hover { opacity: 0.85; transform: translateX(2px); }
    .tl-event.active { box-shadow: 0 0 0 1px currentColor; }
    .tl-event-title {
      font-size: 11px; font-family: var(--font-mono); font-weight: 600;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.2;
    }
    .tl-event-time { font-size: 9px; font-family: var(--font-mono); opacity: 0.6; margin-top: 2px; }
    .tl-now-line { position: absolute; left: 0; right: 0; height: 1px; pointer-events: none; z-index: 10; }
    .tl-now-line::before {
      content: ''; position: absolute; right: 0; left: -2px; top: -1px; height: 3px;
      background: linear-gradient(to right, rgba(255,107,107,0.7), rgba(255,107,107,0.1));
    }
    .tl-now-dot {
      position: absolute; left: -5px; top: -4px; width: 8px; height: 8px; border-radius: 50%;
      background: #FF6B6B; box-shadow: 0 0 5px rgba(255,107,107,0.65);
    }

    /* ── Right panel ── */
    .rp-card {
      background: rgba(255,255,255,0.022); border: 1px solid rgba(255,255,255,0.055);
      border-radius: 11px; padding: 13px;
    }
    .rp-label {
      font-size: 9px; font-family: var(--font-mono); letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--text-tertiary);
      margin-bottom: 9px; display: flex; align-items: center; gap: 6px;
    }
    .rp-label::after {
      content: ''; flex: 1; height: 1px;
      background: linear-gradient(to right, rgba(255,255,255,0.06), transparent);
    }

    /* Quick add */
    .qa-input-wrap { position: relative; }
    .qa-input {
      width: 100%; background: rgba(255,255,255,0.045);
      border: 1px solid rgba(255,255,255,0.09); border-radius: 8px;
      padding: 9px 36px 9px 11px; font-size: 12px; font-family: var(--font-sans);
      color: var(--text-primary); outline: none; transition: border-color 0.15s, background 0.15s;
      box-sizing: border-box;
    }
    .qa-input:focus { border-color: rgba(255,255,255,0.22); background: rgba(255,255,255,0.06); }
    .qa-input::placeholder { color: rgba(255,255,255,0.2); font-size: 11px; }
    .qa-send {
      position: absolute; right: 6px; top: 50%; transform: translateY(-50%);
      width: 24px; height: 24px; border-radius: 6px;
      background: rgba(91,164,245,0.16); border: 1px solid rgba(91,164,245,0.26);
      color: #5BA4F5; cursor: pointer; font-size: 11px;
      display: flex; align-items: center; justify-content: center; transition: background 0.13s;
    }
    .qa-send:hover { background: rgba(91,164,245,0.3); }
    .qa-preview {
      margin-top: 6px; padding: 6px 10px; border-radius: 7px;
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.055);
      font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary);
      display: none; gap: 5px; align-items: center;
    }
    .qa-preview.show { display: flex; }
    .qa-preview-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

    /* Event detail */
    .ev-detail-close {
      position: absolute; top: 13px; right: 13px; width: 20px; height: 20px;
      border-radius: 5px; background: rgba(255,255,255,0.06); border: none;
      color: var(--text-tertiary); cursor: pointer; font-size: 11px;
      display: flex; align-items: center; justify-content: center; transition: background 0.13s;
    }
    .ev-detail-close:hover { background: rgba(255,255,255,0.12); color: var(--text-secondary); }
    .ev-detail { display: flex; flex-direction: column; gap: 9px; }
    .ev-field { display: flex; flex-direction: column; gap: 3px; }
    .ev-field-label {
      font-size: 8.5px; font-family: var(--font-mono); color: var(--text-tertiary);
      text-transform: uppercase; letter-spacing: 0.1em;
    }
    .ev-input {
      background: rgba(255,255,255,0.045); border: 1px solid rgba(255,255,255,0.09);
      border-radius: 7px; padding: 7px 10px; font-size: 12px;
      color: var(--text-primary); font-family: var(--font-sans); outline: none;
      transition: border-color 0.14s; width: 100%; box-sizing: border-box;
    }
    .ev-input:focus { border-color: rgba(255,255,255,0.22); }
    .ev-input-sm { padding: 5px 9px; font-size: 11px; }
    .ev-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .ev-cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; }
    .ev-cat-btn {
      padding: 5px 3px; border-radius: 7px; border: 1px solid rgba(255,255,255,0.07);
      background: rgba(255,255,255,0.025); cursor: pointer;
      font-size: 9px; font-family: var(--font-mono); color: var(--text-tertiary);
      text-align: center; transition: all 0.13s; line-height: 1.3;
    }
    .ev-cat-btn:hover { border-color: rgba(255,255,255,0.15); color: var(--text-secondary); }
    .ev-cat-btn.active { color: var(--text-primary); }
    .ev-actions { display: flex; gap: 7px; margin-top: 3px; }
    .ev-save-btn {
      flex: 1; padding: 8px; border-radius: 8px;
      background: rgba(107,227,164,0.1); border: 1px solid rgba(107,227,164,0.22);
      color: #6BE3A4; cursor: pointer; font-size: 11px; font-family: var(--font-mono);
      letter-spacing: 0.04em; transition: background 0.13s;
    }
    .ev-save-btn:hover { background: rgba(107,227,164,0.2); }
    .ev-del-btn {
      width: 34px; border-radius: 8px;
      background: rgba(160,40,40,0.07); border: 1px solid rgba(160,40,40,0.18);
      color: rgba(200,80,80,0.7); cursor: pointer; font-size: 13px;
      display: flex; align-items: center; justify-content: center; transition: background 0.13s;
    }
    .ev-del-btn:hover { background: rgba(160,40,40,0.16); }
    .ev-gcal-notice {
      font-size: 9.5px; font-family: var(--font-mono); color: var(--text-tertiary);
      padding: 5px 9px; border-radius: 6px;
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.055);
      text-align: center;
    }

    /* Focus stats */
    .focus-stats { display: flex; gap: 5px; }
    .focus-stat {
      flex: 1; background: rgba(255,255,255,0.02); border-radius: 7px; padding: 8px 5px; text-align: center;
    }
    .focus-stat-val {
      font-size: 17px; font-weight: 700; font-family: var(--font-mono);
      color: var(--text-primary); line-height: 1.1;
    }
    .focus-stat-lbl {
      font-size: 7.5px; font-family: var(--font-mono); color: var(--text-tertiary);
      text-transform: uppercase; letter-spacing: 0.09em; margin-top: 2px;
    }

    /* Next event */
    .next-ev-row { display: flex; align-items: center; gap: 9px; }
    .next-ev-bar { width: 3px; border-radius: 2px; flex-shrink: 0; align-self: stretch; min-height: 32px; }
    .next-ev-title { font-size: 13px; font-weight: 600; color: var(--text-primary); }
    .next-ev-meta { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); margin-top: 2px; }

    /* Mini month */
    .mm-header {
      display: flex; align-items: center; justify-content: space-between; margin-bottom: 9px;
    }
    .mm-title {
      font-size: 10px; font-family: var(--font-mono); font-weight: 700;
      color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em;
    }
    .mm-nav-btn {
      width: 22px; height: 22px; border-radius: 5px;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
      color: var(--text-tertiary); cursor: pointer; font-size: 10px;
      display: flex; align-items: center; justify-content: center; transition: background 0.13s;
    }
    .mm-nav-btn:hover { background: rgba(255,255,255,0.09); }
    .mm-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; }
    .mm-dow {
      font-size: 7.5px; font-family: var(--font-mono); color: var(--text-tertiary);
      text-align: center; padding: 0 0 5px; letter-spacing: 0.07em;
    }
    .mm-cell {
      aspect-ratio: 1; border-radius: 5px; cursor: pointer;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      position: relative; transition: background 0.12s;
    }
    .mm-cell:hover { background: rgba(255,255,255,0.07); }
    .mm-cell.other-month { opacity: 0.2; cursor: default; }
    .mm-cell.today { background: rgba(91,164,245,0.1); }
    .mm-cell.selected { background: rgba(255,255,255,0.09); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.14); }
    .mm-cell.selected.today { background: rgba(91,164,245,0.15); box-shadow: inset 0 0 0 1px rgba(91,164,245,0.32); }
    .mm-num { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); }
    .mm-cell.today .mm-num { color: #5BA4F5; font-weight: 700; }
    .mm-cell.selected .mm-num { color: var(--text-primary); }
    .mm-evdot { width: 3px; height: 3px; border-radius: 50%; position: absolute; bottom: 2px; }

    /* ── Upcoming ── */
    .upcoming-card {
      background: rgba(255,255,255,0.022); border: 1px solid rgba(255,255,255,0.055);
      border-radius: 13px; padding: 13px 15px;
    }
    .upcoming-day-group { margin-bottom: 12px; }
    .upcoming-day-group:last-child { margin-bottom: 0; }
    .upcoming-day-label {
      font-size: 8.5px; font-family: var(--font-mono); letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--text-tertiary);
      padding-bottom: 5px; margin-bottom: 3px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      display: flex; align-items: center; justify-content: space-between;
    }
    .upcoming-event {
      display: flex; align-items: center; gap: 8px;
      padding: 5px 6px; border-radius: 6px; margin: 0 -6px;
      cursor: pointer; transition: background 0.12s;
    }
    .upcoming-event:hover { background: rgba(255,255,255,0.04); }
    .up-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .up-title { font-size: 12px; color: var(--text-secondary); flex: 1; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .up-time { font-size: 9.5px; font-family: var(--font-mono); color: var(--text-tertiary); flex-shrink: 0; }
    .up-badge {
      font-size: 7.5px; font-family: var(--font-mono); letter-spacing: 0.07em;
      text-transform: uppercase; padding: 2px 5px; border-radius: 3px; flex-shrink: 0;
    }

    /* ── Toast ── */
    .toast {
      position: fixed; bottom: 20px; right: 20px; z-index: 9999;
      padding: 9px 14px; border-radius: 9px;
      background: rgba(16,16,18,0.96); border: 1px solid rgba(255,255,255,0.11);
      font-size: 11px; font-family: var(--font-mono); color: var(--text-primary);
      backdrop-filter: blur(16px); transform: translateY(6px); opacity: 0;
      transition: opacity 0.22s, transform 0.22s; pointer-events: none; max-width: 340px;
    }
    .toast.show { opacity: 1; transform: translateY(0); }
    .toast.err { border-color: rgba(255,107,107,0.28); color: #FF6B6B; }

    /* Category colors */
    .cat-styrke { --cat: #FFB84D; }
    .cat-stevne { --cat: #F6C453; }
    .cat-kirke  { --cat: #EFD97A; }
    .cat-fridag { --cat: #66C7A3; }
    .cat-other  { --cat: #B197FC; }
    .cat-gcal   { --cat: #5BA4F5; }
  </style>
</head>
<body>

<nav class="main-nav">
