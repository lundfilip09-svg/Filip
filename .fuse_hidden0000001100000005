<script src="utils.js"></script>
<script>
// ── Constants ──────────────────────────────────────────────────────────────
const TL_START_H = 6;
const TL_END_H   = 23;
const HOUR_PX    = 60;

const CAT_COLORS = {
  styrke: '#FFB84D',
  stevne: '#F6C453',
  kirke:  '#EFD97A',
  fridag: '#66C7A3',
  other:  '#B197FC',
  gcal:   '#5BA4F5',
};
// Locale-aware category labels — follow the 🇳🇴/🇺🇸 toggle.
function CAT_LABELS() {
  return {
    styrke: t('kal.cat_styrke'), stevne: t('kal.cat_stevne'), kirke: t('kal.cat_kirke'),
    fridag: t('kal.cat_fridag'), other: t('kal.cat_other'),
  };
}
// Locale-aware day/month names — follow the 🇳🇴/🇺🇸 toggle via fmtLocale().
// Reference dates: 2024-01 starts on a Monday; Jan..Dec are months 0..11.
function _names(opt, count, base) {
  const fmt = new Intl.DateTimeFormat(fmtLocale(), opt);
  return Array.from({ length: count }, (_, i) => fmt.format(base(i)));
}
// Sunday-first to match getDay() (0=Sun): 2023-12-31 is a Sunday.
function DAYS_SHORT()  { return _names({ weekday: 'short' }, 7, i => new Date(2023, 11, 31 + i)); }
function DAYS_FULL()   { return _names({ weekday: 'long'  }, 7, i => new Date(2023, 11, 31 + i)); }
function MONTHS_SHORT() { return _names({ month: 'short' }, 12, i => new Date(2024, i, 1)); }
function MONTHS_FULL()  { return _names({ month: 'long'  }, 12, i => new Date(2024, i, 1)); }
function _cap(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : s; }

applyLang();

// ── State ──────────────────────────────────────────────────────────────────
let db             = null;
let selectedDate   = new Date();
let weekStart      = getMonday(new Date());
let miniMonth      = { year: new Date().getFullYear(), month: new Date().getMonth() };
let gcalEvents     = [];
let customEvents   = [];
let activeEventId  = null;
let viewMode       = 'agenda';

// ── Helpers ────────────────────────────────────────────────────────────────
function pad(n) { return String(n).padStart(2, '0'); }
function toLocalStr(d) { return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`; }
function getMonday(d) {
  const m = new Date(d);
  m.setDate(d.getDate() - ((d.getDay() + 6) % 7));
  m.setHours(0,0,0,0);
  return m;
}
function addDays(d, n) { const r = new Date(d); r.setDate(r.getDate() + n); return r; }
function fmtTime(d) { return `${pad(d.getHours())}:${pad(d.getMinutes())}`; }
function fmtDateLong(d) {
  const name = DAYS_FULL()[d.getDay()];
  return `${_cap(name)} ${d.getDate()}. ${MONTHS_FULL()[d.getMonth()]}`;
}

function getEventColor(ev) {
  if (ev.source === 'gcal') {
    const t = (ev.title || '').toLowerCase();
    if (/styrke|friidrett|sprint|leg|back|chest|gym/.test(t)) return CAT_COLORS.styrke;
    if (/stevne|konkurranse|competition|race/.test(t))        return CAT_COLORS.stevne;
    if (/gudstjeneste|salhus|salt|kirke|church/.test(t))      return CAT_COLORS.kirke;
    if (/helligdag|ferie|fridag|holiday/.test(t))             return CAT_COLORS.fridag;
    return CAT_COLORS.gcal;
  }
  return CAT_COLORS[ev.category] || CAT_COLORS.other;
}
function hexAlpha(hex, a) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${a})`;
}

// ── Category detection ─────────────────────────────────────────────────────
function detectCategory(title) {
  const t = (title || '').toLowerCase();
  if (/sprint|styrke|gym|løp|bein|overkropp|kjerne|friidrett|trening|training|leg|back|chest|squat/.test(t)) return 'styrke';
  if (/stevne|konkurranse|competition|meet|race|norgescup|nm|em|vm/.test(t)) return 'stevne';
  if (/gudstjeneste|salhus|salt|kirke|church/.test(t)) return 'kirke';
  if (/helligdag|ferie|fridag|holiday|jul|påske|pinse/.test(t)) return 'fridag';
  return 'other';
}

// ── Natural language parser ────────────────────────────────────────────────
function parseQuickAdd(text) {
  if (!text.trim()) return null;
  const lower = text.toLowerCase().trim();
  let date = toLocalStr(selectedDate), time = null, endTime = null, remaining = text.trim();

  // ISO date: YYYY-MM-DD (strip before time matching to avoid digits interfering)
  const isoDateMatch = remaining.match(/\b(\d{4}-\d{2}-\d{2})\b/);
  if (isoDateMatch) {
    date = isoDateMatch[1];
    remaining = remaining.replace(isoDateMatch[0], '').trim();
  }

  // First HH:MM → startTime
  const timeMatch  = remaining.match(/\b(\d{1,2}):(\d{2})\b/);
  const timeMatchH = !timeMatch && remaining.match(/\b(\d{1,2})\b(?=\s*$|\s+[a-z])/);
  if (timeMatch) {
    time = `${pad(+timeMatch[1])}:${pad(+timeMatch[2])}`;
    remaining = remaining.replace(timeMatch[0], '').trim();
  } else if (timeMatchH && +timeMatchH[1] >= 6 && +timeMatchH[1] <= 23) {
    time = `${pad(+timeMatchH[1])}:00`;
    remaining = remaining.replace(timeMatchH[0], '').trim();
  }

  // Second HH:MM → endTime (must come before duration check so explicit end wins)
  if (time) {
    const endTimeMatch = remaining.match(/\b(\d{1,2}):(\d{2})\b/);
    if (endTimeMatch) {
      endTime = `${pad(+endTimeMatch[1])}:${pad(+endTimeMatch[2])}`;
      remaining = remaining.replace(endTimeMatch[0], '').trim();
    }
  }

  // Duration fallback: "2t" / "1,5t" etc. — only if no explicit endTime yet
  const durMatch = !endTime && remaining.match(/\b(\d+(?:[.,]\d+)?)\s*t(?:imer?)?\b/i);
  if (durMatch && time) {
    const hrs = parseFloat(durMatch[1].replace(',','.'));
    const [hh, mm] = time.split(':').map(Number);
    const endMins = hh * 60 + mm + hrs * 60;
    endTime = `${pad(Math.floor(endMins / 60))}:${pad(endMins % 60)}`;
    remaining = remaining.replace(durMatch[0], '').trim();
  }

  const dayNames = [
    ['mandag','monday','man','mon'],['tirsdag','tuesday','tir','tue'],
    ['onsdag','wednesday','ons','wed'],['torsdag','thursday','tor','thu'],
    ['fredag','friday','fre','fri'],['lørdag','saturday','lør','sat'],
    ['søndag','sunday','søn','sun'],
  ];
  const relDay = { 'i dag': 0, 'idag': 0, 'i morgen': 1, 'imorgen': 1, 'tomorrow': 1 };

  let foundDay = false;
  for (const [rel, shift] of Object.entries(relDay)) {
    if (lower.includes(rel)) {
      date = toLocalStr(addDays(new Date(), shift));
      remaining = remaining.replace(new RegExp(rel, 'gi'), '').trim();
      foundDay = true; break;
    }
  }
  if (!foundDay) {
    for (let wi = 0; wi < dayNames.length; wi++) {
      for (const alias of dayNames[wi]) {
        const re = new RegExp(`\\b${alias}\\b`, 'i');
        if (re.test(remaining)) {
          const nowDow = (new Date().getDay() + 6) % 7;
          let diff = wi - nowDow;
          if (diff <= 0) diff += 7;
          date = toLocalStr(addDays(new Date(), diff));
          remaining = remaining.replace(re, '').trim();
          foundDay = true; break;
        }
      }
      if (foundDay) break;
    }
  }

  const title = remaining.replace(/\s+/g, ' ').trim() || text.trim();
  return { title, date, startTime: time, endTime, category: detectCategory(title), allDay: !time };
}

// ── Data loading ───────────────────────────────────────────────────────────
async function loadGCalRange() {
  const start = toLocalStr(addDays(weekStart, -7));
  const end   = toLocalStr(addDays(weekStart, 35));
  try {
    const r = await fetch(`/api/kalender?start=${start}&end=${end}`);
    if (!r.ok) throw new Error('API ' + r.status);
    const { events = [] } = await r.json();
    gcalEvents = events.map(e => ({
      id: 'gcal-' + e.id, source: 'gcal',
      title: e.summary || '(uten tittel)',
      date: (e.start?.date || e.start?.dateTime || '').slice(0, 10),
      startTime: e.start?.dateTime ? fmtTime(new Date(e.start.dateTime)) : null,
      endTime:   e.end?.dateTime   ? fmtTime(new Date(e.end.dateTime))   : null,
      allDay: !!e.start?.date, gcalId: e.id,
    }));
  } catch { gcalEvents = []; }
}

async function loadCustomEvents() {
  if (!db) return;
  const { data, error } = await db.from('calendar_events').select('*');
  if (error) {
    if (error.message && error.message.includes('calendar_events')) {
      toast('Mangler database-tabell. Kjør supabase/migrations/006_calendar_events.sql i Supabase SQL Editor.', 'err');
    }
    customEvents = []; return;
  }
  customEvents = (data || []).map(e => ({
    id: 'custom-' + e.id, dbId: e.id, source: 'custom',
    title: e.title, date: e.date,
    startTime: e.start_time ? e.start_time.slice(0, 5) : null,
    endTime:   e.end_time   ? e.end_time.slice(0, 5)   : null,
    allDay: e.all_day, category: e.category || 'other', notes: e.notes || '',
  }));
}

function allEvents() {
  return [...gcalEvents, ...customEvents].sort((a, b) => {
    if (a.date < b.date) return -1;
    if (a.date > b.date) return 1;
    return (a.startTime || '00:00').localeCompare(b.startTime || '00:00');
  });
}

function eventsForDate(dateStr) { return allEvents().filter(e => e.date === dateStr); }

// ── Week strip ─────────────────────────────────────────────────────────────
function renderWeekStrip() {
  const el = document.getElementById('weekStrip');
  const todayStr = today(), selStr = toLocalStr(selectedDate);
  const evts = allEvents();

  el.innerHTML = Array.from({length: 7}, (_, i) => {
    const d    = addDays(weekStart, i);
    const dStr = toLocalStr(d);
    const isToday    = dStr === todayStr;
    const isSelected = dStr === selStr;
    const dayEvts = evts.filter(e => e.date === dStr);

    const firstEv  = dayEvts.find(e => !e.allDay && e.startTime) || dayEvts[0];
    const evColor  = firstEv ? getEventColor(firstEv) : null;
    const evTitle  = firstEv
      ? firstEv.title.slice(0, 9) + (firstEv.title.length > 9 ? '…' : '')
      : null;
    const extraDots = dayEvts.length > 1
      ? `<div class="wd-dots">${dayEvts.slice(1, 4).map(e =>
          `<div class="wd-dot" style="background:${getEventColor(e)}"></div>`).join('')}</div>`
      : '';

    return `<div class="week-day${isToday ? ' today' : ''}${isSelected ? ' selected' : ''}" onclick="selectDay('${dStr}')">
      <div class="wd-top">
        <span class="wd-name">${_cap(DAYS_SHORT()[(i + 1) % 7])}</span>
        <span class="wd-num">${d.getDate()}</span>
      </div>
      ${evTitle ? `<div class="wd-ev"><div class="wd-ev-dot" style="background:${evColor}"></div>${escHtml(evTitle)}</div>` : ''}
      ${extraDots}
    </div>`;
  }).join('');

  const mid = addDays(weekStart, 3);
  document.getElementById('headerLabel').innerHTML =
    `${_cap(MONTHS_FULL()[mid.getMonth()])}<span>${mid.getFullYear()}</span>`;
}

// ── Day view dispatcher ────────────────────────────────────────────────────
function renderDayView(dateStr) {
  const d    = new Date(dateStr + 'T12:00:00');
  const evts = eventsForDate(dateStr);
  document.getElementById('dvDateBig').textContent = fmtDateLong(d);
  document.getElementById('dvMeta').textContent =
    `Uke ${getISOWeek(d)} · ${evts.length} hendelse${evts.length !== 1 ? 'r' : ''}`;
  document.getElementById('ds-events').textContent = evts.length || '0';

  if (viewMode === 'agenda') renderAgenda(dateStr);
  else renderTimeline(dateStr);

  renderNextCard();
}

// ── Agenda view ────────────────────────────────────────────────────────────
function renderAgenda(dateStr) {
  const el   = document.getElementById('dayViewContent');
  const evts = eventsForDate(dateStr);

  if (!evts.length) {
    el.innerHTML = `<div class="agenda-empty">${t('kal.no_events_use_quick')}</div>`;
    return;
  }

  const allDay = evts.filter(e => e.allDay);
  const timed  = evts.filter(e => !e.allDay && e.startTime)
                     .sort((a,b) => a.startTime.localeCompare(b.startTime));
  const noTime = evts.filter(e => !e.allDay && !e.startTime);

  let html = '';

  if (allDay.length) {
    html += `<div class="ag-allday-strip">`;
    html += allDay.map(e => {
      const c = getEventColor(e);
      return `<div class="ag-allday-pill" style="background:${hexAlpha(c,0.14)};color:${c};border:1px solid ${hexAlpha(c,0.24)}"
        onclick="openEvent('${e.id}')">${escHtml(e.title)}</div>`;
    }).join('');
    html += `</div>`;
  }

  if (timed.length) {
    html += `<div class="agenda-list">`;
    html += timed.map(e => agRow(e)).join('');
    html += `</div>`;
  }

  if (noTime.length) {
    if (timed.length || allDay.length) html += `<div class="agenda-section-label">${t('kal.no_time')}</div>`;
    html += `<div class="agenda-list">`;
    html += noTime.map(e => agRow(e)).join('');
    html += `</div>`;
  }

  el.innerHTML = html;
}

function agRow(e) {
  const c        = getEventColor(e);
  const isActive = e.id === activeEventId;
  const catLabel = e.source === 'gcal' ? 'GCal' : (CAT_LABELS()[e.category] || t('kal.cat_other'));
  const timeStr  = e.allDay ? t('kal.whole_day') : (e.startTime || '–');
  const style    = isActive ? `background:${hexAlpha(c,0.07)};border-left-color:${c}` : '';

  return `<div class="agenda-row${isActive ? ' active' : ''}" style="${style}" onclick="openEvent('${e.id}')">
    <div class="ag-time">${timeStr}</div>
    <div class="ag-dot" style="background:${c}"></div>
    <div class="ag-title">${escHtml(e.title)}</div>
    <div class="ag-badge" style="background:${hexAlpha(c,0.14)};color:${c}">${catLabel}</div>
  </div>`;
}

// ── Timeline view ──────────────────────────────────────────────────────────
function renderTimeline(dateStr) {
  const evts   = eventsForDate(dateStr);
  const allDay = evts.filter(e => e.allDay);
  const timed  = evts.filter(e => !e.allDay && e.startTime);

  const adHtml = allDay.map(e => {
    const c = getEventColor(e);
    return `<div class="allday-pill" style="background:${hexAlpha(c,0.14)};color:${c};border:1px solid ${hexAlpha(c,0.24)}"
      onclick="openEvent('${e.id}')">${escHtml(e.title)}</div>`;
  }).join('');

  const totalH  = TL_END_H - TL_START_H;
  const gridH   = totalH * HOUR_PX;

  const hourRows = Array.from({length: totalH}, (_, i) => TL_START_H + i).map(h =>
    `<div class="tl-hour-row">
      <div class="tl-hour-label">${pad(h)}:00</div>
      <div class="tl-col"></div>
    </div>`
  ).join('');

  const eventBlocks = timed.map(e => {
    const [sh, sm]  = e.startTime.split(':').map(Number);
    const startMins = sh * 60 + sm;
    const top       = (Math.max(TL_START_H * 60, startMins) - TL_START_H * 60) / 60 * HOUR_PX;
    let height      = HOUR_PX;
    if (e.endTime) {
      const [eh, em] = e.endTime.split(':').map(Number);
      height = Math.max(24, (eh * 60 + em - startMins) / 60 * HOUR_PX);
    }
    const c        = getEventColor(e);
    const isActive = e.id === activeEventId;
    const timeLabel = e.endTime ? `${e.startTime} – ${e.endTime}` : e.startTime;
    return `<div class="tl-event${isActive ? ' active' : ''}"
      style="top:${top}px;height:${height}px;background:${hexAlpha(c,0.1)};border-left-color:${c};color:${c}"
      onclick="openEvent('${e.id}')">
      <div class="tl-event-title" style="color:var(--text-primary)">${escHtml(e.title)}</div>
      ${height > 34 ? `<div class="tl-event-time">${timeLabel}</div>` : ''}
    </div>`;
  }).join('');

  const nowLine = (() => {
    if (dateStr !== today()) return '';
    const now  = new Date();
    const mins = now.getHours() * 60 + now.getMinutes();
    const top  = (mins - TL_START_H * 60) / 60 * HOUR_PX;
    if (top < 0 || top > gridH) return '';
    return `<div class="tl-now-line" style="top:${top}px"><div class="tl-now-dot"></div></div>`;
  })();

  document.getElementById('dayViewContent').innerHTML =
    `${adHtml ? `<div class="allday-strip">${adHtml}</div>` : ''}
    <div class="tl-grid" id="tlGrid">
      <div class="tl-inner" style="height:${gridH}px">
        ${hourRows}
        <div class="tl-events-layer" style="height:${gridH}px">${eventBlocks}${nowLine}</div>
      </div>
    </div>`;

  const scrollToH = dateStr === today() ? new Date().getHours() - 1 : 7;
  setTimeout(() => {
    const g = document.getElementById('tlGrid');
    if (g) g.scrollTop = Math.max(0, (scrollToH - TL_START_H) * HOUR_PX - 20);
  }, 10);
}

// ── Event detail ───────────────────────────────────────────────────────────
function renderEventDetail() {
  const card = document.getElementById('evDetailCard');
  const el   = document.getElementById('evDetailContent');
  if (!el) return;

  if (!activeEventId) { if (card) card.style.display = 'none'; return; }

  const ev = allEvents().find(e => e.id === activeEventId);
  if (!ev)  { if (card) card.style.display = 'none'; return; }
  if (card) card.style.display = 'block';

  if (ev.source === 'gcal') {
    const c = getEventColor(ev);
    el.innerHTML = `
      <div class="ev-detail">
        <div style="font-size:14px;font-weight:700;color:var(--text-primary);margin-bottom:4px">${escHtml(ev.title)}</div>
        <div style="font-size:10px;font-family:var(--font-mono);color:var(--text-tertiary);margin-bottom:10px">
          ${ev.allDay ? t('kal.all_day') : (ev.startTime + (ev.endTime ? ' – ' + ev.endTime : ''))} · ${ev.date}
        </div>
        <div class="ev-gcal-notice" data-i18n="kal.gcal_readonly">Google Calendar · skrivebeskyttet</div>
      </div>`;
    return;
  }

  const c       = CAT_COLORS[ev.category] || CAT_COLORS.other;
  const catBtns = Object.entries(CAT_LABELS()).map(([k,v]) =>
    `<button class="ev-cat-btn${ev.category === k ? ' active' : ''}"
      style="${ev.category === k ? `background:${hexAlpha(CAT_COLORS[k],0.14)};border-color:${hexAlpha(CAT_COLORS[k],0.28)};color:${CAT_COLORS[k]}` : ''}"
      onclick="evSetCat('${k}')">${v}</button>`
  ).join('');

  el.innerHTML = `
    <div class="ev-detail">
      <div class="ev-field">
        <div class="ev-field-label" data-i18n="kal.title_lbl">Tittel</div>
        <input class="ev-input" id="ef-title" value="${escHtml(ev.title)}">
      </div>
      <div class="ev-field">
        <div class="ev-field-label" data-i18n="date">Dato</div>
        <input class="ev-input ev-input-sm" id="ef-date" type="date" value="${ev.date}">
      </div>
      <div class="ev-row2">
        <div class="ev-field">
          <div class="ev-field-label" data-i18n="kal.start">Start</div>
          <input class="ev-input ev-input-sm" id="ef-start" type="time" value="${ev.startTime || ''}">
        </div>
        <div class="ev-field">
          <div class="ev-field-label" data-i18n="kal.end">Slutt</div>
          <input class="ev-input ev-input-sm" id="ef-end" type="time" value="${ev.endTime || ''}">
        </div>
      </div>
      <div class="ev-field">
        <div class="ev-field-label" data-i18n="kal.category">Kategori</div>
        <div class="ev-cat-grid">${catBtns}</div>
      </div>
      <div class="ev-field">
        <div class="ev-field-label" data-i18n="notes">Notater</div>
        <textarea class="ev-input ev-input-sm" id="ef-notes" style="min-height:48px;resize:vertical">${escHtml(ev.notes || '')}</textarea>
      </div>
      <div class="ev-actions">
        <button class="ev-save-btn" onclick="saveActiveEvent()" data-i18n="save">Lagre</button>
        <button class="ev-del-btn" onclick="deleteActiveEvent()" title="Slett">🗑</button>
      </div>
    </div>`;
}

// ── Mini month ─────────────────────────────────────────────────────────────
function renderMiniMonth() {
  const { year, month } = miniMonth;
  const months = ['Jan','Feb','Mar','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Des'];
  document.getElementById('mmTitle').textContent = `${months[month]} ${year}`;

  const firstDay      = new Date(year, month, 1);
  const startDow      = (firstDay.getDay() + 6) % 7;
  const daysInMonth   = new Date(year, month + 1, 0).getDate();
  const prevMonthDays = new Date(year, month, 0).getDate();
  const todayStr      = today(), selStr = toLocalStr(selectedDate);
  const evDates       = new Set(allEvents().map(e => e.date));

  const dowHeaders = ['M','T','O','T','F','L','S'].map(d => `<div class="mm-dow">${d}</div>`).join('');
  let cells = '';
  for (let i = startDow - 1; i >= 0; i--)
    cells += `<div class="mm-cell other-month"><div class="mm-num">${prevMonthDays - i}</div></div>`;
  for (let d = 1; d <= daysInMonth; d++) {
    const dStr    = `${year}-${pad(month+1)}-${pad(d)}`;
    const isToday = dStr === todayStr, isSel = dStr === selStr;
    const ev      = evDates.has(dStr) ? allEvents().find(e => e.date === dStr) : null;
    cells += `<div class="mm-cell${isToday ? ' today' : ''}${isSel ? ' selected' : ''}" onclick="selectDay('${dStr}')">
      <div class="mm-num">${d}</div>
      ${ev ? `<div class="mm-evdot" style="background:${getEventColor(ev)}"></div>` : ''}
    </div>`;
  }
  const total = startDow + daysInMonth;
  const rem   = (7 - (total % 7)) % 7;
  for (let d = 1; d <= rem; d++)
    cells += `<div class="mm-cell other-month"><div class="mm-num">${d}</div></div>`;

  document.getElementById('mmGrid').innerHTML = dowHeaders + cells;
}

// ── Upcoming ───────────────────────────────────────────────────────────────
function renderUpcoming() {
  const el      = document.getElementById('upcomingList');
  const todayD  = today();
  const upcoming = allEvents().filter(e => e.date >= todayD).slice(0, 28);

  if (!upcoming.length) {
    el.innerHTML = `<div style="font-size:11px;font-family:var(--font-mono);color:var(--text-tertiary);padding:4px 0">${t('dash.no_events')}</div>`;
    return;
  }

  const groups = {};
  for (const e of upcoming) {
    if (!groups[e.date]) groups[e.date] = [];
    groups[e.date].push(e);
  }

  el.innerHTML = Object.entries(groups).slice(0, 8).map(([dateStr, evts]) => {
    const d        = new Date(dateStr + 'T12:00:00');
    const isToday  = dateStr === todayD;
    const dow      = (d.getDay() + 6) % 7;
    const dayLabel = isToday ? t('kal.today')
      : `${_cap(DAYS_SHORT()[dow === 6 ? 0 : dow + 1] || DAYS_SHORT()[dow])} ${d.getDate()}. ${MONTHS_SHORT()[d.getMonth()]}`;

    const rows = evts.map(e => {
      const c        = getEventColor(e);
      const catLabel = e.source === 'gcal' ? '' : (CAT_LABELS()[e.category] || '');
      return `<div class="upcoming-event" onclick="selectDay('${dateStr}');openEvent('${e.id}')">
        <div class="up-dot" style="background:${c}"></div>
        <div class="up-title">${escHtml(e.title)}</div>
        ${catLabel ? `<div class="up-badge" style="background:${hexAlpha(c,0.13)};color:${c}">${catLabel}</div>` : ''}
        <div class="up-time">${e.allDay ? 'Heldags' : (e.startTime || '')}</div>
      </div>`;
    }).join('');

    return `<div class="upcoming-day-group">
      <div class="upcoming-day-label"${isToday ? ' style="color:rgba(91,164,245,0.75)"' : ''}>
        <span>${dayLabel}</span>
        <span style="opacity:0.45">${evts.length} hend.</span>
      </div>
      ${rows}
    </div>`;
  }).join('');
}

// ── Next event card ────────────────────────────────────────────────────────
function renderNextCard() {
  const el = document.getElementById('nextEvContent');
  if (!el) return;
  const todayStr = today();
  const now      = new Date();
  const nowStr   = `${pad(now.getHours())}:${pad(now.getMinutes())}`;

  const next = allEvents().filter(e =>
    !e.allDay && e.startTime && (
      e.date > todayStr || (e.date === todayStr && e.startTime >= nowStr)
    )
  ).sort((a,b) => (a.date + a.startTime).localeCompare(b.date + b.startTime))[0];

  if (!next) {
    el.innerHTML = `<div style="font-size:11px;font-family:var(--font-mono);color:var(--text-tertiary)">${t('kal.no_upcoming')}</div>`;
    return;
  }

  const d        = new Date(next.date + 'T12:00:00');
  const c        = getEventColor(next);
  const isToday  = next.date === todayStr;
  const dow      = (d.getDay() + 6) % 7;
  const dateLabel = isToday ? t('kal.today')
    : `${NO_DAYS_SHORT[dow === 6 ? 0 : dow + 1] || NO_DAYS_SHORT[dow]} ${d.getDate()}. ${NO_MONTHS_SHORT[d.getMonth()]}`;

  el.innerHTML = `
    <div class="next-ev-bar" style="background:${c}"></div>
    <div style="min-width:0">
      <div class="next-ev-title" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escHtml(next.title)}</div>
      <div class="next-ev-meta">${dateLabel} · ${next.startTime}</div>
    </div>`;
}

// ── User actions ───────────────────────────────────────────────────────────
function selectDay(dateStr) {
  selectedDate = new Date(dateStr + 'T12:00:00');
  const selMon = getMonday(selectedDate);
  if (toLocalStr(selMon) !== toLocalStr(weekStart)) weekStart = selMon;
  miniMonth = { year: selectedDate.getFullYear(), month: selectedDate.getMonth() };
  renderWeekStrip();
  renderDayView(dateStr);
  renderMiniMonth();
}

function openEvent(id) {
  activeEventId = id;
  renderDayView(toLocalStr(selectedDate));
  renderEventDetail();
}

function closeEvent() {
  activeEventId = null;
  const card = document.getElementById('evDetailCard');
  if (card) card.style.display = 'none';
  renderDayView(toLocalStr(selectedDate));
}

function evSetCat(cat) {
  if (!activeEventId) return;
  const ev = customEvents.find(e => e.id === activeEventId);
  if (!ev) return;
  ev.category = cat;
  renderEventDetail();
}

async function saveActiveEvent() {
  const ev = customEvents.find(e => e.id === activeEventId);
  if (!ev) return;
  const title     = document.getElementById('ef-title')?.value.trim();
  const date      = document.getElementById('ef-date')?.value;
  const startTime = document.getElementById('ef-start')?.value || null;
  const endTime   = document.getElementById('ef-end')?.value   || null;
  const notes     = document.getElementById('ef-notes')?.value.trim() || null;
  if (!title) { toast(t('gm.save_error'), 'err'); return; }

  const payload = { title, date, start_time: startTime, end_time: endTime, all_day: !startTime, category: ev.category, notes };
  const { error } = await db.from('calendar_events').update(payload).eq('id', ev.dbId);
  if (error) { toast(t('kal.save_error'), 'err'); return; }

  Object.assign(ev, { title, date, startTime, endTime, notes, allDay: !startTime });
  toast(t('kal.updated'));
  renderAll();
}

async function deleteActiveEvent() {
  const ev = customEvents.find(e => e.id === activeEventId);
  if (!ev) return;
  if (!confirm(`${t('kal.del_confirm')} "${ev.title}"`)) return;
  const { error } = await db.from('calendar_events').delete().eq('id', ev.dbId);
  if (error) { toast(t('kal.del_error'), 'err'); return; }
  customEvents = customEvents.filter(e => e.id !== activeEventId);
  activeEventId = null;
  toast(t('kal.deleted'));
  renderAll();
}

async function createEvent(data) {
  const { title, date, startTime, endTime, category, allDay, notes = null } = data;
  if (!title || !date) return;
  const payload = {
    title, date,
    start_time: startTime || null,
    end_time:   endTime   || null,
    all_day:    allDay || !startTime,
    category:   category || 'other',
    notes,
  };
  const { data: rows, error } = await db.from('calendar_events').insert(payload).select();
  if (error) {
    const msg = error.message?.includes('calendar_events')
      ? 'Tabell mangler — kjør 006_calendar_events.sql i Supabase SQL Editor'
      : 'Feil: ' + error.message;
    toast(msg, 'err'); return;
  }
  const row = rows[0];
  const ev  = {
    id: 'custom-' + row.id, dbId: row.id, source: 'custom',
    title: row.title, date: row.date,
    startTime: row.start_time?.slice(0,5) || null,
    endTime:   row.end_time?.slice(0,5)   || null,
    allDay: row.all_day, category: row.category || 'other', notes: row.notes || '',
  };
  customEvents.push(ev);
  activeEventId = ev.id;
  if (ev.date !== toLocalStr(selectedDate)) selectDay(ev.date);
  else renderAll();
  toast(t('kal.added') + ': ' + ev.title);
}

// ── Quick add ──────────────────────────────────────────────────────────────
function onQaInput() {
  const val     = document.getElementById('qaInput').value;
  const parsed  = parseQuickAdd(val);
  const preview = document.getElementById('qaPreview');
  const dot     = document.getElementById('qaPreviewDot');
  const txt     = document.getElementById('qaPreviewText');

  if (parsed && val.length > 2) {
    const c = CAT_COLORS[parsed.category] || CAT_COLORS.other;
    dot.style.background = c;
    const timeStr = parsed.allDay ? 'Hele dagen' : (parsed.startTime + (parsed.endTime ? ' – ' + parsed.endTime : ''));
    txt.textContent = `${parsed.title} · ${timeStr} · ${parsed.date}`;
    preview.classList.add('show');
  } else {
    preview.classList.remove('show');
  }
}

function onQaKey(e) { if (e.key === 'Enter') qaSubmit(); }

async function qaSubmit() {
  const val = document.getElementById('qaInput').value.trim();
  if (!val) return;
  const parsed = parseQuickAdd(val);
  if (!parsed) return;
  await createEvent(parsed);
  document.getElementById('qaInput').value = '';
  document.getElementById('qaPreview').classList.remove('show');
}

// ── Navigation ─────────────────────────────────────────────────────────────
function shiftWeek(dir) {
  weekStart = addDays(weekStart, dir * 7);
  const selStr  = toLocalStr(selectedDate);
  const weekEnd = addDays(weekStart, 6);
  const ws = toLocalStr(weekStart), we = toLocalStr(weekEnd);
  if (selStr < ws || selStr > we) {
    selectedDate = new Date(weekStart); selectedDate.setHours(12,0,0,0);
    renderDayView(toLocalStr(selectedDate));
  }
  renderWeekStrip();
  renderMiniMonth();
}

function goToday() {
  selectedDate = new Date();
  weekStart    = getMonday(new Date());
  miniMonth    = { year: selectedDate.getFullYear(), month: selectedDate.getMonth() };
  renderAll();
}

function shiftMiniMonth(dir) {
  miniMonth.month += dir;
  if (miniMonth.month < 0)  { miniMonth.month = 11; miniMonth.year--; }
  if (miniMonth.month > 11) { miniMonth.month = 0;  miniMonth.year++; }
  renderMiniMonth();
}

// ── View toggle ────────────────────────────────────────────────────────────
function setView(mode) {
  viewMode = mode;
  document.getElementById('vtAgenda').classList.toggle('active', mode === 'agenda');
  document.getElementById('vtTimeline').classList.toggle('active', mode === 'timeline');
  renderDayView(toLocalStr(selectedDate));
}

// ── Render all ─────────────────────────────────────────────────────────────
function renderAll() {
  renderWeekStrip();
  renderDayView(toLocalStr(selectedDate));
  renderEventDetail();
  renderMiniMonth();
  renderUpcoming();
}

// ── Utilities ──────────────────────────────────────────────────────────────
function getISOWeek(d) {
  const tmp = new Date(d); tmp.setHours(0,0,0,0);
  tmp.setDate(tmp.getDate() + 3 - (tmp.getDay()+6)%7);
  const w1 = new Date(tmp.getFullYear(), 0, 4);
  return 1 + Math.round(((tmp-w1)/86400000 - 3 + (w1.getDay()+6)%7)/7);
}
// ── Daily stats ────────────────────────────────────────────────────────────
async function loadDailyStats() {
  if (!db) return;
  const [sleepRes, kneeRes] = await Promise.all([
    db.from('health_data').select('sleep_hours').order('date',{ascending:false}).limit(1),
    db.from('knee_pain').select('after_score').order('date',{ascending:false}).order('id',{ascending:false}).limit(1),
  ]);
  const sleep = sleepRes.data?.[0]?.sleep_hours;
  const knee  = kneeRes.data?.[0]?.after_score;
  document.getElementById('ds-sleep').textContent = sleep != null ? fmtSleepHM(sleep) : '–';
  document.getElementById('ds-knee').textContent  = knee  != null ? knee        : '–';
}

// Formater desimaltimer (f.eks. 8.61) som "8t 37m"
function fmtSleepHM(hours) {
  const totalMin = Math.round(hours * 60);
  const h = Math.floor(totalMin / 60), m = totalMin % 60;
  return m > 0 ? `${h}t ${m}m` : `${h}t`;
}

// ── Init ───────────────────────────────────────────────────────────────────
(async () => {
  document.querySelector('[data-p="kalender"]').classList.add('active');

  try {
    const cfg = await getConfig();
    db = supabase.createClient(cfg.supabaseUrl, cfg.supabaseAnonKey);
    const { data: { session } } = await db.auth.getSession();
    if (!session) { window.location.href = 'login.html'; return; }
  } catch (err) {
    document.querySelector('.kal-page').innerHTML =
      `<div class="card" style="text-align:center;padding:40px;margin-top:40px">
        <div style="color:var(--danger);font-family:var(--font-mono);font-size:13px">${err.message}</div>
      </div>`;
    return;
  }

  applyLang();
  await Promise.all([loadGCalRange(), loadCustomEvents(), loadDailyStats()]);
  renderAll();

  setInterval(() => {
    if (viewMode === 'timeline' && toLocalStr(selectedDate) === today()) {
      renderTimeline(today());
    }
  }, 60_000);
})();

// Re-render everything (day/month names, cards) when language toggles
onLangChange = () => { applyLang(); renderAll(); };
</script>
