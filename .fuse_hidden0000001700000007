<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#050506">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Dashboard">
  <title>Dashboard</title>
  <link rel="stylesheet" href="styles.css">
  <style>
    .sovn-page {
      max-width: 1180px; margin: 0 auto;
      padding: 14px 16px 60px;
      display: flex; flex-direction: column; gap: 10px;
    }

    /* ── Hero ── */
    .hero-card {
      background: linear-gradient(135deg, rgba(124,111,212,0.07) 0%, rgba(74,158,232,0.05) 50%, rgba(107,227,164,0.04) 100%);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px; padding: 22px 26px;
      position: relative; overflow: hidden;
    }
    .hero-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, rgba(124,111,212,0.5), rgba(74,158,232,0.35), rgba(107,227,164,0.2), transparent);
    }
    .hero-inner { display: flex; align-items: center; gap: 26px; }
    .hero-score-box {
      width: 88px; height: 88px; border-radius: 18px; flex-shrink: 0;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.09);
      transition: box-shadow 0.3s;
    }
    .hero-score-box.score-good { background: rgba(107,227,164,0.09); border-color: rgba(107,227,164,0.28); box-shadow: 0 0 32px rgba(107,227,164,0.12); }
    .hero-score-box.score-ok   { background: rgba(242,192,99,0.09);  border-color: rgba(242,192,99,0.28);  box-shadow: 0 0 32px rgba(242,192,99,0.12);  }
    .hero-score-box.score-bad  { background: rgba(255,107,107,0.09); border-color: rgba(255,107,107,0.28); box-shadow: 0 0 32px rgba(255,107,107,0.12); }
    .hero-score-num {
      font-size: 34px; font-weight: 800; font-family: var(--font-mono);
      line-height: 1; letter-spacing: -0.03em;
    }
    .hero-score-lbl {
      font-size: 7.5px; font-family: var(--font-mono); letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--text-tertiary); margin-top: 4px;
    }
    .hero-right { flex: 1; min-width: 0; }
    .hero-date {
      font-size: 9.5px; font-family: var(--font-mono); color: var(--text-tertiary);
      letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 5px;
    }
    .hero-status {
      font-size: 21px; font-weight: 700; line-height: 1.15;
      letter-spacing: -0.02em; margin-bottom: 3px;
    }
    .hero-tagline { font-size: 12px; color: var(--text-secondary); margin-bottom: 14px; }
    .hero-chips { display: flex; gap: 6px; flex-wrap: wrap; }
    .hero-chip {
      padding: 3px 9px; border-radius: 20px; font-size: 10.5px; font-family: var(--font-mono);
      background: rgba(255,255,255,0.045); border: 1px solid rgba(255,255,255,0.08);
      color: var(--text-secondary);
    }

    /* ── Metrics Grid ── */
    /* ── Warning bar ── */
    .warn-bar {
      border-radius: 12px; padding: 12px 16px;
      display: flex; flex-direction: column; gap: 7px;
    }
    .warn-bar.warn-red    { background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.25); }
    .warn-bar.warn-orange { background: rgba(242,192,99,0.08);  border: 1px solid rgba(242,192,99,0.25);  }
    .warn-bar.warn-ok     { background: rgba(107,227,164,0.06); border: 1px solid rgba(107,227,164,0.2);  }
    .warn-item { display: flex; align-items: flex-start; gap: 10px; }
    .warn-icon { font-size: 14px; flex-shrink: 0; margin-top: 1px; }
    .warn-text { font-size: 11.5px; line-height: 1.5; }
    .warn-title { font-weight: 600; color: var(--text-primary); }
    .warn-advice { color: var(--text-secondary); margin-top: 1px; font-size: 11px; }

    /* ── Metrics ── */
    .metrics-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; }
    .metric-card {
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.055);
      border-radius: 12px; padding: 14px 14px 12px; transition: all 0.14s;
      cursor: default; position: relative;
    }
    .metric-card:hover { background: rgba(255,255,255,0.04); }
    .mc-top-lbl {
      font-size: 9px; font-family: var(--font-mono); letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 8px;
    }
    .mc-val {
      font-size: 28px; font-weight: 700; font-family: var(--font-mono);
      line-height: 1; letter-spacing: -0.02em; color: var(--text-primary);
    }
    .mc-unit {
      font-size: 9.5px; font-family: var(--font-mono); color: var(--text-tertiary); margin-top: 4px;
    }
    .mc-status-badge {
      display: inline-flex; align-items: center; gap: 4px;
      margin-top: 8px; padding: 2px 7px; border-radius: 20px;
      font-size: 9px; font-family: var(--font-mono); letter-spacing: 0.06em;
      text-transform: uppercase; border: 1px solid currentColor;
    }
    .mc-advice {
      margin-top: 7px; padding-top: 7px;
      border-top: 1px solid rgba(255,255,255,0.06);
      font-size: 10px; color: var(--text-secondary); line-height: 1.55;
    }

    /* ── Mid Grid ── */
    .mid-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .mid-card {
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.055);
      border-radius: 14px; padding: 17px 18px;
    }
    .card-lbl {
      font-size: 9px; font-family: var(--font-mono); letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 12px;
      display: flex; align-items: center; gap: 6px;
    }
    .card-lbl::after {
      content: ''; flex: 1; height: 1px;
      background: linear-gradient(to right, rgba(255,255,255,0.07), transparent);
    }

    /* Sleep architecture */
    .arch-insight {
      font-size: 12px; font-weight: 600; font-family: var(--font-mono); margin-bottom: 12px;
    }
    .arch-bar-premium {
      height: 12px; border-radius: 6px; overflow: hidden; display: flex; gap: 2px;
      margin-bottom: 18px;
    }
    .arch-seg { border-radius: 2px; transition: width 0.5s ease; min-width: 2px; }
    .arch-stages { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 14px; }
    .arch-stage-item { display: flex; align-items: center; gap: 8px; }
    .arch-stage-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
    .arch-stage-name {
      font-size: 9px; font-family: var(--font-mono); color: var(--text-tertiary);
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .arch-stage-val {
      font-size: 14px; font-weight: 600; font-family: var(--font-mono); color: var(--text-primary);
    }
    .arch-times { display: flex; gap: 7px; margin-top: 14px; flex-wrap: wrap; }
    .time-badge {
      padding: 3px 9px; border-radius: 20px; font-size: 10.5px; font-family: var(--font-mono);
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      color: var(--text-secondary);
    }

    /* Readiness */
    .readiness-status {
      font-size: 17px; font-weight: 700; font-family: var(--font-mono); margin-bottom: 3px;
    }
    .readiness-desc { font-size: 11px; color: var(--text-tertiary); margin-bottom: 14px; line-height: 1.5; }
    .readiness-level {
      height: 4px; border-radius: 3px; background: rgba(255,255,255,0.07); margin-bottom: 16px; overflow: hidden;
    }
    .readiness-level-fill { height: 100%; border-radius: 3px; transition: width 0.5s ease; }
    .readiness-indicators { display: flex; flex-direction: column; gap: 7px; }
    .ri-row { display: flex; align-items: center; justify-content: space-between; }
    .ri-label { font-size: 10.5px; color: var(--text-tertiary); font-family: var(--font-mono); }
    .ri-val { font-size: 10.5px; font-family: var(--font-mono); color: var(--text-secondary); }

    /* ── Chart ── */
    .chart-card {
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.055);
      border-radius: 14px; padding: 17px 18px;
    }
    .chart-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 12px; gap: 10px; flex-wrap: wrap;
    }
    .chart-toggle-group { display: flex; gap: 6px; align-items: center; }
    .chart-pills {
      display: flex; background: rgba(255,255,255,0.04); border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.08); padding: 2px; gap: 2px;
    }
    .cm-btn, .cp-btn {
      padding: 4px 11px; border-radius: 6px; border: none; background: none;
      font-size: 10px; font-family: var(--font-mono); letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--text-tertiary); cursor: pointer; transition: all 0.13s;
    }
    .cm-btn.active, .cp-btn.active { background: rgba(255,255,255,0.1); color: var(--text-primary); }
    .cm-btn:hover:not(.active), .cp-btn:hover:not(.active) { color: var(--text-secondary); }
    .chart-legend { display: flex; gap: 12px; margin-bottom: 11px; flex-wrap: wrap; }
    .chart-leg-item {
      display: flex; align-items: center; gap: 5px;
      font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary);
    }
    .chart-leg-dot  { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
    .chart-leg-line { width: 16px; height: 2px; border-top: 2px dashed rgba(255,255,255,0.22); flex-shrink: 0; }
    .chart-wrap { position: relative; height: 220px; }

    /* ── Misc ── */
    .empty-state {
      font-size: 11px; font-family: var(--font-mono);
      color: rgba(255,255,255,0.16); padding: 14px 0; text-align: center; line-height: 1.8;
    }

    /* ── Responsive ── */
    @media (max-width: 820px) { .mid-grid { grid-template-columns: 1fr; } }
    @media (max-width: 900px) { .metrics-grid { grid-template-columns: repeat(3,1fr); } }
    @media (max-width: 640px) {
      .metrics-grid { grid-template-columns: repeat(2,1fr); }
      .hero-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
      .mood-card { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
