<main class="sovn-page">

  <!-- Hero -->
  <div class="hero-card">
    <div id="heroInner">
      <div class="hero-inner"><div class="empty-state" data-i18n="loading">Laster…</div></div>
    </div>
  </div>

  <!-- Warning bar -->
  <div id="warnBar"></div>

  <!-- Metrics -->
  <div class="metrics-grid" id="metricsGrid"></div>

  <!-- Mid: Architecture + Readiness -->
  <div class="mid-grid">
    <div class="mid-card" id="archSection">
      <div class="card-lbl" data-i18n="sovn.architecture">Søvnarkitektur</div>
      <div class="empty-state" data-i18n="loading">Laster…</div>
    </div>
    <div class="mid-card" id="readinessSection">
      <div class="card-lbl" data-i18n="sovn.readiness">Treningsberedskap</div>
      <div class="empty-state" data-i18n="loading">Laster…</div>
    </div>
  </div>

  <!-- Chart -->
  <div class="chart-card">
    <div class="chart-header">
      <div class="chart-toggle-group">
        <div class="chart-pills">
          <button class="cm-btn active" data-metric="sleep"  onclick="setChartMetric('sleep')" data-i18n="nav.sovn">Søvn</button>
          <button class="cm-btn"        data-metric="hrv"    onclick="setChartMetric('hrv')">HRV</button>
          <button class="cm-btn"        data-metric="rhr"    onclick="setChartMetric('rhr')" data-i18n="sovn.rhr">Puls</button>
          <button class="cm-btn"        data-metric="score"  onclick="setChartMetric('score')" data-i18n="sovn.score_sub">Score</button>
        </div>
      </div>
      <div class="chart-toggle-group">
        <div class="chart-pills">
          <button class="cp-btn active" data-days="7"  onclick="setChartPeriod(7)">7d</button>
          <button class="cp-btn" data-days="14" onclick="setChartPeriod(14)">14d</button>
          <button class="cp-btn" data-days="30" onclick="setChartPeriod(30)">30d</button>
        </div>
      </div>
    </div>
    <div class="chart-legend" id="chartLegend"></div>
    <div class="chart-wrap">
      <canvas id="sleepChart"></canvas>
    </div>
  </div>

</main>

<div class="toast" id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script src="utils.js"></script>
<script>
let db;
document.querySelector('[data-p="sovn"]').classList.add('active');
applyLang();

// ── Sett inn Vercel-domenet ditt her ─────────────────────────────────────
const VERCEL_DOMAIN = 'https://filip-vita.vercel.app';
// ─────────────────────────────────────────────────────────────────────────

let todayEntry   = null;
let chartData    = [];
let chartInstance = null;
let chartMetric  = 'sleep';
let chartDays    = parseInt(localStorage.getItem('sovn_chart_days') || '7', 10);

// Date navigation
let viewDate = new Date().toLocaleDateString('sv'); // YYYY-MM-DD local

function offsetViewDate(delta) {
  const d = new Date(viewDate + 'T12:00:00');
  d.setDate(d.getDate() + delta);
  const next = d.toLocaleDateString('sv');
  const today = new Date().toLocaleDateString('sv');
  if (next > today) return; // can't go into the future
  viewDate = next;
  loadViewDate();
}

function isViewingToday() {
  return viewDate === new Date().toLocaleDateString('sv');
}

function minToHM(min) {
  if (!min) return '–';
  const h = Math.floor(min / 60), m = min % 60;
  return h > 0 ? `${h}t${m > 0 ? ' ' + m + 'm' : ''}` : `${m}m`;
}
function minToH(min) { return min ? +(min / 60).toFixed(2) : null; }
function sleepHoursStr(h) {
  if (!h) return '–';
  return `${Math.floor(h)}t${Math.round((h % 1) * 60) > 0 ? ' ' + Math.round((h % 1) * 60) + 'm' : ''}`;
}

// ── Smart insights ─────────────────────────────────────────────────────────
function getHeroText(d) {
  if (!d) return { main: t('sovn.no_data'), sub: t('sovn.sync_auto'), color:'var(--text-tertiary)' };
  const sc = d.sleep_score;
  if (!sc) {
    return { main: t('sovn.sleeping'), sub: d.sleep_hours ? t('sovn.registered', {d: sleepHoursStr(d.sleep_hours)}) : t('sovn.waiting'), color:'var(--text-secondary)' };
  }
  if (sc >= 85) return { main: t('sovn.recovery'),  sub: t('sovn.sprint_ready'), color:'#6BE3A4' };
  if (sc >= 70) return { main: t('sovn.solid'),      sub: t('sovn.train_ready'),  color:'#6BE3A4' };
  if (sc >= 55) return { main: t('sovn.moderate'),   sub: t('sovn.light_session'), color:'#F2C063' };
  return { main: t('sovn.hard'), sub: t('sovn.rest'), color:'#FF6B6B' };
}

function getArchInsight(d) {
  if (!d) return null;
  const total = (d.deep_sleep_minutes||0) + (d.rem_sleep_minutes||0) + (d.light_sleep_minutes||0);
  if (total < 10) return null;
  const deepPct = (d.deep_sleep_minutes||0) / total * 100;
  const remPct  = (d.rem_sleep_minutes||0)  / total * 100;
  if (deepPct < 10) return { text: t('sovn.arch_low_deep'),  color:'#F2C063' };
  if (remPct  < 14) return { text: t('sovn.arch_low_rem'),   color:'#F2C063' };
  if (deepPct > 22 && remPct > 20) return { text: t('sovn.arch_excellent'), color:'#6BE3A4' };
  if (deepPct > 18) return { text: t('sovn.arch_deep'),      color:'#6BE3A4' };
  if (remPct  > 22) return { text: t('sovn.arch_good_rem'),  color:'#4A9EE8' };
  return { text: t('sovn.arch_normal'), color:'var(--text-tertiary)' };
}

function getReadinessInsight(d) {
  if (!d || !d.sleep_score) return { status: t('sovn.missing'), desc:'', color:'var(--text-tertiary)', level:0 };
  const sc = d.sleep_score, hrv = d.hrv, rhr = d.rhr;
  if (sc >= 85 && rhr && rhr < 58)
    return { status: t('sovn.ready_high'),     desc: t('sovn.ready_high_desc'),     color:'#6BE3A4', level:100 };
  if (sc >= 70)
    return { status: t('sovn.ready_good'),     desc: t('sovn.ready_good_desc'),     color:'#6BE3A4', level:72 };
  if (sc >= 55)
    return { status: t('sovn.ready_moderate'), desc: t('sovn.ready_moderate_desc'), color:'#F2C063', level:45 };
  return { status: t('sovn.ready_rest'),       desc: t('sovn.ready_rest_desc'),     color:'#FF6B6B', level:20 };
}

// ── Render: Hero ───────────────────────────────────────────────────────────
function goToToday() {
  viewDate = new Date().toLocaleDateString('sv');
  loadViewDate();
  renderChart(chartMetric, chartDays);
}

function renderHero(d) {
  const el  = document.getElementById('heroInner');
  const sc  = d?.sleep_score;
  const txt = getHeroText(d);
  const cls = !sc ? '' : sc >= 80 ? ' score-good' : sc >= 60 ? ' score-ok' : ' score-bad';

  const chips = [];
  if (d?.sleep_hours)    chips.push(`🌙 ${sleepHoursStr(d.sleep_hours)}`);
  if (d?.rhr)            chips.push(`❤️ ${d.rhr} bpm`);
  if (d?.hrv != null)    chips.push(`⚡ HRV ${d.hrv}ms`);
  if (d?.awake_minutes)  chips.push(`👁 ${t('sovn.awake')} ${d.awake_minutes}min`);
  if (d?.sleep_start)    chips.push(`🛌 ${d.sleep_start}`);
  if (d?.sleep_end)      chips.push(`⏰ ${d.sleep_end}`);

  // Build tagline — include awake context
  let tagline = '';
  if (d?.sleep_hours) {
    tagline = t('sovn.you_slept') + sleepHoursStr(d.sleep_hours);
    if (d.awake_minutes) {
      const aw = d.awake_minutes;
      const awCtx = aw <= 5 ? t('sovn.awake_ctx_none') : aw <= 19 ? t('sovn.awake_ctx_good', {v:aw}) : aw <= 30 ? t('sovn.awake_ctx_acceptable', {v:aw}) : aw <= 50 ? t('sovn.awake_ctx_restless', {v:aw}) : t('sovn.awake_ctx_fragmented', {v:aw});
      tagline += ' · ' + awCtx;
    }
    if (txt.sub) tagline += ' · ' + txt.sub;
  } else {
    tagline = txt.sub;
  }

  // Date nav
  const today = new Date().toLocaleDateString('sv');
  const isToday = viewDate === today;
  const dispDate = new Date(viewDate + 'T12:00:00').toLocaleDateString(fmtLocale(), {weekday:'long', day:'numeric', month:'long'});

  const noData = !d || !d.sleep_score;
  el.innerHTML = `
    <div class="hero-inner">
      <div class="hero-score-box${cls}">
        <div class="hero-score-num" style="${sc && sc >= 80 ? 'color:#6BE3A4' : sc && sc >= 60 ? 'color:#F2C063' : sc && sc < 60 ? 'color:#FF6B6B' : ''}">${sc ?? '–'}</div>
        <div class="hero-score-lbl">${t('sovn.score_sub')}</div>
      </div>
      <div class="hero-right">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px">
          <button onclick="offsetViewDate(-1)" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:var(--text-tertiary);border-radius:6px;width:24px;height:24px;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0" title="${t('sovn.prev_day')}">‹</button>
          <div class="hero-date" style="margin:0">${dispDate}${isToday ? ' · ' + t('dash.today').toUpperCase() : ''}</div>
