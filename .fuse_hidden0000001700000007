  <div class="nav-inner">
    <div class="nav-tabs">
      <a href="ai.html"           class="nav-tab" data-p="ai"          data-i18n="nav.ai">AI</a>
      <a href="dashboard.html"    class="nav-tab" data-p="dashboard"   data-i18n="nav.dashboard">Dashboard</a>
