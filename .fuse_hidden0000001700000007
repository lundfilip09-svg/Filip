}

async function fetchSleepNow(btn) {
  const orig = btn.innerHTML;
  btn.innerHTML = `<span>⏳</span> ${t('sovn.fetching')}`;
  btn.style.pointerEvents = 'none';
  try {
    const today = new Date().toLocaleDateString('sv');
    const r = await fetch(`/api/garmin-sync?date=${today}&force=1`);
    const j = await r.json();
    if (j?.ok && j.data && (j.data.sleep_hours || j.data.sleep_score)) {
      toast(t('sovn.fetched')); loadToday(); loadChartData(); return;
    }
    toast(t('sovn.no_new'));
  } catch {
    toast(t('sovn.fetch_err'), 'err');
  }
  btn.innerHTML = orig;
  btn.style.pointerEvents = '';
}

// ── Render: Metrics ────────────────────────────────────────────────────────
// ── Metric analysis engine ─────────────────────────────────────────────────
function analyzeMetrics(d) {
  const results = [];

  // HRV
  if (d?.hrv) {
    const v = d.hrv;
    if (v >= 60)      results.push({ key:'hrv', val:`${v}ms`, label:'HRV', level:'ok',     badge: t('sovn.hrv_optimal'),  color:'#6BE3A4', glow:'rgba(107,227,164,0.14)', advice: t('sovn.hrv_advice_optimal') });
    else if (v >= 50) results.push({ key:'hrv', val:`${v}ms`, label:'HRV', level:'ok',     badge: t('sovn.hrv_good'),     color:'#6BE3A4', glow:'rgba(107,227,164,0.1)',  advice: t('sovn.hrv_advice_good') });
    else if (v >= 40) results.push({ key:'hrv', val:`${v}ms`, label:'HRV', level:'warn',   badge: t('sovn.hrv_low'),      color:'#F2C063', glow:'rgba(242,192,99,0.12)',  advice: t('sovn.hrv_advice_low') });
    else if (v >= 30) results.push({ key:'hrv', val:`${v}ms`, label:'HRV', level:'danger', badge: t('sovn.hrv_critical'), color:'#FF6B6B', glow:'rgba(255,107,107,0.14)', advice: t('sovn.hrv_advice_critical') });
    else              results.push({ key:'hrv', val:`${v}ms`, label:'HRV', level:'danger', badge: t('sovn.hrv_alarm'),    color:'#FF6B6B', glow:'rgba(255,107,107,0.18)', advice: t('sovn.hrv_advice_alarm') });
  }

  // RHR
  if (d?.rhr) {
    const v = d.rhr;
    // Grenser tilpasset ung sprinter — lav RHR er positivt, ikke alarm
    if (v <= 42)      results.push({ key:'rhr', val:`${v}`, label: t('sovn.rhr'), unit:'bpm', level:'ok',     badge: t('sovn.rhr_peak'),      color:'#6BE3A4', glow:'rgba(107,227,164,0.14)', advice: t('sovn.rhr_advice_peak') });
    else if (v <= 52) results.push({ key:'rhr', val:`${v}`, label: t('sovn.rhr'), unit:'bpm', level:'ok',     badge: t('sovn.rhr_excellent'),  color:'#6BE3A4', glow:'rgba(107,227,164,0.1)',  advice: t('sovn.rhr_advice_excellent') });
    else if (v <= 60) results.push({ key:'rhr', val:`${v}`, label: t('sovn.rhr'), unit:'bpm', level:'ok',     badge: t('sovn.rhr_normal'),     color:'#6BE3A4', glow:'rgba(107,227,164,0.08)', advice: t('sovn.rhr_advice_normal') });
    else if (v <= 68) results.push({ key:'rhr', val:`${v}`, label: t('sovn.rhr'), unit:'bpm', level:'warn',   badge: t('sovn.rhr_elevated'),   color:'#F2C063', glow:'rgba(242,192,99,0.12)',  advice: t('sovn.rhr_advice_elevated') });
    else if (v <= 78) results.push({ key:'rhr', val:`${v}`, label: t('sovn.rhr'), unit:'bpm', level:'danger', badge: t('sovn.rhr_high'),       color:'#FF6B6B', glow:'rgba(255,107,107,0.14)', advice: t('sovn.rhr_advice_high') });
    else              results.push({ key:'rhr', val:`${v}`, label: t('sovn.rhr'), unit:'bpm', level:'danger', badge: t('sovn.rhr_alarm'),      color:'#FF6B6B', glow:'rgba(255,107,107,0.18)', advice: t('sovn.rhr_advice_alarm') });
  }

  // Sleep hours
  if (d?.sleep_hours) {
    const v = d.sleep_hours;
    if (v >= 8)       results.push({ key:'sleep', val:sleepHoursStr(v), label: t('sovn.total'), level:'ok',     badge: t('sovn.sleep_optimal'), color:'#5BA4F5', glow:'rgba(91,164,245,0.12)',  advice: t('sovn.sleep_advice_optimal') });
    else if (v >= 7)  results.push({ key:'sleep', val:sleepHoursStr(v), label: t('sovn.total'), level:'ok',     badge: t('sovn.sleep_good'),    color:'#5BA4F5', glow:'rgba(91,164,245,0.1)',   advice: t('sovn.sleep_advice_good') });
    else if (v >= 6)  results.push({ key:'sleep', val:sleepHoursStr(v), label: t('sovn.total'), level:'warn',   badge: t('sovn.sleep_little'),  color:'#F2C063', glow:'rgba(242,192,99,0.12)',  advice: t('sovn.sleep_advice_little') });
    else              results.push({ key:'sleep', val:sleepHoursStr(v), label: t('sovn.total'), level:'danger', badge: t('sovn.sleep_critical'),color:'#FF6B6B', glow:'rgba(255,107,107,0.14)', advice: t('sovn.sleep_advice_critical') });
  }

  // Sleep score
  if (d?.sleep_score) {
    const v = d.sleep_score;
    if (v >= 85)      results.push({ key:'score', val:`${v}`, label: t('sovn.score_lbl'), unit:'/100', level:'ok',     badge: t('sovn.score_excellent'), color:'#6BE3A4', glow:'rgba(107,227,164,0.14)', advice: t('sovn.score_advice_excellent') });
    else if (v >= 70) results.push({ key:'score', val:`${v}`, label: t('sovn.score_lbl'), unit:'/100', level:'ok',     badge: t('sovn.score_good'),      color:'#6BE3A4', glow:'rgba(107,227,164,0.1)',  advice: t('sovn.score_advice_good') });
    else if (v >= 55) results.push({ key:'score', val:`${v}`, label: t('sovn.score_lbl'), unit:'/100', level:'warn',   badge: t('sovn.score_ok'),        color:'#F2C063', glow:'rgba(242,192,99,0.12)',  advice: t('sovn.score_advice_ok') });
    else              results.push({ key:'score', val:`${v}`, label: t('sovn.score_lbl'), unit:'/100', level:'danger', badge: t('sovn.score_bad'),       color:'#FF6B6B', glow:'rgba(255,107,107,0.14)', advice: t('sovn.score_advice_bad') });
  }

  // Awake time (WASO — wakefulness after sleep onset)
  // Reference: healthy young adults <20 min (Sleep Foundation). High-training athletes
  // average 30–48 min WASO (PMC8343120). Optimal target for a sprinter/lifter is <20 min.
  // <5 min = exceptional (deep uninterrupted sleep), 5–19 = solid, 20–30 = acceptable for
  // an athlete with high training load, 31–50 = starting to fragment, >50 = flag it.
  if (d?.awake_minutes != null) {
    const v = d.awake_minutes;
    if (v <= 5)       results.push({ key:'awake', val:`${v}`, label:t('sovn.awake'), unit:'min', level:'ok',     badge:t('sovn.awake_exceptional'), color:'#6BE3A4', glow:'rgba(107,227,164,0.14)', advice:t('sovn.awake_advice_exceptional', {v}) });
    else if (v <= 19) results.push({ key:'awake', val:`${v}`, label:t('sovn.awake'), unit:'min', level:'ok',     badge:t('sovn.awake_good'),        color:'#6BE3A4', glow:'rgba(107,227,164,0.08)', advice:t('sovn.awake_advice_good', {v}) });
    else if (v <= 30) results.push({ key:'awake', val:`${v}`, label:t('sovn.awake'), unit:'min', level:'ok',     badge:t('sovn.awake_acceptable'),  color:'var(--text-secondary)', glow:'', advice:t('sovn.awake_advice_acceptable', {v}) });
    else if (v <= 50) results.push({ key:'awake', val:`${v}`, label:t('sovn.awake'), unit:'min', level:'warn',   badge:t('sovn.awake_restless'),    color:'#F2C063', glow:'rgba(242,192,99,0.1)',   advice:t('sovn.awake_advice_restless', {v}) });
    else              results.push({ key:'awake', val:`${v}`, label:t('sovn.awake'), unit:'min', level:'danger', badge:t('sovn.awake_fragmented'),  color:'#FF6B6B', glow:'rgba(255,107,107,0.12)', advice:t('sovn.awake_advice_fragmented', {v}) });
  }

  return results;
}

function renderWarnings(metrics) {
  const el = document.getElementById('warnBar');
  const dangers = metrics.filter(m => m.level === 'danger');
  const warns   = metrics.filter(m => m.level === 'warn');

  if (!dangers.length && !warns.length) { el.innerHTML = ''; return; }

  const items = [...dangers, ...warns];
  const cls   = dangers.length ? 'warn-red' : 'warn-orange';
  const icon  = dangers.length ? '⚠️' : '💡';

  el.innerHTML = `<div class="warn-bar ${cls}">
    ${items.map(m => `
      <div class="warn-item">
        <div class="warn-icon">${icon}</div>
        <div class="warn-text">
          <div class="warn-title">${m.label}: ${m.badge}</div>
          <div class="warn-advice">${m.advice}</div>
        </div>
      </div>`).join('')}
  </div>`;
}

function renderMetrics(d) {
  const el = document.getElementById('metricsGrid');
  if (!d) { el.innerHTML = ''; renderWarnings([]); return; }

  const metrics = analyzeMetrics(d);
  renderWarnings(metrics);

  // Lag en map for rask oppslag
  const byKey = {};
  metrics.forEach(m => byKey[m.key] = m);

  // Alltid vis alle 5 kort i fast rekkefølge
  const cards = [
    byKey['score'] || { key:'score', val:'–', label: t('sovn.score_lbl'), unit:'/100', level:'none', badge:'', color:'', glow:'', advice:'' },
    byKey['sleep'] || { key:'sleep', val:'–', label: t('sovn.total'),     level:'none', badge:'', color:'#5BA4F5', glow:'', advice:'' },
    byKey['rhr']   || { key:'rhr',   val:'–', label: t('sovn.rhr'),       unit:'bpm',  level:'none', badge:'', color:'', glow:'', advice:'' },
    byKey['hrv']   || { key:'hrv',   val:'–', label:'HRV',                unit:'ms',   level:'none', badge:'', color:'', glow:'', advice:'' },
    byKey['awake'] || { key:'awake', val:'–', label:t('sovn.awake'),       unit:'min',  level:'none', badge:'', color:'', glow:'', advice:'' },
  ];

  el.innerHTML = cards.map(m => `
    <div class="metric-card" style="${m.glow ? `box-shadow:0 0 28px ${m.glow};border-color:${m.color}22` : ''}">
      <div class="mc-top-lbl">${m.label}</div>
      <div class="mc-val" style="${m.color ? `color:${m.color}` : ''}">${m.val}</div>
      ${m.unit ? `<div class="mc-unit">${m.unit}</div>` : ''}
      ${m.badge ? `<div class="mc-status-badge" style="color:${m.color};border-color:${m.color}55;background:${m.color}11">${m.badge}</div>` : ''}
      ${m.advice ? `<div class="mc-advice">${m.advice}</div>` : ''}
    </div>`
  ).join('');
}

// ── Render: Sleep Architecture ─────────────────────────────────────────────
function renderArch(d) {
  const el = document.getElementById('archSection');
  const hasFaser = d?.deep_sleep_minutes || d?.rem_sleep_minutes || d?.light_sleep_minutes;

  if (!d || !hasFaser) {
    el.innerHTML = `<div class="card-lbl">${t('sovn.architecture')}</div><div class="empty-state">${t('sovn.no_phase')}</div>`;
    return;
  }

  const total = (d.deep_sleep_minutes||0) + (d.rem_sleep_minutes||0) + (d.light_sleep_minutes||0) + (d.awake_minutes||0);
  const pct    = m => total > 0 ? ((m||0)/total*100).toFixed(1) : 0;
  const pctN   = m => total > 0 ? (m||0)/total*100 : 0;
  const insight = getArchInsight(d);

  const stages = [
    { name: t('sovn.deep'),  mins:d.deep_sleep_minutes,  color:'#7C6FD4' },
    { name: t('sovn.rem'),   mins:d.rem_sleep_minutes,   color:'#4A9EE8' },
    { name: t('sovn.light'), mins:d.light_sleep_minutes, color:'#6BE3A4' },
  ];
  if (d.awake_minutes) stages.push({ name: t('sovn.awake'), mins:d.awake_minutes, color:'rgba(255,255,255,0.15)' });

  el.innerHTML = `
    <div class="card-lbl">${t('sovn.architecture')}</div>
    ${insight ? `<div class="arch-insight" style="color:${insight.color}">${insight.text}</div>` : ''}
    <div class="arch-bar-premium">
      ${stages.map(s => pctN(s.mins) > 0.5 ? `<div class="arch-seg" style="width:${pctN(s.mins)}%;background:${s.color}" title="${s.name}: ${pct(s.mins)}%"></div>` : '').join('')}
    </div>
    <div class="arch-stages">
      ${stages.filter(s => s.mins).map(s => `
        <div class="arch-stage-item">
          <div class="arch-stage-dot" style="background:${s.color}"></div>
          <div>
            <div class="arch-stage-name">${s.name}</div>
            <div class="arch-stage-val">${minToHM(s.mins)} <span style="opacity:0.45;font-size:9px">${pct(s.mins)}%</span></div>
          </div>
        </div>`).join('')}
    </div>
    ${(d.sleep_start || d.sleep_end) ? `
    <div class="arch-times">
      ${d.sleep_start ? `<div class="time-badge">🛌 ${d.sleep_start}</div>` : ''}
      ${d.sleep_end   ? `<div class="time-badge">⏰ ${d.sleep_end}</div>`   : ''}
    </div>` : ''}`;
}

// ── Render: Readiness ──────────────────────────────────────────────────────
function renderReadiness(d) {
  const el = document.getElementById('readinessSection');
  const r  = getReadinessInsight(d);

  const indicators = [];
  if (d?.sleep_score) {
    const sc = d.sleep_score;
    indicators.push({ label: t('sovn.score_lbl'), val:`${sc}/100`, status: sc >= 80 ? t('sovn.score_good') : sc >= 60 ? t('sovn.score_ok') : t('sovn.score_bad'), color: sc >= 80 ? '#6BE3A4' : sc >= 60 ? '#F2C063' : '#FF6B6B' });
  }
  if (d?.hrv) {
    const hrv = d.hrv;
    indicators.push({ label:'HRV', val:`${hrv}ms`, status: hrv >= 50 ? t('sovn.hrv_good') : hrv >= 35 ? t('sovn.hrv_low') : t('sovn.hrv_critical'), color: hrv >= 50 ? '#6BE3A4' : hrv >= 35 ? '#F2C063' : '#FF6B6B' });
  }
  if (d?.rhr) {
    const rhr = d.rhr;
    indicators.push({ label: t('sovn.rhr'), val:`${rhr} bpm`, status: rhr < 53 ? 'Optimal ✓' : rhr < 61 ? t('sovn.rhr_normal') : rhr < 69 ? t('sovn.rhr_elevated') : t('sovn.rhr_high'), color: rhr < 61 ? '#6BE3A4' : rhr < 69 ? '#F2C063' : '#FF6B6B' });
  }

  el.innerHTML = `
    <div class="card-lbl">${t('sovn.readiness')}</div>
    <div class="readiness-status" style="color:${r.color}">${r.status}</div>
    ${r.desc ? `<div class="readiness-desc">${r.desc}</div>` : ''}
    <div class="readiness-level">
      <div class="readiness-level-fill" style="width:${r.level}%;background:${r.color}"></div>
    </div>
    <div class="readiness-indicators">
      ${indicators.map(i => `
        <div class="ri-row">
          <span class="ri-label">${i.label}</span>
          <span style="font-size:10.5px;font-family:var(--font-mono);color:${i.color}">${i.status}</span>
        </div>`).join('')}
    </div>
    ${!d ? `<div class="empty-state" style="margin-top:8px">${t('sovn.no_today')}</div>` : ''}`;
}

