        <button onclick="fetchSleepNow(this)" style="
          margin-top:14px; display:inline-flex; align-items:center; gap:7px;
          background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.11);
          color:var(--text-secondary); font-family:var(--font-mono); font-size:11px;
          padding:7px 13px; border-radius:7px; cursor:pointer; transition:all 0.15s;
