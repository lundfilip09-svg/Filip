function renderChart(metric, days) {
  const dayNames = _lang === 'en' ? ['sun','mon','tue','wed','thu','fri','sat'] : ['søn','man','tir','ons','tor','fre','lør'];
  const labels = [], dates = [];
  for (let i = days - 1; i >= 0; i--) {
    const d = new Date(); d.setDate(d.getDate() - i);
    labels.push(`${dayNames[d.getDay()]} ${d.getDate()}`);
    dates.push(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`);
  }
  const find = ds => chartData.find(r => r.date === ds);

  if (chartInstance) { chartInstance.destroy(); chartInstance = null; }
  updateChartLegend(metric);

  // Fjern evt. gammel overlay
  const wrap = document.querySelector('.chart-wrap');
  const old = wrap.querySelector('.chart-overlay');
  if (old) old.remove();

  let datasets, isLine = false, yMax, yLabel;

  if (metric === 'sleep') {
    const deepV  = dates.map(ds => { const e=find(ds); return e?.deep_sleep_minutes  ? minToH(e.deep_sleep_minutes)  : null; });
    const remV   = dates.map(ds => { const e=find(ds); return e?.rem_sleep_minutes   ? minToH(e.rem_sleep_minutes)   : null; });
    const lightV = dates.map(ds => {
      const e = find(ds); if (!e) return null;
      if (e.light_sleep_minutes) return minToH(e.light_sleep_minutes);
      if (e.sleep_hours && !e.deep_sleep_minutes) return e.sleep_hours;
      return null;
    });
    const awakeV = dates.map(ds => { const e=find(ds); return e?.awake_minutes ? minToH(e.awake_minutes) : null; });
    datasets = [
      { label:t('sovn.leg_deep'),  data:deepV,  backgroundColor:'rgba(124,111,212,0.82)', borderColor:'#7C6FD4', borderWidth:1, stack:'s', borderRadius:{topLeft:0,topRight:0} },
      { label:t('sovn.leg_rem'),   data:remV,   backgroundColor:'rgba(74,158,232,0.82)',  borderColor:'#4A9EE8', borderWidth:1, stack:'s', borderRadius:{topLeft:0,topRight:0} },
      { label:t('sovn.leg_light'), data:lightV, backgroundColor:'rgba(107,227,164,0.55)', borderColor:'#6BE3A4', borderWidth:1, stack:'s', borderRadius:{topLeft:0,topRight:0} },
      { label:t('sovn.awake'),     data:awakeV, backgroundColor:'rgba(255,255,255,0.18)', borderColor:'rgba(255,255,255,0.3)', borderWidth:1, stack:'s', borderRadius:{topLeft:4,topRight:4} },
      { label:t('sovn.goal_8h'), data:Array(days).fill(8), type:'line', borderColor:'rgba(255,255,255,0.2)', borderDash:[5,4], borderWidth:1.5, pointRadius:0, fill:false, stack:undefined },
    ];
    yMax = 12; yLabel = t('sovn.hours');

  } else if (metric === 'hrv') {
    const vals = dates.map(ds => { const e=find(ds); return e?.hrv || null; });
    datasets = [{ label:'HRV', data:vals, borderColor:'#4A9EE8', backgroundColor:'rgba(74,158,232,0.09)', borderWidth:2, fill:true, tension:0.4, pointRadius:3, pointBackgroundColor:'#4A9EE8', pointHoverRadius:5, pointBorderColor:'transparent' }];
    isLine = true; yLabel = 'ms';

  } else if (metric === 'rhr') {
    const vals = dates.map(ds => { const e=find(ds); return e?.rhr || null; });
    datasets = [{ label:t('sovn.rhr'), data:vals, borderColor:'#FF6B6B', backgroundColor:'rgba(255,107,107,0.09)', borderWidth:2, fill:true, tension:0.4, pointRadius:3, pointBackgroundColor:'#FF6B6B', pointHoverRadius:5, pointBorderColor:'transparent' }];
    isLine = true; yLabel = 'bpm';

  } else if (metric === 'score') {
    const vals = dates.map(ds => { const e=find(ds); return e?.sleep_score || null; });
    datasets = [{
      label:t('sovn.score_lbl'), data:vals,
      backgroundColor: vals.map(v => !v ? 'transparent' : v >= 80 ? 'rgba(107,227,164,0.75)' : v >= 60 ? 'rgba(242,192,99,0.75)' : 'rgba(255,107,107,0.75)'),
      borderColor:      vals.map(v => !v ? 'transparent' : v >= 80 ? '#6BE3A4' : v >= 60 ? '#F2C063' : '#FF6B6B'),
      borderWidth:1, borderRadius:4,
    }];
    yMax = 100; yLabel = t('sovn.score_sub');
  }

  const ctx = document.getElementById('sleepChart').getContext('2d');
  chartInstance = new Chart(ctx, {
    type: isLine ? 'line' : 'bar',
    data: { labels, datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: { duration: 380 },
      onClick: (e, els) => {
        if (!els.length) return;
        const ds = dates[els[0].index];
        if (!ds || ds === viewDate) return;
        viewDate = ds;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        loadViewDate();
        setTimeout(() => renderChart(chartMetric, chartDays), 50);
      },
      onHover: (e, els) => { if (e?.native?.target) e.native.target.style.cursor = els.length ? 'pointer' : 'default'; },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor:'rgba(10,10,13,0.97)', titleColor:'#FAFAFA', bodyColor:'#B8B6B0',
          borderColor:'rgba(255,255,255,0.08)', borderWidth:1, padding:10, cornerRadius:8,
          filter: item => item.dataset.label !== '8t mål' && item.parsed.y > 0,
          callbacks: {
            label: ctx => {
              if (metric === 'sleep') return `${ctx.dataset.label}: ${ctx.parsed.y.toFixed(1)}${_lang === 'en' ? 'h' : 't'}`;
              return `${ctx.dataset.label}: ${ctx.parsed.y}`;
            },
          },
        },
      },
      scales: {
        x: {
          stacked: metric === 'sleep',
          grid: { color:'rgba(255,255,255,0.04)', drawBorder:false },
          ticks: { color:(c)=>dates[c.index]===viewDate?'#FAFAFA':'#6B6964', font:{family:'ui-monospace',size:9}, maxRotation:45, maxTicksLimit:days <= 14 ? 14 : 16 },
        },
        y: {
          stacked: metric === 'sleep',
          min: 0, ...(yMax ? { max:yMax } : {}),
          grid: { color:'rgba(255,255,255,0.05)', drawBorder:false },
          ticks: { color:'#6B6964', font:{family:'ui-monospace',size:9} },
          title: { display:true, text:yLabel, color:'rgba(255,255,255,0.18)', font:{size:9} },
        },
      },
    },
  });

  // Vis melding hvis lite historikk
  if (chartData.length < 3) {
    const ov = document.createElement('div');
    ov.className = 'chart-overlay';
    ov.style.cssText = 'position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none';
    ov.innerHTML = `<div style="font-size:11px;font-family:var(--font-mono);color:rgba(255,255,255,0.2);text-align:center;line-height:1.8">
      ${chartData.length === 1 ? t('sovn.1day') : t('sovn.no_history')}<br>
      <span style="font-size:10px;color:rgba(255,255,255,0.1)">${t('sovn.auto_fill')}</span>
    </div>`;
    wrap.appendChild(ov);
  }
}

async function loadChartData() {
  const cutoff = new Date(); cutoff.setDate(cutoff.getDate() - 29);
  const { data } = await db.from('health_data')
    .select('date,sleep_hours,deep_sleep_minutes,rem_sleep_minutes,light_sleep_minutes,awake_minutes,hrv,rhr,sleep_score')
    .gte('date', `${cutoff.getFullYear()}-${String(cutoff.getMonth()+1).padStart(2,'0')}-${String(cutoff.getDate()).padStart(2,'0')}`).order('date');
  chartData = data || [];
  renderChart(chartMetric, chartDays);
}

function setChartMetric(metric) {
  chartMetric = metric;
  document.querySelectorAll('.cm-btn').forEach(b => b.classList.toggle('active', b.dataset.metric === metric));
  renderChart(metric, chartDays);
}

function setChartPeriod(days) {
  chartDays = days;
  localStorage.setItem('sovn_chart_days', days);
  document.querySelectorAll('.cp-btn').forEach(b => b.classList.toggle('active', b.dataset.days === String(days)));
  renderChart(chartMetric, days);
}


// ── Init ───────────────────────────────────────────────────────────────────
(async () => {
  try {
    const cfg = await getConfig();
    db = supabase.createClient(cfg.supabaseUrl, cfg.supabaseAnonKey);
    const { data: { session } } = await db.auth.getSession();
    if (!session) { window.location.href = 'login.html'; return; }
  } catch (err) {
    document.querySelector('.sovn-page').innerHTML =
      `<div class="card" style="text-align:center;padding:40px">
        <div style="color:var(--danger);font-family:var(--font-mono);font-size:13px">${err.message}</div>
      </div>`;
    return;
  }
  // Re-render everything when language switches (re-calls all render fns)
  window.onLangChange = () => renderStats(todayEntry);
  applyLang();
  // Sett riktig periode-knapp aktiv
  document.querySelectorAll('.cp-btn').forEach(b => b.classList.toggle('active', b.dataset.days === String(chartDays)));
  await Promise.all([loadToday(), loadChartData()]);
  // Hent søvn automatisk hvis de siste dagene mangler (null oppsett for brukeren)
  autoSyncSleep().then(got => {
    if (got) { toast(t('sovn.fetched')); loadToday(); loadChartData(); }
  });
})();
</script>
