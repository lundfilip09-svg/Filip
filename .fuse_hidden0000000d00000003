    .set-remove { width: 22px; height: 22px; border-radius: 50%; background: transparent; border: 1px solid rgba(255,255,255,0.15); color: var(--text-tertiary); font-size: 14px; line-height: 1; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.12s; }
