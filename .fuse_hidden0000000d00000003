  const ti = document.getElementById(`ti-${id}`);
  if (!tb) return;
  const open = tb.style.display === 'block';
  tb.style.display = open ? 'none' : 'block';
  ti?.classList.toggle('open', !open);
}

function updateNotesCount() {
  const ta  = document.getElementById('sidebarNotes');
  const el  = document.getElementById('notesVal');
  if (!el || !ta) return;
  const n = ta.value.trim().split('\n').filter(l => l.trim()).length;
