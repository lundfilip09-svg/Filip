}

// ── Init ───────────────────────────────────────────────────────────
async function init() {
  document.getElementById('logDate').value = today();
  applyLang();
  // Request notification permission on load so timer fires system alerts
  if (typeof Notification !== 'undefined' && Notification.permission === 'default')
    Notification.requestPermission();

  let saved = null;
  try { saved = JSON.parse(localStorage.getItem(SESSION_KEY) || 'null'); } catch(e) {}

  // A6: last data (inkl. gymDays) FØR vi avgjør aktiv dag, så pills kan rendres.
  await loadData();

  // Restore active day — session key wins, then draft, then detectDay()
  let wantDay = null;
  if (saved?.activeDay) {
    wantDay = saved.activeDay;
  } else {
    try {
      const dr = JSON.parse(localStorage.getItem(DRAFT_KEY) || 'null');
      if (dr?.activeDay) wantDay = dr.activeDay;
    } catch(e) {}
  }
  // Bruk lagret dag bare hvis den fortsatt finnes, ellers detectDay().
  activeDay = (wantDay && getDay(wantDay)) ? wantDay : detectDay();

  setDay(activeDay);

  if (saved?.workoutStartedAt && tryRestoreSession(saved)) {
    setWS('active');
    elapsedTimer = setInterval(() => { updateElapsed(); updateRingTimer(); }, 1000);
    renderAll();
    setSbPhase('during');
    updateProgress();
    updateNextEx();
    updateSbActiveEx(null);
    buildPainButtons();
    ['before','during','after','day-after'].forEach(p => {
      if (kneePain[p] !== null && kneePain[p] !== undefined) selectPain(p, kneePain[p]);
    });
    if (saved.notes) {
      const el = document.getElementById('sidebarNotes');
      if (el) { el.value = saved.notes; updateNotesCount(); }
    }
    if (getRestRemaining() > 0) {
      resumeRestTimer();
      const pb = document.getElementById('restPauseBtn');
      if (pb) { pb.textContent = '⏸'; pb.disabled = false; }
    }
    toast(t('gym.session_saved'));
  } else {
    restoreDraft();   // populates setData + kneePain before rendering
    renderAll();
    buildPainButtons();
    // Re-highlight pain buttons now that they exist in the DOM
    ['before','during','after','day-after'].forEach(p => {
      if (kneePain[p] !== null && kneePain[p] !== undefined) selectPain(p, kneePain[p]);
    });
  }

  // Persist draft on notes / date changes
  ['sessionNotes','sidebarNotes','logDate'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', saveDraft);
    document.getElementById(id)?.addEventListener('change', saveDraft);
  });

  renderGymRpe();   // RPE-slider for økta

  onLangChange = () => {
    const openEx = activeDrawer;   // bevar åpen drawer over språkbytte
    loadGymHistory();
    renderDayPills();
    const d = getDay(activeDay);
    const wt = document.getElementById('workoutTitle');
    if (wt && d) wt.textContent = dayLabel(d);
    renderAll();                   // re-rendrer vektinput i gjeldende enhet
    renderGymRpe(rpeValue('gymRpe'));
    applyLang();
    if (openEx) { activeDrawer = null; openDrawer(openEx); }   // gjenåpne + konverter sett-vekter
  };
  await loadGymHistory();
  await checkDayAfterRehab();
  applyLang();
}

async function loadData() {
  const [prog, wts, days] = await Promise.all([
    db.from('workout_program').select('*').order('sort_order'),
    db.from('exercise_weights').select('*'),
    db.from('gym_days').select('*').order('sort_order'),
  ]);
  // A6: dag-registeret. Fallback til de gamle hardkodede dagene hvis tabellen
  // ikke finnes ennå (migrasjon 016 ikke kjørt).
  gymDays = (days.data && days.data.length) ? days.data : [
    { day_key: 'monday',    weekday: 1, type_label: 'daytype.strength_capacity', is_protected: false, sort_order: 0 },
    { day_key: 'wednesday', weekday: 3, type_label: 'daytype.mobility',          is_protected: false, sort_order: 1 },
    { day_key: 'friday',    weekday: 5, type_label: 'daytype.strength_power',     is_protected: false, sort_order: 2 },
    { day_key: 'rehab',     weekday: null, type_label: 'daytype.rehab',          is_protected: true,  sort_order: 99 },
  ];
  allExercises = {};
  (prog.data || []).forEach(ex => {
    if (!allExercises[ex.day]) allExercises[ex.day] = {};
    if (!allExercises[ex.day][ex.section]) allExercises[ex.day][ex.section] = [];
    allExercises[ex.day][ex.section].push(ex);
  });
  weights = {};
  (wts.data || []).forEach(w => {
    if (w.exercise_id) weights[w.exercise_id] = w.weight_kg;
    else if (w.exercise_name) weights[w.exercise_name] = w.weight_kg;
  });
  _applyLocalExOrders();
  await seedRehabIfEmpty();
  await migrateWarmupData();
}

// ── Exercise order localStorage helpers ───────────────────────────
function _exOrdKey(day, section) { return `ex_ord__${day}__${section}`; }
function _saveLocalExOrder(day, section, ids) {
  try { localStorage.setItem(_exOrdKey(day, section), JSON.stringify(ids.map(String))); } catch {}
}
function _applyLocalExOrders() {
  // Strength sections
  for (const day of Object.keys(allExercises)) {
    for (const section of Object.keys(allExercises[day])) {
      try {
        const saved = JSON.parse(localStorage.getItem(_exOrdKey(day, section)));
        if (!saved?.length) continue;
        const reordered = saved.map(id => allExercises[day][section].find(e => String(e.id) === id)).filter(Boolean);
        if (reordered.length === allExercises[day][section].length) allExercises[day][section] = reordered;
      } catch {}
    }
  }
  // Warmup: apply sort_orders from saved list
  try {
    const saved = JSON.parse(localStorage.getItem('ex_ord__warmup'));
    if (saved?.length) {
      saved.forEach((id, idx) => {
        for (const wmDay of ['warmup', 'friday_warmup']) {
          for (const exs of Object.values(allExercises[wmDay] || {})) {
            const ex = exs.find(e => String(e.id) === String(id));
            if (ex) { ex.sort_order = idx; return; }
          }
        }
      });
    }
  } catch {}
}

