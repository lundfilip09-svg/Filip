// ── Warmup ─────────────────────────────────────────────────────────
function renderWarmup() {
  const el    = document.getElementById('warmupContent');
  const isFri = activeDay === 'friday';
  const base  = allExercises['warmup'] || {};
  const fri   = allExercises['friday_warmup'] || {};

  // Sykkel section key for each bucket
  const baseCirKey = base['Sirkulasjon'] ? 'Sirkulasjon' : 'Sykkel';
  const friCirKey  = fri['Sirkulasjon']  ? 'Sirkulasjon' : 'Sykkel';

  // Combined approach:
  //   Monday  → base exercises only
  //   Friday  → base exercises (shared, sykkel excluded) + friday_warmup (Friday sykkel + extras)
  const allWmExs = [];
  if (isFri) {
    for (const [sec, exs] of Object.entries(base)) {
      if (sec === baseCirKey) continue; // Friday has its own sykkel in friday_warmup
      for (const ex of exs) allWmExs.push({ ex, isSyk: false });
    }
    for (const [sec, exs] of Object.entries(fri)) {
      for (const ex of exs) allWmExs.push({ ex, isSyk: sec === friCirKey });
    }
  } else {
    for (const [sec, exs] of Object.entries(base)) {
      for (const ex of exs) allWmExs.push({ ex, isSyk: sec === baseCirKey });
    }
  }

  // Sort by sort_order (null → last)
  allWmExs.sort((a, b) => (a.ex.sort_order ?? Infinity) - (b.ex.sort_order ?? Infinity));

  document.getElementById('warmupBadge').textContent =
    allWmExs.length ? `${allWmExs.length} ${t('gym.exercises_lc')}` : '—';

  let zoneHtml = '';
  allWmExs.forEach(({ ex, isSyk }, i) => {
    const exDay     = ex.day || (isFri ? 'friday_warmup' : 'warmup');
    const cirKeyFallback = exDay === 'friday_warmup' ? friCirKey : baseCirKey;
    if (isSyk) {
      zoneHtml += `<div class="ex-row-wrap" id="ex-row-wrap-${ex.id}"
        draggable="true" data-exid="${ex.id}" data-day="${escHtml(exDay)}" data-section="${escHtml(ex.section || cirKeyFallback)}"
        ondragstart="exDragStart(event)" ondragend="exDragEnd(event)">
        <div class="circ-row">
          <span class="ex-drag-handle" onclick="event.stopPropagation()">⠿</span>
          <div class="circ-icon">🚴</div>
          <div>
            <div class="circ-name">${escHtml(ex.exercise_name)}</div>
            <div class="circ-meta">${escHtml(ex.reps || '8–10 min')}</div>
          </div>
        </div>
      </div>`;
    } else {
      zoneHtml += renderExRow(ex, exDay, i + 1, true);
    }
  });

  const wmAddDay = isFri ? 'friday_warmup' : 'warmup';
  const addId = `add-${wmAddDay}-Prepøvelser`;
  const addHtml = `<div class="add-ex-form" id="${addId}">
    <input class="input-sm" placeholder="${t('gym.exercise_ph')}" id="${addId}-name">
    <input class="input-sm w-short" type="number" placeholder="${t('gym.sets_ph')}" id="${addId}-sets">
    <input class="input-sm w-short" placeholder="${t('gym.reps_ph')}" id="${addId}-reps">
    <button class="btn btn-success btn-sm" onclick="addExercise('${wmAddDay}','Prepøvelser','${addId}')">+</button>
    <button class="btn btn-ghost btn-sm" onclick="document.getElementById('${addId}').classList.remove('open')">✕</button>
  </div>
  <button class="add-ex-btn" onclick="document.getElementById('${addId}').classList.toggle('open')">${t('gym.add_exercise_btn')}</button>`;

  el.innerHTML = zoneHtml
    ? `<div id="warmup-drag-zone" data-wm-zone="1"
        ondragover="wmDragOver(event)" ondragleave="wmDragLeave(event)" ondrop="wmDrop(event)">
        ${zoneHtml}
      </div>${addHtml}`
    : `<div class="empty">${t('gym.no_warmup_data')}</div>${addHtml}`;
}

// ── B1: Progressive Overload-coach ──────────────────────────────────
const PO_PAIN_LIMIT = 4;   // logget knesmerte > dette ⇒ ikke foreslå progresjon
let _poCache = {};         // exercise_name → siste sett-historikk (per sesjon)

async function renderOverloadCoach() {
  const card = document.getElementById('poCard');
  const body = document.getElementById('poBody');
  if (!card || !body) return;
  // Rehab-dagen har ingen vektprogresjon → skjul coachen der.
  if (activeDay === 'rehab') { card.style.display = 'none'; return; }
  const dayExs = getSortedMainExercises();
  if (!dayExs.length) { card.style.display = 'none'; return; }

  const names = [...new Set(dayExs.map(e => e.exercise_name))];
  const { data, error } = await db.from('set_log')
    .select('exercise_name,weight_kg,reps,date,knee_max')
    .in('exercise_name', names)
    .order('date', { ascending: false })
    .limit(400);
  if (error) { card.style.display = 'none'; return; }

  // Grupper per øvelse → per dato (én "økt" = ett datapunkt, beste vekt den dagen)
  const byEx = {};
  (data || []).forEach(r => {
    (byEx[r.exercise_name] ||= {});
    const d = byEx[r.exercise_name];
    if (!d[r.date] || (r.weight_kg ?? 0) > (d[r.date].weight_kg ?? 0)) {
      d[r.date] = { weight_kg: r.weight_kg, reps: r.reps, knee_max: r.knee_max };
    }
  });

  if (!Object.keys(byEx).length) {
    card.style.display = '';
    body.innerHTML = `<div class="po-empty">${t('po.no_data')}</div>`;
    return;
  }

  const rows = names.map(name => {
    const hist = byEx[name];
    if (!hist) return '';
    const dates = Object.keys(hist).sort().reverse();   // nyeste først
    const last  = hist[dates[0]];
    const lastW = last.weight_kg;
    const lastR = last.reps || '';
    const lastPain = last.knee_max ?? 0;

    // Platå: hvor mange påfølgende økter (fra nyeste) med samme vekt
    let plateau = 1;
    for (let i = 1; i < dates.length; i++) {
      if ((hist[dates[i]].weight_kg ?? null) === (lastW ?? null)) plateau++;
      else break;
    }

    let recCls, recTxt;
    if (lastPain > PO_PAIN_LIMIT) {
      recCls = 'hold'; recTxt = t('po.hold_pain', { p: lastPain });
    } else if (lastW != null && lastW > 0) {
      if (plateau >= 3) { recCls = 'hold'; recTxt = t('po.plateau', { n: plateau }); }
      else {
        const next = Math.round((lastW + 2.5) * 2) / 2;   // +2.5 kg, halvkilo-presisjon (kanonisk)
        recCls = 'up'; recTxt = t('po.try', { w: fromKg(next) });
      }
    } else {
      recCls = 'flat'; recTxt = t('po.keep');
    }

    const lastLbl = lastW != null
      ? t('po.last', { w: fromKg(lastW), r: lastR })
      : (lastR ? t('po.try_reps', { r: lastR }) : '');
    return `<div class="po-item">
      <span class="po-ex">${escHtml(name)}</span>
      <span class="po-last">${escHtml(lastLbl)}</span>
      <span class="po-rec ${recCls}">${escHtml(recTxt)}</span>
    </div>`;
  }).filter(Boolean).join('');

  card.style.display = '';
  body.innerHTML = rows || `<div class="po-empty">${t('po.no_data')}</div>`;
}

// ── Workout ────────────────────────────────────────────────────────
function renderWorkout() {
  const el  = document.getElementById('workoutBlocks');
  const day = allExercises[activeDay] || {};
  const sections = Object.entries(day);
  // A6: tom (egendefinert) dag → vis "ingen seksjoner" + legg-til, ikke "laster".
  const body = sections.length
    ? sections.map(([sec, exs]) => renderSectionBlock(sec, exs, activeDay)).join('')
    : `<div class="empty" style="padding:14px 2px">${t('gym.no_sections_yet')}</div>`;
  el.innerHTML = body + renderAddSection(activeDay);
}

// A6: legg-til-seksjon-skjema, tilgjengelig på alle dager (også egendefinerte).
function renderAddSection(day) {
  const id = `add-section-${day}`;
  return `<div class="add-section-wrap">
    <div class="add-ex-form" id="${id}">
      <input class="input-sm" placeholder="${t('gym.section_name_ph')}" id="${id}-name">
      <button class="btn btn-success btn-sm" onclick="addSection('${escHtml(day)}','${id}')">+</button>
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('${id}').classList.remove('open')">✕</button>
    </div>
    <button class="add-ex-btn" onclick="document.getElementById('${id}').classList.toggle('open')"
      data-i18n="gym.add_section">+ Seksjon</button>
  </div>`;
}

async function addSection(day, formId) {
  const name = document.getElementById(`${formId}-name`).value.trim();
  if (!name) return;
  if (allExercises[day]?.[name]) { toast(t('gym.section_exists'), 'err'); return; }
  // Seksjoner finnes som "kolonner" via øvelser. Vi oppretter en tom seksjon i
  // minnet; den persisteres så snart første øvelse legges til (workout_program
  // har ingen egen seksjonstabell).
  if (!allExercises[day]) allExercises[day] = {};
  allExercises[day][name] = [];
  document.getElementById(formId).classList.remove('open');
  document.getElementById(`${formId}-name`).value = '';
  renderAll();
  toast(t('gym.section_added'));
}

function renderSectionBlock(label, exs, day) {
  const addId   = `add-${day}-${label.replace(/\s/g,'_')}`;
  const isMulti = exs.length > 1;
  const totSets = exs.reduce((a, e) => a + e.sets, 0);
  return `<div class="ex-section${isMulti ? ' multi' : ''}" data-day="${escHtml(day)}" data-section="${escHtml(label)}"
    ondragover="exSecDragOver(event)" ondragleave="exSecDragLeave(event)" ondrop="exSecDrop(event)">
    <div class="sec-hd">
      <span class="sec-label">${escHtml(label)}</span>
      <span class="sec-divider"></span>
      <span class="sec-count">${exs.length} ${t('gym.ex_unit')} · ${totSets} ${t('gym.sets_unit')}</span>
    </div>
    ${exs.map((ex, i) => renderExRow(ex, day, i + 1, false)).join('')}
    <div class="add-ex-form" id="${addId}">
      <input class="input-sm" placeholder="${t('gym.exercise_ph')}" id="${addId}-name">
      <input class="input-sm w-short" type="number" placeholder="${t('gym.sets_ph')}" id="${addId}-sets">
      <input class="input-sm w-short" placeholder="${t('gym.reps_ph')}" id="${addId}-reps">
      <button class="btn btn-success btn-sm" onclick="addExercise('${day}','${escHtml(label)}','${addId}')">+</button>
      <button class="btn btn-ghost btn-sm" onclick="document.getElementById('${addId}').classList.remove('open')">✕</button>
    </div>
    <button class="add-ex-btn" onclick="document.getElementById('${addId}').classList.toggle('open')">${t('gym.add_exercise_btn')}</button>
  </div>`;
}

function renderExRow(ex, day, num, isWarmup) {
  const done   = completedSets[ex.id] || new Set();
  const isDone = !isWarmup && done.size >= ex.sets && ex.sets > 0;
  const isAct  = ex.id === activeExId;
  let progTxt  = '', progCls = '';
  if (!isWarmup) {
    if (isDone) { progTxt = '✓'; progCls = 'done'; }
    else if (done.size > 0) { progTxt = `${done.size}/${ex.sets}`; progCls = 'partial'; }
  }
  const exDay = ex.day || day;
  const exSec = ex.section || '';
  const dragAttrs = ` draggable="true" data-exid="${ex.id}" data-day="${escHtml(exDay)}" data-section="${escHtml(exSec)}"` +
    ` ondragstart="exDragStart(event)" ondragend="exDragEnd(event)"`;
  return `<div class="ex-row-wrap" id="ex-row-wrap-${ex.id}"${dragAttrs}>
    <div class="ex-row${isDone ? ' is-done' : ''}${isAct ? ' is-active' : ''}" id="ex-row-${ex.id}"
      onclick="${isWarmup ? '' : `handleExClick('${ex.id}')`}">
      ${!isWarmup ? `<div class="ex-chk${isDone ? ' done' : ''}" id="ex-chk-${ex.id}"
        onclick="event.stopPropagation();toggleExDone('${ex.id}')">${isDone ? '✓' : ''}</div>` : ''}
      <span class="ex-drag-handle" onclick="event.stopPropagation()">⠿</span>
      <div class="ex-r-num">${num}</div>
      <div class="ex-r-info">
        <div class="ex-r-name">${escHtml(ex.exercise_name)}</div>
        <div class="ex-r-vol">
          <input type="number" min="1" class="ex-inline-input" value="${ex.sets}" style="width:32px"
            onclick="event.stopPropagation()"
            onblur="autoSaveExField('${ex.id}','sets',this.value)">
          <span style="color:var(--text-tertiary);font-family:var(--font-mono)">×</span>
          <input class="ex-inline-input" value="${escHtml(ex.reps)}" style="width:54px"
            onclick="event.stopPropagation()"
            onblur="autoSaveExField('${ex.id}','reps',this.value)">
          ${!isWarmup ? `<span style="color:rgba(255,255,255,0.18);font-family:var(--font-mono);margin:0 2px">·</span>
          <input class="ex-inline-input weight-inp" type="number" step="${weightStep(true)}" min="0" placeholder="—"
            value="${fromKg(weights[ex.id] !== undefined ? weights[ex.id] : (weights[ex.exercise_name] !== undefined ? weights[ex.exercise_name] : ''))}"
            style="width:48px"
            data-exercise-id="${ex.id}"
            onclick="event.stopPropagation()"
            onblur="saveWeight(this.dataset.exerciseId, toKg(this.value))"
            onchange="saveWeight(this.dataset.exerciseId, toKg(this.value))">
          <span style="color:var(--text-tertiary);font-family:var(--font-mono)">${t('po.kg')}</span>` : ''}
        </div>
      </div>
      ${progTxt ? `<div class="ex-r-prog ${progCls}">${progTxt}</div>` : ''}
      <button class="ex-r-del" onclick="event.stopPropagation();deleteExercise('${ex.id}')" title="${t('delete')}">×</button>
    </div>
    <div class="set-drawer" id="drawer-${ex.id}"></div>
  </div>`;
}

// ── Drawer ─────────────────────────────────────────────────────────
function handleExClick(exId) {
  if (workoutState !== 'active') return;
  if (activeDrawer === exId) { closeDrawer(); return; }
  openDrawer(exId);
}

function openDrawer(exId) {
  if (activeDrawer && activeDrawer !== exId) {
    document.getElementById(`drawer-${activeDrawer}`)?.classList.remove('open');
    document.getElementById(`ex-row-${activeDrawer}`)?.classList.remove('is-active');
  }
  activeDrawer = exId;
  activeExId   = exId;
  initSetData(exId);
  document.getElementById(`ex-row-${exId}`)?.classList.add('is-active');
  renderDrawer(exId);
  updateSbActiveEx(exId);
  updateNextEx();
}

function closeDrawer() {
  if (!activeDrawer) return;
  document.getElementById(`drawer-${activeDrawer}`)?.classList.remove('open');
  document.getElementById(`ex-row-${activeDrawer}`)?.classList.remove('is-active');
  activeDrawer = null;
  activeExId   = null;
  updateSbActiveEx(null);
}

function initSetData(exId) {
  if (setData[exId]) return;
  const ex = findExById(exId);
  if (!ex) return;
  const prevDone = completedSets[exId] || new Set();
  setData[exId] = [...Array(ex.sets)].map((_, i) => ({
    done:   prevDone.has(i),
    weight: weights[exId] ?? weights[ex.exercise_name] ?? '',
    reps:   ex.reps,
    notes:  '',
  }));
}

function renderDrawer(exId) {
  const el = document.getElementById(`drawer-${exId}`);
  if (!el) return;
  const ex   = findExById(exId);
  if (!ex) return;
  const data = setData[exId] || [];
  el.innerHTML = `
    <div class="drawer-hd">
      <span class="drawer-title">${escHtml(ex.exercise_name)}</span>
      <span class="drawer-meta-lbl">${ex.sets} × ${escHtml(ex.reps)}</span>
      <button class="drawer-close" onclick="closeDrawer()">✕</button>
    </div>
    <table class="drawer-table">
      <thead><tr>
        <th style="width:28px">${t('gym.col_sets')}</th><th>${t('gym.col_reps')}</th><th>${t('gym.col_weight')}</th>
        <th style="width:32px">✓</th><th>${t('gym.col_notes')}</th><th style="width:28px"></th>
      </tr></thead>
      <tbody id="drawer-body-${exId}">
        ${data.map((s, i) => drawerRow(exId, i, s)).join('')}
      </tbody>
    </table>
    <div class="drawer-actions">
      <button class="btn btn-ghost btn-sm" onclick="addSet('${exId}')">+ ${t('gym.col_sets')}</button>
      <span class="drawer-spacer"></span>
      <button class="btn btn-ghost btn-sm" onclick="saveSetWeights('${exId}')">${t('save')}</button>
      <button class="btn btn-success btn-sm" onclick="completeExercise('${exId}')">${t('gym.complete_exercise')}</button>
    </div>`;
  el.classList.add('open');
}

function drawerRow(exId, i, s) {
  return `<tr id="drow-${exId}-${i}" class="${s.done ? 'set-done' : ''}">
    <td class="set-num-cell">${i + 1}</td>
    <td><input class="set-inp" type="text" value="${escHtml(String(s.reps))}"
      onchange="setData['${exId}'][${i}].reps=this.value;saveDraft()"></td>
    <td><input class="set-inp" type="number" step="${weightStep(false)}" value="${s.weight !== '' && s.weight !== undefined ? fromKg(s.weight) : ''}"
      onchange="setData['${exId}'][${i}].weight=this.value===''?'':toKg(this.value);saveDraft()"></td>
    <td><button class="set-check${s.done ? ' done' : ''}" id="sc-${exId}-${i}"
      onclick="toggleSetDone('${exId}',${i})">${s.done ? '✓' : ''}</button></td>
    <td><input class="set-inp set-notes-inp" type="text" value="${escHtml(s.notes)}"
      onchange="setData['${exId}'][${i}].notes=this.value;saveDraft()" placeholder="—"></td>
    <td><button class="set-remove" onclick="removeSet('${exId}',${i})" title="Fjern sett">−</button></td>
  </tr>`;
}

function toggleSetDone(exId, setIdx) {
  const d = setData[exId];
  if (!d || !d[setIdx]) return;
  d[setIdx].done = !d[setIdx].done;
  if (!completedSets[exId]) completedSets[exId] = new Set();
  if (d[setIdx].done) { completedSets[exId].add(setIdx); startRest(180); }
  else completedSets[exId].delete(setIdx);
  const row = document.getElementById(`drow-${exId}-${setIdx}`);
  if (row) row.classList.toggle('set-done', d[setIdx].done);
  const btn = document.getElementById(`sc-${exId}-${setIdx}`);
  if (btn) { btn.className = 'set-check' + (d[setIdx].done ? ' done' : ''); btn.textContent = d[setIdx].done ? '✓' : ''; }
  updateExRowStatus(exId);
  updateProgress();
  updateNextEx();
  saveSession();
}

function addSet(exId) {
  const ex = findExById(exId);
  if (!ex || !setData[exId]) return;
  const d = setData[exId];
  const last = d.length ? d[d.length - 1] : null;
  const i = d.length;
  d.push({ done: false, weight: last?.weight ?? (weights[exId] ?? weights[ex.exercise_name] ?? ''), reps: last?.reps ?? ex.reps, notes: '' });
  document.getElementById(`drawer-body-${exId}`)?.insertAdjacentHTML('beforeend', drawerRow(exId, i, d[i]));
}

function removeSet(exId, i) {
  const d = setData[exId];
  if (!d) return;
  if (d.length <= 1) { toast('Minst 1 sett kreves', 'err'); return; }
  // Shift completedSets indices after removal
  if (completedSets[exId]) {
    const updated = new Set();
    completedSets[exId].forEach(idx => {
      if (idx < i) updated.add(idx);
      else if (idx > i) updated.add(idx - 1);
    });
    completedSets[exId] = updated;
  }
  d.splice(i, 1);
  renderDrawer(exId);
  saveDraft();
  updateExRowStatus(exId);
  updateProgress();
}

async function saveSetWeights(exId) {
  if (!setData[exId]) return;
  const s = setData[exId].find(r => r.weight !== '' && r.weight !== undefined && !isNaN(parseFloat(r.weight)));
  if (s) await saveWeight(exId, s.weight);
}

async function completeExercise(exId) {
  const ex = findExById(exId);
  if (!ex) return;
  initSetData(exId);
  if (!completedSets[exId]) completedSets[exId] = new Set();
  setData[exId].forEach((s, i) => { s.done = true; completedSets[exId].add(i); });
  const s = setData[exId].find(r => r.weight !== '' && r.weight !== undefined && !isNaN(parseFloat(r.weight)));
  if (s) await saveWeight(exId, s.weight);
  closeDrawer();
  updateExRowStatus(exId);
  updateProgress();
  const next = getSortedMainExercises().find(e => (completedSets[e.id]?.size || 0) < e.sets);
  if (next) setTimeout(() => openDrawer(next.id), 160);
  else updateNextEx();
}

function toggleExDone(exId) {
  if (workoutState !== 'active') return;
  initSetData(exId);
  const ex = findExById(exId);
  if (!ex || !setData[exId]) return;
  const allDone = setData[exId].every(s => s.done);
  if (!completedSets[exId]) completedSets[exId] = new Set();
  setData[exId].forEach((s, i) => {
    s.done = !allDone;
    if (!allDone) completedSets[exId].add(i);
    else completedSets[exId].delete(i);
  });
  if (activeDrawer === exId) renderDrawer(exId);
  updateExRowStatus(exId);
  updateProgress();
  updateNextEx();
}

function updateExRowStatus(exId) {
  const ex = findExById(exId);
  if (!ex) return;
  const done  = completedSets[exId] || new Set();
  const isDone = done.size >= ex.sets && ex.sets > 0;
  const row = document.getElementById(`ex-row-${exId}`);
  if (row) row.classList.toggle('is-done', isDone);
  const chk = document.getElementById(`ex-chk-${exId}`);
  if (chk) { chk.className = 'ex-chk' + (isDone ? ' done' : ''); chk.textContent = isDone ? '✓' : ''; }
  const prog = row?.querySelector('.ex-r-prog');
  if (prog) {
    if (isDone)          { prog.textContent = '✓'; prog.className = 'ex-r-prog done'; }
    else if (done.size)  { prog.textContent = `${done.size}/${ex.sets}`; prog.className = 'ex-r-prog partial'; }
    else                 { prog.textContent = ''; prog.className = 'ex-r-prog'; }
  }
}

// ── Sidebar updates ────────────────────────────────────────────────
function updateSbActiveEx(exId) {
  const el = document.getElementById('sbActiveCard');
  if (!el) return;
  if (!exId) {
    el.innerHTML = `<div class="sb-ex-empty">${t('gym.no_active_exercise')}</div><div class="sb-ex-hint">${t('gym.tap_exercise')}</div>`;
    return;
  }
  const ex   = findExById(exId);
  if (!ex) return;
  const done = completedSets[exId]?.size || 0;
  el.innerHTML = `<div class="sb-ex-name">${escHtml(ex.exercise_name)}</div>
    <div class="sb-ex-vol">${ex.sets} × ${escHtml(ex.reps)}</div>
    <div class="sb-ex-prog">${done} av ${ex.sets} sett fullført</div>`;
}

function updateNextEx() {
  const el   = document.getElementById('sbNextCard');
  if (!el) return;
  const next = getSortedMainExercises().find(e =>
    e.id !== activeExId && (completedSets[e.id]?.size || 0) < e.sets
  );
  if (!next) { el.innerHTML = `<div class="sb-ex-empty">${t('gym.all_done')}</div>`; return; }
  el.innerHTML = `<div class="sb-ex-name">${escHtml(next.exercise_name)}</div>
    <div class="sb-ex-vol">${next.sets} × ${escHtml(next.reps)}</div>`;
}

// ── Workout state ──────────────────────────────────────────────────
function startWorkout() {
  if (typeof Notification !== 'undefined' && Notification.permission === 'default')
    Notification.requestPermission();
  workoutStart  = Date.now();
  completedSets = {};
  setData       = {};
  activeDrawer  = null;
  activeExId    = null;
  setWS('active');
  clearInterval(elapsedTimer);
  elapsedTimer = setInterval(() => { updateElapsed(); updateRingTimer(); }, 1000);
  renderAll();
  setSbPhase('during');
  updateProgress();
  updateNextEx();
  updateSbActiveEx(null);
  saveSession();
}

function finishWorkout() {
  clearInterval(elapsedTimer);
  workoutStart = null;
  stopRest();
  if (activeDrawer) closeDrawer();
  const sbNotes = document.getElementById('sidebarNotes')?.value || '';
  if (sbNotes) document.getElementById('sessionNotes').value = sbNotes;
  const total = getTotalSets(), done = getDoneSets();
  document.getElementById('doneStats').textContent = t('gym.sets_done', { done, total });
  setWS('done');
}

function resetWorkout() {
  clearInterval(elapsedTimer);
  stopRest();
  workoutStart = null; completedSets = {}; setData = {}; activeDrawer = null; activeExId = null;
  document.getElementById('elapsedDisplay').textContent = '0:00';
  clearSession();
  setWS('idle');
  renderAll();
}

function updateElapsed() {
  const s = Math.floor((Date.now() - workoutStart) / 1000);
  document.getElementById('elapsedDisplay').textContent =
    `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`;
}

function updateRingTimer() {
  const s   = Math.floor((Date.now() - workoutStart) / 1000);
  const h   = Math.floor(s / 3600);
  const m   = Math.floor((s % 3600) / 60);
  const sec = s % 60;
  const el  = document.getElementById('sbTimer');
  if (el) el.textContent = h
    ? `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`
    : `${m}:${String(sec).padStart(2,'0')}`;
}

// ── Progress ───────────────────────────────────────────────────────
function getSortedMainExercises() { return Object.values(allExercises[activeDay] || {}).flat(); }
function getTotalSets() { return getSortedMainExercises().reduce((a, e) => a + e.sets, 0); }
function getDoneSets()  { return getSortedMainExercises().reduce((a, e) => a + (completedSets[e.id]?.size || 0), 0); }

function updateProgress() {
  const total = getTotalSets(), done = getDoneSets();
  const pct   = total ? Math.round(done / total * 100) : 0;
  const pctEl = document.getElementById('ringPct');
  if (pctEl) pctEl.textContent = pct + '%';
  const fill  = document.getElementById('ringFill');
  if (fill) fill.style.strokeDashoffset = 188.5 - (188.5 * pct / 100);
  const sc = document.getElementById('sbSetCount');
  if (sc) sc.textContent = `${done} / ${total} sett`;
}

// ── Shortcuts ──────────────────────────────────────────────────────
function addSetToActive() {
  if (!activeDrawer) { toast(t('gym.select_exercise_first'), 'err'); return; }
  addSet(activeDrawer);
