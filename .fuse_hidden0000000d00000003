function closeDayDialog() { document.getElementById('dayDialog').classList.remove('open'); }

async function createDay() {
  const weekday = parseInt(document.getElementById('ddWeekday').value, 10);
  const typeRaw = document.getElementById('ddType').value;
  const type_label = typeRaw || null;
  // Unik nøkkel: ukedag + type (slik at "Tuesday Strength" og "Tuesday Soccer" kan sameksistere).
  const day_key = `wd${weekday}` + (type_label ? '_' + type_label.replace('daytype.', '') : '');
  if (gymDays.some(d => d.day_key === day_key)) { toast(t('gym.day_exists'), 'err'); closeDayDialog(); return; }
  const sort_order = Math.max(0, ...gymDays.filter(d => !d.is_protected).map(d => d.sort_order ?? 0)) + 1;
  const row = { day_key, weekday, type_label, is_protected: false, sort_order };
  const { data, error } = await db.from('gym_days').insert(row).select().single();
  if (error) { toast(t('gym.save_error'), 'err'); return; }
  gymDays.push(data || row);
  closeDayDialog();
  allExercises[day_key] = {};   // ny dag starter tom
  setDay(day_key);
  toast(t('gym.day_created'));
}

async function deleteDay(key) {
  const d = getDay(key);
  if (!d || d.is_protected) return;
  if (!confirm(t('gym.delete_day_confirm'))) return;
  await db.from('workout_program').delete().eq('day', key);   // rydd øvelser på dagen
  await db.from('gym_days').delete().eq('day_key', key);
  gymDays = gymDays.filter(x => x.day_key !== key);
  delete allExercises[key];
  if (activeDay === key) activeDay = detectDay();
  renderDayPills();
  setDay(activeDay);
  toast(t('gym.day_deleted'));
}
function setWS(s) { workoutState = s; document.body.dataset.ws = s; }

// ── Session persistence ────────────────────────────────────────────
function saveSession() {
  if (workoutState !== 'active') return;
  const blob = {
    workoutStartedAt: workoutStart,
    activeDay,
    completedSets: Object.fromEntries(
      Object.entries(completedSets).map(([k, v]) => [k, [...v]])
    ),
    setData,
    kneePain: { ...kneePain },
    restStartedAt,
    restDuration,
    notes: document.getElementById('sidebarNotes')?.value || '',
  };
  try { localStorage.setItem(SESSION_KEY, JSON.stringify(blob)); } catch(e) {}
  syncSessionToCloud(blob);
}

function clearSession() {
  localStorage.removeItem(SESSION_KEY);
  clearCloudSession();
}

function getRestRemaining() {
  if (!restStartedAt || !restDuration) return 0;
  return Math.max(0, restDuration - Math.floor((Date.now() - restStartedAt) / 1000));
}

function resumeRestTimer() {
  const el = document.getElementById('restDisplay');
  if (el) { el.classList.add('running'); el.classList.remove('done'); }
  updateRestDisplay();
  restTimerInt = setInterval(() => {
    const rem = getRestRemaining();
    updateRestDisplay();
    if (rem <= 0) {
      clearInterval(restTimerInt); restTimerInt = null; restStartedAt = null;
      restPaused = false;
      playTimerDone();
      const e = document.getElementById('restDisplay');
      if (e) { e.classList.remove('running'); e.classList.add('done'); e.textContent = t('gym.ready'); }
      const rv = document.getElementById('restVal');
      if (rv) rv.textContent = t('gym.ready');
      const pb = document.getElementById('restPauseBtn');
      if (pb) { pb.textContent = '⏸'; pb.disabled = true; }
    }
  }, 500);
}

function tryRestoreSession(data) {
  if (!data?.workoutStartedAt) return false;
  try {
    workoutStart  = data.workoutStartedAt;
    completedSets = {};
    Object.entries(data.completedSets || {}).forEach(([k, v]) => { completedSets[k] = new Set(v); });
    setData = data.setData || {};
    Object.assign(kneePain, data.kneePain || {});
    if (data.restStartedAt && data.restDuration) {
      restStartedAt = data.restStartedAt;
      restDuration  = data.restDuration;
    }
    return true;
  } catch(e) { clearSession(); return false; }
}


