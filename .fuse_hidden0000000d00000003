async function seedRehabIfEmpty() {
  if ((allExercises['rehab']?.['Rehab'] || []).length > 0) return;
  const defaults = [
    { name: 'Spanish Squat ISO',                   sets: 2, reps: '35–45 sek', sort_order: 0 },
    { name: 'Ankelstrekk mot vegg (Knee-to-wall)', sets: 2, reps: '12 reps',   sort_order: 1 },
    { name: 'Hip Swivels',                         sets: 1, reps: '10 reps',   sort_order: 2 },
