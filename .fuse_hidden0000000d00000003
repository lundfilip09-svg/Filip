// ── Rest timer (timestamp-based — survives refresh/lock) ───────────
function startCustomRest() {
  const min = parseInt(document.getElementById('restCustomMin').value, 10) || 0;
  const sec = parseInt(document.getElementById('restCustomSec').value, 10) || 0;
  const total = min * 60 + sec;
  if (total < 5 || total > 600) { toast(t('gym.rest_range'), 'err'); return; }
  startRest(total);
}
function startRest(seconds) {
  stopRest();
  restStartedAt = Date.now();
  restDuration  = seconds;
  restPaused    = false;
  saveSession();
  // Tell Service Worker to fire a background notification when timer ends
  swPost({ type: 'START_TIMER', seconds,
    title: t('gym.notif_rest_done'), body: t('gym.notif_rest_body') });
  resumeRestTimer();
  const rv = document.getElementById('restVal');
  if (rv) rv.textContent = fmtRest(seconds);
  const pb = document.getElementById('restPauseBtn');
  if (pb) { pb.textContent = '⏸'; pb.disabled = false; }
  const tb = document.getElementById('tb-rest');
  if (tb && tb.style.display !== 'block') toggleTool('rest');
}

function stopRest() {
  clearInterval(restTimerInt); restTimerInt = null;
  swPost({ type: 'CANCEL_TIMER' }); // cancel any pending SW notification
  restStartedAt = null; restDuration = 0;
  restPaused = false; restPausedRemaining = 0;
  const el = document.getElementById('restDisplay');
  if (el) { el.textContent = '—'; el.className = 'rest-display'; }
  const rv = document.getElementById('restVal');
  if (rv) rv.textContent = t('gym.not_running');
  const pb = document.getElementById('restPauseBtn');
  if (pb) { pb.textContent = '⏸'; pb.disabled = true; }
}

function toggleRestPause() {
  if (!restDuration && !restPaused) return;
  const btn = document.getElementById('restPauseBtn');
  const el  = document.getElementById('restDisplay');
  if (restPaused) {
    restStartedAt = Date.now() - (restDuration - restPausedRemaining) * 1000;
    restPaused = false;
    if (el) { el.classList.add('running'); el.classList.remove('done'); }
    if (btn) btn.textContent = '⏸';
    resumeRestTimer();
  } else {
    restPausedRemaining = getRestRemaining();
    clearInterval(restTimerInt); restTimerInt = null;
    restPaused = true;
    if (el) el.classList.remove('running');
    if (btn) btn.textContent = '▶';
  }
}

function updateRestDisplay() {
  const rem = getRestRemaining();
  const el  = document.getElementById('restDisplay');
  if (el) el.textContent = fmtRest(rem);
  const rv  = document.getElementById('restVal');
  if (rv) rv.textContent = fmtRest(rem);
}

function fmtRest(s) { return `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`; }

// ── Pain ───────────────────────────────────────────────────────────
function painClass(score) {
  if (score <= 3) return 'sel-green';
  if (score <= 5) return 'sel-yellow';
  if (score <= 7) return 'sel-orange';
  return 'sel-red';
}

function buildPainButtons() {
  ['before','after','day-after'].forEach(phase => {
    const el = document.getElementById(`knee-${phase}`);
    if (!el) return;
    el.innerHTML = [...Array(11)].map((_,i) =>
      `<button type="button" class="pain-btn" data-phase="${phase}" data-score="${i}"
        onclick="selectPain('${phase}',${i});this.blur()">${i}</button>`
    ).join('');
  });
  buildMiniPainButtons();
}

function buildMiniPainButtons() {
  const el = document.getElementById('sbKneeButtons');
  if (!el) return;
  el.innerHTML = [...Array(11)].map((_,i) =>
    `<button class="mini-pain-btn" data-sb-score="${i}" onclick="selectSbPain(${i})">${i}</button>`
  ).join('');
}

function selectPain(phase, score) {
  kneePain[phase] = score;
  document.querySelectorAll(`[data-phase="${phase}"]`).forEach(b => {
    b.className = 'pain-btn' + (parseInt(b.dataset.score) === score ? ' ' + painClass(score) : '');
  });
  saveDraft();
}

function selectSbPain(score) {
  kneePain[sbKneePhase] = score;
  document.querySelectorAll('.mini-pain-btn').forEach(b => {
    const s = parseInt(b.dataset.sbScore);
    b.className = 'mini-pain-btn' + (s === score ? ' ' + painClass(score) : '');
  });
  document.querySelectorAll(`[data-phase="${sbKneePhase}"]`).forEach(b => {
    b.className = 'pain-btn' + (parseInt(b.dataset.score) === score ? ' ' + painClass(score) : '');
  });
  const kv = document.getElementById('kneeVal');
  if (kv) kv.textContent = `${score} (${sbKneePhase})`;
  saveSession();
  saveDraft();
}

function setSbPhase(phase) {
  sbKneePhase = phase;
  document.querySelectorAll('.pain-phase-pill').forEach(p => p.classList.remove('active'));
  document.getElementById(`pp-${phase}`)?.classList.add('active');
  const cur = kneePain[phase];
  document.querySelectorAll('.mini-pain-btn').forEach(b => {
    const s = parseInt(b.dataset.sbScore);
    b.className = 'mini-pain-btn' + (cur !== null && cur !== undefined && s === cur ? ' ' + painClass(cur) : '');
  });
}

// ── Weight ─────────────────────────────────────────────────────────
async function saveWeight(exId, val) {
  if (!exId || val === '' || val === null || val === undefined) return;
  const kg = parseFloat(val);
  if (isNaN(kg)) return;
  weights[exId] = kg;
  const ex = findExById(exId);
  const { error } = await db.from('exercise_weights').upsert(
    { exercise_id: exId, weight_kg: kg, updated_at: new Date().toISOString() },
    { onConflict: 'exercise_id' }
  );
  if (!error) toast(t('gym.weight_saved', { name: ex?.exercise_name ?? exId, w: fromKg(kg) }));
}

// ── CRUD ───────────────────────────────────────────────────────────
async function addExercise(day, section, formId) {
  const name = document.getElementById(`${formId}-name`).value.trim();
  const sets = parseInt(document.getElementById(`${formId}-sets`).value) || 3;
  const reps = document.getElementById(`${formId}-reps`).value.trim() || '8–10';
  if (!name) return;
  const maxSort = Math.max(0, ...((allExercises[day]?.[section] || []).map(e => e.sort_order)));
  const { data, error } = await db.from('workout_program').insert(
    { day, section, exercise_name: name, sets, reps, sort_order: maxSort + 1 }
  ).select().single();
  if (error) { toast(t('gym.save_error'), 'err'); return; }
  if (!allExercises[day]) allExercises[day] = {};
  if (!allExercises[day][section]) allExercises[day][section] = [];
  allExercises[day][section].push(data);
  document.getElementById(formId).classList.remove('open');
  document.getElementById(`${formId}-name`).value = '';
  renderAll();
  toast(t('gym.exercise_added', { name }));
}

async function deleteExercise(id) {
  if (!confirm(t('confirm.delete_exercise'))) return;
  await db.from('workout_program').delete().eq('id', id);
  for (const d of Object.keys(allExercises))
    for (const s of Object.keys(allExercises[d]))
      allExercises[d][s] = allExercises[d][s].filter(e => e.id !== id);
  renderAll();
  toast(t('gym.exercise_deleted'));
}

function toggleEditEx(id) { document.getElementById(`edit-form-${id}`)?.classList.toggle('open'); }

async function saveExMeta(id) {
  const name = document.getElementById(`edit-name-${id}`)?.value.trim();
  const sets = parseInt(document.getElementById(`edit-sets-${id}`).value);
  const reps = document.getElementById(`edit-reps-${id}`).value.trim();
  if (!sets || !reps) { toast(t('gym.fill_sets_reps'), 'err'); return; }
  const upd = { sets, reps };
  if (name) upd.exercise_name = name;
  await db.from('workout_program').update(upd).eq('id', id);
  for (const d of Object.keys(allExercises))
    for (const s of Object.keys(allExercises[d])) {
      const ex = allExercises[d][s].find(e => String(e.id) === String(id));
      if (ex) { if (name) ex.exercise_name = name; ex.sets = sets; ex.reps = reps; }
    }
  renderAll();
  toast(t('gm.saved'));
}

async function autoSaveExField(id, field, value) {
  if (field === 'sets') {
    const v = parseInt(value);
    if (isNaN(v) || v < 1) return;
    await db.from('workout_program').update({ sets: v }).eq('id', id);
    for (const d of Object.keys(allExercises))
      for (const s of Object.keys(allExercises[d])) {
        const ex = allExercises[d][s].find(e => String(e.id) === String(id));
        if (ex) ex.sets = v;
      }
  } else {
    const v = value.trim();
    if (!v) return;
    await db.from('workout_program').update({ reps: v }).eq('id', id);
    for (const d of Object.keys(allExercises))
      for (const s of Object.keys(allExercises[d])) {
        const ex = allExercises[d][s].find(e => String(e.id) === String(id));
        if (ex) ex.reps = v;
      }
  }
}

