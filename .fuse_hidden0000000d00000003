<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#050506">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Dashboard">
  <title>Dashboard</title>
  <link rel="stylesheet" href="styles.css">
  <style>
    .gym-shell {
      display: grid;
      grid-template-columns: 1fr 276px;
      gap: 18px;
      align-items: start;
    }
    .gym-main { min-width: 0; }
    .gym-sidebar {
      position: sticky;
      top: 72px;
      max-height: calc(100vh - 88px);
      overflow-y: auto;
      scrollbar-width: none;
      background: var(--card-bg);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
    }
    .gym-sidebar::-webkit-scrollbar { display: none; }

    /* Workout header */
    .wh {
      background: var(--card-bg);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      padding: 16px 20px 18px;
      margin-bottom: 12px;
    }
    .wh-row1 {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .day-pills { display: flex; gap: 3px; flex-wrap: wrap; align-items: center; }
    /* A6 — legg-til-dag-knapp + dialog */
    .day-add-pill {
      padding: 4px 11px; border-radius: 20px; border: 1px dashed rgba(255,255,255,0.18);
      background: transparent; color: var(--text-tertiary); font-size: 11px;
      font-family: var(--font-mono); cursor: pointer; transition: all 0.15s;
    }
    .day-add-pill:hover { color: var(--text-secondary); border-color: rgba(255,255,255,0.32); }
    .day-dialog-backdrop {
      position: fixed; inset: 0; background: rgba(0,0,0,0.55); z-index: 200;
      display: none; align-items: center; justify-content: center;
    }
    .day-dialog-backdrop.open { display: flex; }
    .day-dialog {
      background: #16161a; border: 1px solid rgba(255,255,255,0.12); border-radius: 14px;
      padding: 22px; width: min(340px, 90vw); display: flex; flex-direction: column; gap: 14px;
    }
    .day-dialog h3 { margin: 0; font-size: 15px; color: var(--text-primary); }
    .day-dialog label { font-size: 10px; font-family: var(--font-mono); letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--text-tertiary); display: block; margin-bottom: 5px; }
    .day-dialog select {
      width: 100%; padding: 8px 10px; border-radius: 8px; background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.12); color: var(--text-primary); font-size: 13px;
    }
    .day-dialog-actions { display: flex; gap: 8px; justify-content: flex-end; }
    .day-pill-del {
      margin-left: 5px; opacity: 0.45; cursor: pointer; font-size: 12px;
    }
    .day-pill-del:hover { opacity: 1; color: #FF6B6B; }
    .add-section-wrap { margin-top: 10px; }
    /* B1 — progressive overload-coach */
    .po-card {
      background: linear-gradient(135deg, rgba(91,164,245,0.06), rgba(107,227,164,0.04));
      border: 1px solid rgba(91,164,245,0.18); border-radius: 12px;
      padding: 14px 16px; margin-bottom: 14px;
    }
    .po-hd { display: flex; align-items: baseline; gap: 10px; margin-bottom: 10px; flex-wrap: wrap; }
    .po-title { font-size: 13px; font-weight: 700; color: var(--text-primary); }
    .po-sub { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.08em; }
    .po-item { display: flex; align-items: center; gap: 10px; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 12px; }
    .po-item:last-child { border-bottom: none; }
    .po-ex { flex: 1; color: var(--text-secondary); font-weight: 600; }
    .po-last { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); }
    .po-rec { font-family: var(--font-mono); font-size: 11px; padding: 3px 9px; border-radius: 10px; white-space: nowrap; }
    .po-rec.up   { background: rgba(107,227,164,0.12); color: #6BE3A4; border: 1px solid rgba(107,227,164,0.25); }
    .po-rec.hold { background: rgba(242,130,60,0.12); color: #F2823C; border: 1px solid rgba(242,130,60,0.25); }
    .po-rec.flat { background: rgba(255,255,255,0.05); color: var(--text-tertiary); }
    .po-empty { font-size: 11px; color: var(--text-tertiary); padding: 4px 0; }
    .day-pill {
      padding: 4px 12px;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.09);
      background: transparent;
      color: var(--text-tertiary);
      font-size: 11px;
      font-family: var(--font-mono);
      cursor: pointer;
      transition: all 0.15s;
    }
    .day-pill.active { background: rgba(255,255,255,0.08); color: var(--text-primary); border-color: rgba(255,255,255,0.16); }
    .day-pill:hover:not(.active) { color: var(--text-secondary); }
    .wh-cta { display: flex; align-items: center; gap: 8px; }
    .wh-title { font-size: 21px; font-weight: 700; letter-spacing: -0.03em; color: var(--text-primary); line-height: 1.1; }
    .wh-meta { display: flex; gap: 14px; margin-top: 4px; }
    .wh-meta-item { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); display: flex; align-items: center; gap: 4px; }
    .elapsed-chip {
      display: flex; align-items: center; gap: 6px;
      background: rgba(107,227,164,0.07); border: 1px solid rgba(107,227,164,0.16);
      border-radius: 20px; padding: 5px 13px;
      font-family: var(--font-mono); font-size: 13px; font-weight: 700; color: var(--success);
    }
    .elapsed-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--success); animation: blink 1.4s ease-in-out infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* Done banner */
    .done-banner {
      display: flex; align-items: center; gap: 14px;
      background: rgba(107,227,164,0.05); border: 1px solid rgba(107,227,164,0.14);
      border-radius: 10px; padding: 16px 20px; margin-bottom: 12px;
    }
    .done-icon { font-size: 22px; }
    .done-title { font-size: 15px; font-weight: 700; color: var(--success); }
    .done-sub { font-size: 11px; font-family: var(--font-mono); color: var(--text-tertiary); margin-top: 2px; }

    /* Warmup */
    .wm-wrap {
      background: var(--card-bg); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px; margin-bottom: 10px; overflow: hidden;
    }
    .wm-toggle {
      display: flex; align-items: center; gap: 10px;
      width: 100%; padding: 12px 16px;
      background: transparent; border: none; cursor: pointer; text-align: left;
    }
    .wm-label { font-size: 9px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-tertiary); flex: 1; }
    .wm-badge { font-size: 9px; font-family: var(--font-mono); color: var(--text-tertiary); background: rgba(255,255,255,0.04); padding: 2px 8px; border-radius: 8px; }
    .wm-chevron { color: var(--text-tertiary); font-size: 9px; transition: transform 0.2s; }
    .wm-wrap.open .wm-chevron { transform: rotate(180deg); }
    .wm-body { display: none; padding: 0 14px 14px; }
    .wm-wrap.open .wm-body { display: block; }

    /* Sirkulasjon special row */
    .circ-row {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 12px;
      background: rgba(91,164,245,0.05); border: 1px solid rgba(91,164,245,0.12);
      border-radius: 8px; margin-bottom: 10px;
    }
    .circ-icon { font-size: 18px; flex-shrink: 0; }
    .circ-name { font-size: 13px; font-weight: 600; color: var(--text-primary); }
    .circ-meta { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); margin-top: 2px; }

    /* Section header */
    .sec-hd { display: flex; align-items: center; gap: 8px; padding: 8px 2px; margin-bottom: 3px; }
    .sec-label { font-size: 9px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-tertiary); }
    .sec-divider { flex: 1; height: 1px; background: rgba(255,255,255,0.05); }
    .sec-count { font-size: 9px; font-family: var(--font-mono); color: var(--text-tertiary); background: rgba(255,255,255,0.04); padding: 1px 7px; border-radius: 8px; }

    /* Superset bracket */
    .ex-section { margin-bottom: 14px; }
    .ex-section.multi { border-left: 2px solid rgba(91,164,245,0.28); padding-left: 0; }
    .ex-section.multi .ex-row { margin-left: 10px; }
    .ex-section.multi .sec-hd { padding-left: 10px; }

    /* Exercise row */
    .ex-row-wrap { }
    .ex-row {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px;
      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.055);
      border-radius: 8px; cursor: pointer;
      transition: background 0.15s, border-color 0.15s, opacity 0.2s;
      margin-bottom: 2px;
    }
    .ex-row:hover { background: rgba(255,255,255,0.04); }
    .ex-row.is-active { background: rgba(91,164,245,0.06); border-color: rgba(91,164,245,0.22); }
    .ex-row.is-done { opacity: 0.42; background: transparent; }
    .ex-row.is-done .ex-r-name { text-decoration: line-through; color: var(--text-tertiary); }

    .ex-chk {
      width: 18px; height: 18px; border-radius: 4px;
      border: 1.5px solid rgba(255,255,255,0.14); background: transparent;
      flex-shrink: 0; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 9px; color: transparent; transition: all 0.12s;
    }
    .ex-chk.done { background: rgba(107,227,164,0.16); border-color: rgba(107,227,164,0.5); color: var(--success); }
    .ex-r-num { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); width: 14px; flex-shrink: 0; }
    .ex-r-info { flex: 1; min-width: 0; }
    .ex-r-name { font-size: 13px; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ex-r-vol { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); margin-top: 1px; display: flex; align-items: center; gap: 3px; }
    .ex-inline-input {
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 4px; color: var(--text-primary); font-family: var(--font-mono);
      font-size: 10px; padding: 1px 4px; text-align: center;
    }
    .ex-inline-input:focus { outline: none; border-color: rgba(91,164,245,0.4); }
    .ex-r-del {
      background: none; border: none; color: var(--text-tertiary); cursor: pointer;
      font-size: 15px; padding: 2px 6px; opacity: 0;
      transition: opacity 0.15s, color 0.15s; flex-shrink: 0;
    }
    .ex-row:hover .ex-r-del { opacity: 0.5; }
    .ex-r-del:hover { opacity: 1 !important; color: var(--danger); }
    .ex-r-prog { font-size: 9px; font-family: var(--font-mono); color: var(--text-tertiary); flex-shrink: 0; }
    .ex-r-prog.partial { color: var(--warning); }
    .ex-r-prog.done { color: var(--success); }
    .ex-r-menu {
      background: none; border: none; color: var(--text-tertiary);
      cursor: pointer; font-size: 14px; padding: 2px 4px;
      opacity: 0; transition: opacity 0.15s; flex-shrink: 0;
    }
    .ex-row:hover .ex-r-menu { opacity: 1; }

    /* Inline edit form */
    .ex-edit-form {
      display: none; align-items: center; gap: 6px;
      padding: 7px 14px 8px;
      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.055);
      border-top: none; border-radius: 0 0 8px 8px;
      margin-top: -2px; margin-bottom: 2px;
    }
    .ex-edit-form.open { display: flex; }

    /* Set drawer */
    .set-drawer {
      display: none;
      background: rgba(255,255,255,0.022);
      border: 1px solid rgba(255,255,255,0.06);
      border-top: none; border-radius: 0 0 8px 8px;
      margin-top: -2px; margin-bottom: 2px;
      overflow: hidden;
    }
    .set-drawer.open { display: block; }
    .drawer-hd {
      display: flex; align-items: center; gap: 8px;
      padding: 9px 14px 8px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .drawer-title { font-size: 11px; font-weight: 600; color: var(--text-secondary); flex: 1; }
    .drawer-meta-lbl { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); }
    .drawer-close { background: none; border: none; color: var(--text-tertiary); cursor: pointer; font-size: 11px; padding: 2px 4px; }
    .drawer-table { width: 100%; border-collapse: collapse; font-size: 11px; font-family: var(--font-mono); }
    .drawer-table th {
      padding: 5px 8px; color: var(--text-tertiary);
      font-size: 9px; text-transform: uppercase; letter-spacing: 0.08em;
      text-align: left; border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .drawer-table td { padding: 4px 8px; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--text-secondary); vertical-align: middle; }
    .drawer-table tr:last-child td { border-bottom: none; }
    .drawer-table tr.set-done td { opacity: 0.45; }
    .set-num-cell { color: var(--text-tertiary); width: 28px; }
    .set-inp {
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 4px; color: var(--text-primary);
      font-family: var(--font-mono); font-size: 11px; padding: 3px 6px; width: 54px;
    }
    .set-inp:focus { outline: none; border-color: rgba(91,164,245,0.4); }
    .set-notes-inp { width: 80px; }
    .set-check {
      width: 22px; height: 22px; border-radius: 4px;
      border: 1.5px solid rgba(255,255,255,0.12); background: transparent;
      cursor: pointer; font-size: 10px; color: transparent;
      display: flex; align-items: center; justify-content: center; transition: all 0.1s;
    }
    .set-check.done { background: rgba(107,227,164,0.16); border-color: rgba(107,227,164,0.5); color: var(--success); }
    .drawer-actions {
      display: flex; gap: 5px; align-items: center;
      padding: 8px 10px; border-top: 1px solid rgba(255,255,255,0.04);
    }
    .drawer-spacer { flex: 1; }
    .drawer-actions .btn { font-size: 10px; padding: 5px 10px; }

    /* Add exercise */
    .add-ex-btn {
      width: 100%; padding: 6px; background: transparent;
      border: 1px dashed rgba(255,255,255,0.07); border-radius: 6px;
      color: var(--text-tertiary); font-size: 10px; font-family: var(--font-mono);
      cursor: pointer; margin-top: 4px; transition: all 0.15s;
    }
    .add-ex-btn:hover { border-color: rgba(255,255,255,0.16); color: var(--text-secondary); }
    .add-ex-form {
      display: none; gap: 6px; align-items: center;
      padding: 8px 10px; margin-top: 4px;
      background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.1); border-radius: 8px;
    }
    .add-ex-form.open { display: flex; }
    .add-ex-form input { flex: 1; }
    .add-ex-form .w-short { width: 54px; flex: none; }

    /* Sidebar sections */
    .sb-sec { padding: 13px 14px 12px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .sb-sec:last-child { border-bottom: none; }
    .sb-hd { font-size: 8px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-tertiary); margin-bottom: 9px; }

    /* Circular progress ring */
    .ring-wrap { display: flex; align-items: center; gap: 14px; margin-bottom: 8px; }
    .ring-center { position: relative; width: 72px; height: 72px; flex-shrink: 0; }
    .ring-svg { position: absolute; top: 0; left: 0; width: 72px; height: 72px; transform: rotate(-90deg); }
    .ring-bg { stroke: rgba(255,255,255,0.06); }
    .ring-fill { stroke: var(--success); stroke-linecap: round; transition: stroke-dashoffset 0.4s ease; }
    .ring-txt {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      text-align: center; line-height: 1;
    }
    .ring-pct { font-size: 15px; font-weight: 700; font-family: var(--font-mono); color: var(--text-primary); }
    .ring-sub { font-size: 8px; font-family: var(--font-mono); color: var(--text-tertiary); margin-top: 2px; }
    .ring-stats { flex: 1; }
    .ring-count { font-size: 11px; font-family: var(--font-mono); color: var(--text-secondary); line-height: 1.6; }
    .ring-timer { font-size: 20px; font-weight: 700; font-family: var(--font-mono); color: var(--text-primary); letter-spacing: -0.02em; line-height: 1; margin-top: 2px; }

    /* Sidebar exercise cards */
    .sb-ex-card {
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 7px; padding: 9px 11px;
    }
    .sb-ex-empty { font-size: 11px; color: var(--text-tertiary); }
    .sb-ex-hint { font-size: 9px; color: var(--text-tertiary); font-family: var(--font-mono); margin-top: 2px; }
    .sb-ex-name { font-size: 12px; font-weight: 600; color: var(--text-primary); }
    .sb-ex-vol { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); margin-top: 2px; }
    .sb-ex-prog { font-size: 9px; font-family: var(--font-mono); color: var(--text-secondary); margin-top: 4px; }

    /* Tool items */
    .tool-item {
      display: flex; align-items: center; gap: 9px;
      padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04);
      cursor: pointer;
    }
    .tool-item:last-of-type { border-bottom: none; }
    .tool-icon { width: 28px; height: 28px; border-radius: 6px; background: rgba(255,255,255,0.04); display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
    .tool-name { font-size: 11px; font-weight: 500; color: var(--text-secondary); flex: 1; }
    .tool-val { font-size: 10px; font-family: var(--font-mono); color: var(--text-tertiary); }
    .tool-arr { font-size: 10px; color: var(--text-tertiary); transition: transform 0.2s; }
    .tool-item.open .tool-arr { transform: rotate(90deg); }
    .tool-body { display: none; padding: 8px 0 4px; }
    .tool-body.open { display: block; }

    /* Shortcut bar */
    .shortcut-bar { display: flex; gap: 4px; }
    .sc-btn {
      flex: 1; padding: 7px 4px;
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 6px; color: var(--text-tertiary);
      font-size: 9px; font-family: var(--font-mono);
      cursor: pointer; text-align: center; line-height: 1.4; transition: all 0.12s;
    }
    .sc-btn:hover { background: rgba(255,255,255,0.07); color: var(--text-secondary); }
    .sc-btn.accent { background: rgba(107,227,164,0.07); border-color: rgba(107,227,164,0.18); color: var(--success); }
    .sc-btn.accent:hover { background: rgba(107,227,164,0.13); }

    /* Mini pain */
    .mini-pain-row { display: flex; gap: 2px; flex-wrap: wrap; }
    .mini-pain-btn {
      width: 20px; height: 20px; border-radius: 4px;
      border: 1px solid rgba(255,255,255,0.1); background: transparent;
      cursor: pointer; font-size: 8px; font-family: var(--font-mono); color: var(--text-tertiary);
      display: flex; align-items: center; justify-content: center; transition: all 0.1s;
    }
    .mini-pain-btn:hover { background: rgba(255,255,255,0.08); }
    .mini-pain-btn.sel-green  { background: rgba(107,227,164,0.18); border-color: rgba(107,227,164,0.5); color: var(--success); }
    .mini-pain-btn.sel-yellow { background: rgba(242,192,99,0.18);  border-color: rgba(242,192,99,0.5);  color: var(--warning); }
    .mini-pain-btn.sel-orange { background: rgba(242,130,60,0.18);  border-color: rgba(242,130,60,0.5);  color: rgba(242,130,60,1); }
    .mini-pain-btn.sel-red    { background: rgba(255,107,107,0.18); border-color: rgba(255,107,107,0.5); color: var(--danger); }
    .pain-phase-pills { display: flex; gap: 3px; margin-top: 7px; }
    .pain-phase-pill {
      flex: 1; padding: 4px 0; text-align: center;
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 4px; cursor: pointer;
      font-size: 9px; font-family: var(--font-mono); color: var(--text-tertiary); transition: all 0.12s;
    }
    .pain-phase-pill.active { background: rgba(255,255,255,0.09); color: var(--text-secondary); border-color: rgba(255,255,255,0.14); }

    /* Rest timer */
    .rest-display { font-size: 30px; font-weight: 700; font-family: var(--font-mono); color: var(--text-primary); line-height: 1; letter-spacing: -0.02em; }
    .rest-display.running { color: var(--warning); }
    .rest-display.done { color: var(--success); }
    .rest-timer-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .rest-pause-btn {
      width: 30px; height: 30px; flex-shrink: 0;
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px; color: var(--text-secondary); font-size: 13px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background 0.15s;
    }
    .rest-pause-btn:hover:not(:disabled) { background: rgba(255,255,255,0.12); }
