      day: 'rehab', section: 'Rehab', exercise_name: d.name,
      sets: d.sets, reps: d.reps, sort_order: d.sort_order,
    }).select().single();
    if (data && !error) allExercises['rehab']['Rehab'].push(data);
  }
}

// ── Warmup data migration ──────────────────────────────────────────
async function migrateWarmupData() {
  const log = { fixed: [], moved: [], seeded: [] };

  // 0. Seed Monday sykkel if missing from warmup
  const hasMondaySykkel = Object.entries(allExercises['warmup'] || {}).some(([sec, exs]) =>
    /sirkul|sykkel/i.test(sec) || exs.some(e => /sykkel/i.test(e.exercise_name))
  );
  if (!hasMondaySykkel) {
    const { data, error } = await db.from('workout_program').insert({
      day: 'warmup', section: 'Sirkulasjon', exercise_name: 'Sykkel',
      sets: 1, reps: '8–10 min', sort_order: 0,
    }).select().single();
    if (data && !error) {
      if (!allExercises['warmup']) allExercises['warmup'] = {};
      if (!allExercises['warmup']['Sirkulasjon']) allExercises['warmup']['Sirkulasjon'] = [];
      allExercises['warmup']['Sirkulasjon'].push(data);
      log.seeded.push('Sykkel (warmup/Monday)');
    }
  }

  // 1. Fix Monday sykkel duration: should be 8–10 min, not 5–8 min
  for (const [sec, exs] of Object.entries(allExercises['warmup'] || {})) {
    for (const ex of exs) {
      if (/5.?8\s*min/i.test(ex.reps)) {
        const { error } = await db.from('workout_program').update({ reps: '8–10 min' }).eq('id', ex.id);
        if (!error) { ex.reps = '8–10 min'; log.fixed.push(ex.exercise_name); }
      }
    }
  }

  // 2. Move Friday-only exercises from warmup → friday_warmup
  const fridayOnlyRE = /(backwards?|backward)\s*treadmill|sled\s*(pull|push)/i;
  for (const [sec, exs] of Object.entries(allExercises['warmup'] || {})) {
    for (const ex of [...exs]) {
      if (!fridayOnlyRE.test(ex.exercise_name)) continue;
      const { error } = await db.from('workout_program').update({ day: 'friday_warmup' }).eq('id', ex.id);
      if (!error) {
        if (!allExercises['friday_warmup']) allExercises['friday_warmup'] = {};
        if (!allExercises['friday_warmup'][sec]) allExercises['friday_warmup'][sec] = [];
        const alreadyThere = allExercises['friday_warmup'][sec].some(e => String(e.id) === String(ex.id));
        if (!alreadyThere) allExercises['friday_warmup'][sec].push({ ...ex, day: 'friday_warmup' });
        allExercises['warmup'][sec] = allExercises['warmup'][sec].filter(e => String(e.id) !== String(ex.id));
        log.moved.push(ex.exercise_name);
      }
    }
  }

  // 3. Seed Friday sykkel if missing from friday_warmup
  const hasFriSykkel = Object.entries(allExercises['friday_warmup'] || {}).some(([sec, exs]) =>
    /sirkul|sykkel/i.test(sec) || exs.some(e => /sykkel/i.test(e.exercise_name))
  );
  if (!hasFriSykkel) {
    const { data, error } = await db.from('workout_program').insert({
      day: 'friday_warmup', section: 'Sirkulasjon', exercise_name: 'Sykkel',
      sets: 1, reps: '5–8 min', sort_order: 0,
    }).select().single();
    if (data && !error) {
      if (!allExercises['friday_warmup']) allExercises['friday_warmup'] = {};
      if (!allExercises['friday_warmup']['Sirkulasjon']) allExercises['friday_warmup']['Sirkulasjon'] = [];
      allExercises['friday_warmup']['Sirkulasjon'].push(data);
      log.seeded.push('Sykkel (friday_warmup)');
    }
  }

  // 4. Seed Friday-specific extras if missing
  const friNames = Object.values(allExercises['friday_warmup'] || {}).flat()
    .map(e => e.exercise_name.toLowerCase());
  const extras = [
    { name: 'Backwards Treadmill Walk', section: 'Ekstra', sets: 1, reps: '10 min',  sort_order: 10 },
    { name: 'Sled Pull',               section: 'Ekstra', sets: 2, reps: '2 × 40 m', sort_order: 11 },
  ];
  for (const s of extras) {
    if (friNames.some(n => n.includes(s.name.toLowerCase().split(' ')[0]))) continue;
    const { data, error } = await db.from('workout_program').insert({
      day: 'friday_warmup', section: s.section, exercise_name: s.name,
      sets: s.sets, reps: s.reps, sort_order: s.sort_order,
    }).select().single();
    if (data && !error) {
      if (!allExercises['friday_warmup'][s.section]) allExercises['friday_warmup'][s.section] = [];
      allExercises['friday_warmup'][s.section].push(data);
      log.seeded.push(s.name);
    }
  }

  const total = log.fixed.length + log.moved.length + log.seeded.length;
}

