  const mainExs = getSortedMainExercises();
  const raw     = 15 + prepExs.length * 2 + mainExs.length * 4;
  const rounded = Math.round(raw / 5) * 5;
  document.getElementById('whDuration').textContent = `~${rounded} min`;
}

