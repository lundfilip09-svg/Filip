// ── Log ────────────────────────────────────────────────────────────
async function saveLog() {
  if (_isSavingLog) return;
  _isSavingLog = true;
  const btn = document.getElementById('saveLogBtn');
  if (btn) btn.disabled = true;
  try {
    const notes  = document.getElementById('sessionNotes').value.trim();
    const date   = document.getElementById('logDate').value || today();
    // A6: bruk det auto-oversatte dagnavnet som session_type (også for egendefinerte dager)
    const _d = getDay(activeDay);
    const sessionType = _d ? dayLabel(_d) : activeDay;
    const gymRpe = rpeValue('gymRpe');
    const gRes = await db.from('gym_log').insert({ date, session_type: sessionType, session_notes: notes, rpe: gymRpe });
    if (gRes.error) { toast(`${t('gym.save_error')}: ${gRes.error.message}`, 'err'); return; }
    const kRes = await db.from('knee_pain').insert({
      date, session_type: sessionType,
      before_score: kneePain['before'], during_score: kneePain['during'],
      after_score: kneePain['after'], day_after_score: kneePain['day-after'], notes,
    });
    if (kRes.error) toast(t('gym.knee_not_saved', { msg: kRes.error.message }), 'err');

    // B1: lagre sett-historikk for progressive overload-coachen.
    const kneeMax = Math.max(0,
      kneePain['before'] ?? 0, kneePain['during'] ?? 0,
      kneePain['after'] ?? 0, kneePain['day-after'] ?? 0);
    const setRows = [];
    for (const [exId, sets] of Object.entries(setData)) {
      const ex = findExById(exId);
      if (!ex) continue;
      (sets || []).forEach((s, i) => {
        if (!s.done) return;
        const w = (s.weight === '' || s.weight == null) ? null : Number(s.weight);
        setRows.push({
          date, day_key: activeDay, exercise_name: ex.exercise_name,
          weight_kg: (w == null || isNaN(w)) ? null : w,
          reps: String(s.reps ?? ex.reps ?? ''), set_index: i, knee_max: kneeMax,
        });
      });
    }
    if (setRows.length) {
      const sRes = await db.from('set_log').insert(setRows);
      if (sRes.error) { /* stille — set_log er sekundær, økta er allerede lagret */ }
    }

    clearSession();
    clearDraft();
    toast(t('gym.session_saved'));
    await loadGymHistory();
  } finally {
    _isSavingLog = false;
    if (btn) btn.disabled = false;
  }
}

function clearLog() {
  ['before','during','after','day-after'].forEach(p => {
    kneePain[p] = null;
    document.querySelectorAll(`[data-phase="${p}"]`).forEach(b => b.className = 'pain-btn');
  });
  document.querySelectorAll('.mini-pain-btn').forEach(b => b.className = 'mini-pain-btn');
  document.getElementById('sessionNotes').value = '';
  document.getElementById('logDate').value = today();
  renderGymRpe();
}

// ── History (sidebar: last 10 sessions; full log in Treningsoversikt) ──
async function loadGymHistory() {
  const el = document.getElementById('gymHistory');

  // Primary source: gym_log
  const { data: gymData, error: gymErr } = await db.from('gym_log')
    .select('*').order('date', { ascending: false }).limit(10);

  let sessions = gymData || [];
  let kneeMap  = {};

  if (sessions.length) {
    const dates = [...new Set(sessions.map(g => g.date))];
    const { data: kneeData, error: kneeErr } = await db.from('knee_pain')
      .select('*').in('date', dates);
    (kneeData || []).forEach(k => { kneeMap[k.date + '|' + (k.session_type || '')] = k; });
  } else {
    // Fallback: build from knee_pain for non-sprint sessions
    const { data: kneeData, error: kneeErr } = await db.from('knee_pain')
      .select('*')
      .not('session_type', 'ilike', 'Sprint%')
      .order('date', { ascending: false })
      .limit(10);
    if (kneeData?.length) {
      sessions = kneeData.map(k => ({
        id: k.id, date: k.date, session_type: k.session_type, session_notes: null, _knee: k,
      }));
    }
  }

  if (!sessions.length) {
    el.innerHTML = `<div class="empty">${t('gym.no_history')}</div>`; return;
  }

  function fmtSessDate(ds) {
    return new Date(ds + 'T12:00:00').toLocaleDateString(fmtLocale(), { weekday:'short', day:'numeric', month:'short' });
  }
  function painClrH(v) {
    if (v == null) return 'var(--text-tertiary)';
    if (v <= 3) return '#6BE3A4'; if (v <= 5) return '#F2C063';
    if (v <= 7) return 'rgba(242,130,60,1)'; return '#FF6B6B';
  }

  el.innerHTML = sessions.map(g => {
    const knee    = g._knee || kneeMap[g.date + '|' + (g.session_type || '')] || null;
    const kneeId  = knee?.id || '';
    const blurSave = `autoSaveKnee('${g.id}','${g.date}','${escHtml(g.session_type || '')}')`;

    const painStr = [
      { l:t('knee.before'),       v: knee?.before_score },
      { l:t('knee.during'),       v: knee?.during_score },
      { l:t('knee.after'),        v: knee?.after_score },
      { l:t('knee.dayafter'),     v: knee?.day_after_score },
    ].map(p =>
      `${p.l}: <span style="color:${painClrH(p.v)};font-weight:600">${p.v ?? '—'}</span>`
    ).join(' · ');

    return `<div id="hist-wrap-${g.id}" class="gym-history-item">
      <div class="hist-row" style="align-items:flex-start;padding:8px 0">
        <div style="flex:1;min-width:0">
          <div style="font-size:10px;font-family:var(--font-mono);color:var(--text-tertiary);margin-bottom:2px">${fmtSessDate(g.date)}</div>
          <div style="font-size:11px;font-weight:600;color:var(--text-secondary);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escHtml(displaySessionType(g.session_type))}</div>
          <div style="font-size:9px;font-family:var(--font-mono);color:var(--text-tertiary);line-height:1.6">${painStr}</div>
        </div>
        <button class="edit-knee-btn" onclick="toggleKneeEdit('${g.id}')">✎</button>
        <button class="gym-del-btn" onclick="deleteGymSession('${g.id}','${kneeId}')" title="${t('delete')}">✕</button>
      </div>
      <div class="knee-edit-panel" id="knee-edit-${g.id}" data-knee-id="${kneeId}">
        <div class="knee-edit-row" style="margin-bottom:6px;flex-wrap:wrap;gap:4px">
          <span class="knee-edit-label">${t('knee.before')}</span>
          <input class="input-sm" type="number" min="0" max="10" id="ke-before-${g.id}"
            value="${knee?.before_score ?? ''}" style="width:42px" onblur="${blurSave}">
          <span class="knee-edit-label">${t('knee.during')}</span>
          <input class="input-sm" type="number" min="0" max="10" id="ke-during-${g.id}"
            value="${knee?.during_score ?? ''}" style="width:42px" onblur="${blurSave}">
          <span class="knee-edit-label">${t('knee.after')}</span>
          <input class="input-sm" type="number" min="0" max="10" id="ke-after-${g.id}"
            value="${knee?.after_score ?? ''}" style="width:42px" onblur="${blurSave}">
          <span class="knee-edit-label">${t('tp.knee_dayafter')}</span>
          <input class="input-sm" type="number" min="0" max="10" id="ke-dayafter-${g.id}"
            value="${knee?.day_after_score ?? ''}" style="width:42px" onblur="${blurSave}"
            title="${t('gym.fill_day_after')}">
        </div>
        <div style="display:flex;gap:5px">
          <button class="btn btn-ghost btn-sm" onclick="toggleKneeEdit('${g.id}')">${t('close')}</button>
        </div>
      </div>
    </div>`;
  }).join('') +
  `<a href="treningsplan.html" style="display:block;margin-top:8px;font-size:10px;
    font-family:var(--font-mono);color:var(--accent-blue);text-decoration:none;
    text-align:center">${t('gym.full_log')}</a>`;
}

async function deleteGymSession(gymId, kneePainId) {
  if (!confirm(t('confirm.delete_session'))) return;
  const ops = [db.from('gym_log').delete().eq('id', gymId)];
  if (kneePainId) ops.push(db.from('knee_pain').delete().eq('id', kneePainId));
  const results = await Promise.all(ops);
  if (results.some(r => r.error)) { toast(t('gym.delete_error'), 'err'); return; }
  toast(t('gym.deleted'));
  await loadGymHistory();
}

function toggleKneeEdit(gymId) {
  document.getElementById(`knee-edit-${gymId}`)?.classList.toggle('open');
}

async function saveKneeEdit(gymId, kneeId, date, sessionType) {
  const before   = parseInt(document.getElementById(`ke-before-${gymId}`).value);
  const during   = parseInt(document.getElementById(`ke-during-${gymId}`).value);
  const after    = parseInt(document.getElementById(`ke-after-${gymId}`).value);
  const dayAfter = parseInt(document.getElementById(`ke-dayafter-${gymId}`).value);
  const payload  = {
    before_score:    isNaN(before)   ? null : before,
    during_score:    isNaN(during)   ? null : during,
    after_score:     isNaN(after)    ? null : after,
    day_after_score: isNaN(dayAfter) ? null : dayAfter,
  };
  if (kneeId) await db.from('knee_pain').update(payload).eq('id', kneeId);
  else await db.from('knee_pain').insert({ date, session_type: sessionType, ...payload });
  toast(t('sprint.knee_updated'));
  await loadGymHistory();
}

// ── Helpers ────────────────────────────────────────────────────────
function findExById(id) {
  for (const day of Object.values(allExercises))
    for (const exs of Object.values(day)) {
      const ex = exs.find(e => String(e.id) === String(id));
      if (ex) return ex;
    }
  return null;
}

// ── Drag & drop (exercises) ────────────────────────────────────────
let _exDragId = null, _exDragEl = null, _exDragDay = null, _exDragSection = null;

function exDragStart(e) {
  const el = e.currentTarget;
  _exDragId = el.dataset.exid; _exDragEl = el;
  _exDragDay = el.dataset.day; _exDragSection = el.dataset.section;
  e.dataTransfer.effectAllowed = 'move';
  setTimeout(() => _exDragEl?.classList.add('ex-dragging'), 0);
}
function exDragEnd() {
  _exDragEl?.classList.remove('ex-dragging');
  clearExDragClasses();
  _exDragId = _exDragEl = _exDragDay = _exDragSection = null;
}
function clearExDragClasses() {
  document.querySelectorAll('.ex-drag-before,.ex-drag-after').forEach(el =>
    el.classList.remove('ex-drag-before','ex-drag-after'));
}
function exSecDragOver(e) {
  const sec = e.currentTarget;
  if (sec.dataset.day !== _exDragDay || sec.dataset.section !== _exDragSection) return;
  e.preventDefault(); e.dataTransfer.dropEffect = 'move';
  const target = e.target.closest('.ex-row-wrap[data-exid]');
  clearExDragClasses();
  if (!target || target === _exDragEl) return;
  const r = target.getBoundingClientRect();
  target.classList.add(e.clientY < r.top + r.height / 2 ? 'ex-drag-before' : 'ex-drag-after');
}
function exSecDragLeave(e) {
  if (!e.currentTarget.contains(e.relatedTarget)) clearExDragClasses();
}
async function exSecDrop(e) {
  e.preventDefault();
  const sec = e.currentTarget;
  if (sec.dataset.day !== _exDragDay || sec.dataset.section !== _exDragSection) return;
  const target = e.target.closest('.ex-row-wrap[data-exid]');
  clearExDragClasses();
  if (!target || !_exDragEl || target === _exDragEl) return;
  const r = target.getBoundingClientRect();
  if (e.clientY < r.top + r.height / 2) sec.insertBefore(_exDragEl, target);
  else sec.insertBefore(_exDragEl, target.nextSibling);
  const newOrder = [...sec.querySelectorAll('.ex-row-wrap[data-exid]')].map(el => el.dataset.exid);
  await saveExOrder(_exDragDay, _exDragSection, newOrder);
}
async function saveExOrder(day, section, orderedIds) {
  if (allExercises[day]?.[section]) {
    const reordered = orderedIds
      .map(id => allExercises[day][section].find(e => String(e.id) === String(id)))
      .filter(Boolean);
    if (reordered.length) allExercises[day][section] = reordered;
  }
  _saveLocalExOrder(day, section, orderedIds);
  await Promise.all(
    orderedIds.map((id, idx) =>
      db.from('workout_program').update({ sort_order: idx }).eq('id', isNaN(+id) ? id : +id)
    )
  );
}

// ── Warmup drag & drop ─────────────────────────────────────────────
const _wmDays = new Set(['warmup', 'friday_warmup']);

function wmDragOver(e) {
  if (!_exDragId || !_wmDays.has(_exDragDay)) return;
  e.preventDefault(); e.dataTransfer.dropEffect = 'move';
  const target = e.target.closest('.ex-row-wrap[data-exid]');
  clearExDragClasses();
  if (!target || target === _exDragEl) return;
  const r = target.getBoundingClientRect();
  target.classList.add(e.clientY < r.top + r.height / 2 ? 'ex-drag-before' : 'ex-drag-after');
}
function wmDragLeave(e) {
  if (!e.currentTarget.contains(e.relatedTarget)) clearExDragClasses();
}
async function wmDrop(e) {
  e.preventDefault();
  if (!_wmDays.has(_exDragDay)) return;
  const zone   = e.currentTarget;
  const target = e.target.closest('.ex-row-wrap[data-exid]');
  clearExDragClasses();
  if (!target || !_exDragEl || target === _exDragEl) return;
  const r = target.getBoundingClientRect();
  if (e.clientY < r.top + r.height / 2) zone.insertBefore(_exDragEl, target);
  else zone.insertBefore(_exDragEl, target.nextSibling);
  const newOrder = [...zone.querySelectorAll('.ex-row-wrap[data-exid]')].map(el => el.dataset.exid);
  await saveWarmupOrder(newOrder);
}
async function saveWarmupOrder(orderedIds) {
  // Update in-memory sort_orders so renderWarmup re-sorts correctly on tab switch
  const orderMap = Object.fromEntries(orderedIds.map((id, idx) => [String(id), idx]));
  for (const wmDay of ['warmup', 'friday_warmup']) {
    for (const exs of Object.values(allExercises[wmDay] || {})) {
      for (const ex of exs) {
        const newIdx = orderMap[String(ex.id)];
        if (newIdx !== undefined) ex.sort_order = newIdx;
      }
    }
  }
  // Persist to localStorage (reliable) + Supabase (cross-device)
  try { localStorage.setItem('ex_ord__warmup', JSON.stringify(orderedIds.map(String))); } catch {}
  await Promise.all(
    orderedIds.map((id, idx) =>
      db.from('workout_program').update({ sort_order: idx }).eq('id', isNaN(+id) ? id : +id)
    )
  );
}

// Touch drag support (mobile)
(function() {
  let _tEl = null, _tDay = null, _tSec = null;
  document.addEventListener('touchstart', e => {
    const handle = e.target.closest('.ex-drag-handle');
    if (!handle) return;
    const wrap = handle.closest('.ex-row-wrap[data-exid]');
    if (!wrap) return;
    e.preventDefault();
    _tEl = wrap; _tDay = wrap.dataset.day; _tSec = wrap.dataset.section;
    wrap.classList.add('ex-dragging');
    document.addEventListener('touchmove', onTM, { passive: false });
    document.addEventListener('touchend', onTE);
  }, { passive: false });
  function onTM(e) {
    e.preventDefault();
    const t = e.touches[0];
    const under = document.elementFromPoint(t.clientX, t.clientY);
    const target = under?.closest('.ex-row-wrap[data-exid]');
    clearExDragClasses();
    if (!target || target === _tEl) return;
    const sec = target.closest(`[data-day="${_tDay}"][data-section="${_tSec}"]`);
    if (!sec) return;
    const r = target.getBoundingClientRect();
    target.classList.add(t.clientY < r.top + r.height / 2 ? 'ex-drag-before' : 'ex-drag-after');
  }
  function onTE(e) {
    document.removeEventListener('touchmove', onTM);
    document.removeEventListener('touchend', onTE);
    if (!_tEl) return;
    _tEl.classList.remove('ex-dragging');
    clearExDragClasses();
    const t = e.changedTouches[0];
    const under = document.elementFromPoint(t.clientX, t.clientY);
    const target = under?.closest('.ex-row-wrap[data-exid]');
    if (target && target !== _tEl) {
      let sec = target.closest(`[data-day="${_tDay}"][data-section="${_tSec}"]`);
      let isWmDrop = false;
      if (!sec && _wmDays.has(_tDay)) {
        sec = target.closest('[data-wm-zone]');
        isWmDrop = !!sec;
      }
      if (sec) {
        const r = target.getBoundingClientRect();
        if (t.clientY < r.top + r.height / 2) sec.insertBefore(_tEl, target);
        else sec.insertBefore(_tEl, target.nextSibling);
        const newOrder = [...sec.querySelectorAll('.ex-row-wrap[data-exid]')].map(el => el.dataset.exid);
        if (isWmDrop) saveWarmupOrder(newOrder);
        else saveExOrder(_tDay, _tSec, newOrder);
      }
    }
    _tEl = _tDay = _tSec = null;
  }
})();

// ── Rest timer sound + notification ───────────────────────────────
function playTimerDone() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    [0, 0.35].forEach(delay => {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.frequency.value = 880;
      g.gain.setValueAtTime(0.3, ctx.currentTime + delay);
      g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + delay + 0.22);
      o.start(ctx.currentTime + delay);
      o.stop(ctx.currentTime + delay + 0.25);
    });
  } catch(e) {}
  // Vibrate on mobile (pattern: short-pause-short)
  try { navigator.vibrate?.([200, 100, 200]); } catch(e) {}
  if (typeof Notification !== 'undefined' && Notification.permission === 'granted') {
    try { new Notification(t('gym.notif_rest_done'), { body: t('gym.notif_rest_body') }); } catch(e) {}
  }
}

// ── Day-after rehab pain reminder ────────────────────────────────
async function checkDayAfterRehab() {
  const yesterday = new Date();
  yesterday.setDate(yesterday.getDate() - 1);
  const yDate = yesterday.toLocaleDateString('sv');

  const { data: sessions } = await db.from('gym_log')
    .select('id, session_type, date')
    .eq('date', yDate)
    .ilike('session_type', '%rehab%')
    .limit(1);

  if (!sessions?.length) return;
  const gym = sessions[0];

  const { data: kneeRows } = await db.from('knee_pain')
    .select('id, day_after_score')
    .eq('date', yDate)
    .ilike('session_type', '%rehab%')
    .limit(1);

  const knee = kneeRows?.[0];
  if (knee?.day_after_score !== null && knee?.day_after_score !== undefined) return;

  _dayAfterSession = { gymId: gym.id, kneeId: knee?.id || null, date: yDate, sessionType: gym.session_type };
  _dayAfterScore = null;

  const banner  = document.getElementById('dayAfterBanner');
  const subEl   = document.getElementById('dayAfterBannerSub');
  const btnsEl  = document.getElementById('dayAfterPainBtns');
  if (!banner) return;

  if (subEl) subEl.textContent = `Rehab ${yDate}`;
  if (btnsEl) btnsEl.innerHTML = [...Array(11)].map((_,i) =>
    `<button class="mini-pain-btn" data-da-score="${i}" onclick="selectDayAfterPain(${i})">${i}</button>`
  ).join('');

  banner.style.display = '';
}

function selectDayAfterPain(score) {
  _dayAfterScore = score;
  document.querySelectorAll('[data-da-score]').forEach(b => {
    b.className = 'mini-pain-btn' + (parseInt(b.dataset.daScore) === score ? ' ' + painClass(score) : '');
  });
}

async function saveDayAfterPain() {
  if (_dayAfterScore === null || !_dayAfterSession) { toast(t('gym.select_pain_score'), 'err'); return; }
  const { date, sessionType, kneeId } = _dayAfterSession;
  if (kneeId) {
    const { error } = await db.from('knee_pain').update({ day_after_score: _dayAfterScore }).eq('id', kneeId);
    if (error) { toast(t('gym.save_error'), 'err'); return; }
  } else {
    const { data, error } = await db.from('knee_pain')
      .insert({ date, session_type: sessionType, day_after_score: _dayAfterScore })
      .select('id').single();
    if (error) { toast(t('gym.save_error'), 'err'); return; }
    if (data?.id) _dayAfterSession.kneeId = String(data.id);
  }
  toast(t('gym.day_after_saved'));
  dismissDayAfterBanner();
  await loadGymHistory();
}

function dismissDayAfterBanner() {
  const banner = document.getElementById('dayAfterBanner');
  if (banner) banner.style.display = 'none';
}

// ── Autosave knee pain in history panel ───────────────────────────
async function autoSaveKnee(gymId, date, sessionType) {
  const panel = document.getElementById(`knee-edit-${gymId}`);
  if (!panel) return;
  let kneeId = panel.dataset.kneeId || '';
  const parse = id => { const v = parseInt(document.getElementById(id)?.value); return isNaN(v) ? null : v; };
  const payload = {
    before_score:    parse(`ke-before-${gymId}`),
    during_score:    parse(`ke-during-${gymId}`),
    after_score:     parse(`ke-after-${gymId}`),
    day_after_score: parse(`ke-dayafter-${gymId}`),
  };
  if (kneeId) {
    await db.from('knee_pain').update(payload).eq('id', kneeId);
  } else {
    const { data } = await db.from('knee_pain')
      .insert({ date, session_type: sessionType, ...payload }).select('id').single();
    if (data?.id) { panel.dataset.kneeId = String(data.id); kneeId = String(data.id); }
  }
  await loadGymHistory();
}

// ── Bootstrap ──────────────────────────────────────────────────────
(async () => {
  try {
    const cfg = await getConfig();
    db = supabase.createClient(cfg.supabaseUrl, cfg.supabaseAnonKey);
    const { data: { session } } = await db.auth.getSession();
    if (!session) { window.location.href = 'login.html'; return; }
    _uid = session.user.id;
  } catch (err) {
    document.querySelector('.page').innerHTML =
      `<div class="card" style="text-align:center;padding:40px">
        <div style="color:var(--danger);font-family:var(--font-mono);font-size:13px">${err.message}</div>
      </div>`;
    return;
  }

  // Cross-device: hvis en aktiv økt finnes i skyen og er nyere enn lokal,
  // seed localStorage fra skyen før init() leser den.
  try {
    const cloud = await fetchCloudSession();
    if (cloud?.state?.workoutStartedAt) {
      let local = null;
      try { local = JSON.parse(localStorage.getItem(SESSION_KEY) || 'null'); } catch(e) {}
      const cloudNewer = !local?.workoutStartedAt ||
        cloud.state.workoutStartedAt >= local.workoutStartedAt;
      if (cloudNewer) localStorage.setItem(SESSION_KEY, JSON.stringify(cloud.state));
    }
  } catch (e) { /* stille — lokal kopi brukes */ }

  await init();
})();
