function oppdaterTidsestimat() {
  if (activeDay === 'rehab') {
    document.getElementById('whDuration').textContent = '~15 min';
    return;
  }
  const isFri   = activeDay === 'friday';
  const base    = allExercises['warmup'] || {};
  const fri     = allExercises['friday_warmup'] || {};
  const prepExs = [
    ...(base['Hofteaktivering'] || []),
    ...(base['Knær'] || []),
    ...(base['Prepøvelser'] || []),
    ...(isFri ? (fri['Ekstra'] || []) : []),
