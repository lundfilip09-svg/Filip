<script>
let db;
document.querySelector('[data-p="gym"]').classList.add('active');
applyLang();

// ── State ──────────────────────────────────────────────────────────
let activeDay    = 'monday';   // settes ordentlig i bootstrap etter at gymDays er lastet
let allExercises = {};
let gymDays      = [];          // A6: [{ id, day_key, weekday, type_label, is_protected, sort_order }]
let weights      = {};
const kneePain   = { before: null, during: null, after: null, 'day-after': null };

let _isSavingLog      = false;
let _dayAfterSession  = null;  // { gymId, kneeId, date, sessionType }
let _dayAfterScore    = null;
let workoutState  = 'idle';
let workoutStart  = null;   // timestamp (ms)
let elapsedTimer  = null;
let completedSets = {};     // exId -> Set of done set indices
let setData       = {};     // exId -> [{ done, weight, reps, notes }]
let activeDrawer  = null;
let activeExId    = null;
let restTimerInt        = null;
let restStartedAt       = null;   // timestamp (ms) — persisted
let restDuration        = 0;      // total seconds — persisted
let restPaused          = false;
let restPausedRemaining = 0;
let sbKneePhase   = 'during';

const SESSION_KEY = 'gym_session_v2';
const DRAFT_KEY   = 'gym_form_draft';

// ── Cross-device aktiv-økt-sync (Supabase) ────────────────────────────
let _uid = null;            // settes i bootstrap
let _remoteSaveTimer = null;

// Speil økt-bloben til Supabase (debounced, fire-and-forget)
function syncSessionToCloud(blob) {
  if (!_uid || !db) return;
  clearTimeout(_remoteSaveTimer);
  _remoteSaveTimer = setTimeout(async () => {
    try {
      await db.from('active_session').upsert({
        user_id: _uid, kind: 'gym', state: blob, updated_at: new Date().toISOString(),
      }, { onConflict: 'user_id' });
    } catch (e) { /* stille — localStorage er fortsatt gyldig */ }
  }, 1500);
}

// Slett skyøkta (når økt fullføres/avbrytes)
async function clearCloudSession() {
  if (!_uid || !db) return;
  clearTimeout(_remoteSaveTimer);
  try { await db.from('active_session').delete().eq('user_id', _uid).eq('kind', 'gym'); }
  catch (e) { /* stille */ }
}

// Hent skyøkt og bruk den hvis den er nyere enn lokal kopi
async function fetchCloudSession() {
  if (!_uid || !db) return null;
  try {
    const { data } = await db.from('active_session')
      .select('state, updated_at').eq('user_id', _uid).eq('kind', 'gym').maybeSingle();
    return data || null;
  } catch (e) { return null; }
}

function saveDraft() {
  try {
    localStorage.setItem(DRAFT_KEY, JSON.stringify({
      activeDay,
      logDate:      document.getElementById('logDate')?.value       || '',
      sessionNotes: document.getElementById('sessionNotes')?.value  || '',
      sidebarNotes: document.getElementById('sidebarNotes')?.value  || '',
      setData,
      kneePain: { ...kneePain },
    }));
  } catch(e) {}
}

function clearDraft() { localStorage.removeItem(DRAFT_KEY); }

function restoreDraft() {
  const raw = localStorage.getItem(DRAFT_KEY);
  if (!raw) return;
  try {
    const d = JSON.parse(raw);
    // Only restore set data if the draft is from today — avoids yesterday's
    // user-added sets bleeding into a new session
    if (d.setData && d.logDate === today()) setData = d.setData;
    if (d.kneePain)     Object.assign(kneePain, d.kneePain);
    if (d.logDate)      document.getElementById('logDate').value = d.logDate;
    if (d.sessionNotes) document.getElementById('sessionNotes').value = d.sessionNotes;
    if (d.sidebarNotes) {
      const el = document.getElementById('sidebarNotes');
      if (el) { el.value = d.sidebarNotes; try { updateNotesCount(); } catch(e) {} }
    }
  } catch(e) { /* ugyldig draft, ignorer */ }
}

function detectDay() {
  // A6: finn en eksisterende dag som matcher dagens ukedag, ellers første dag.
  const wd = new Date().getDay();
  const match = gymDays.find(d => d.weekday === wd && d.day_key !== 'rehab');
  if (match) return match.day_key;
  const firstNonRehab = gymDays.find(d => d.day_key !== 'rehab');
  return firstNonRehab ? firstNonRehab.day_key : (gymDays[0]?.day_key || 'monday');
}

// A6: auto-oversatt visningsnavn for en dag.
// Ukedagsnavn (man/tue/...) + valgfri type. Rehab vises bare som typen.
function dayLabel(d) {
  if (!d) return '';
  if (d.day_key === 'rehab') return t('daytype.rehab');
  const wdName   = (d.weekday != null) ? t('wd.' + d.weekday) : '';
  const typeName = d.type_label ? t(d.type_label) : '';
  if (wdName && typeName) return `${wdName} · ${typeName}`;
  return wdName || typeName || d.day_key;
}

function getDay(key) { return gymDays.find(d => d.day_key === key); }

// Oversett lagrede session_type-verdier (norske/engelske) til aktivt språk,
// slik at gammel økthistorikk ("Strength Capacity", "Rehab") vises riktig.
const _SESSION_TYPE_KEYS = {
  'styrke kapasitet': 'session.strength_capacity', 'strength capacity': 'session.strength_capacity',
  'styrke power': 'session.strength_power', 'strength power': 'session.strength_power',
  'sirkulasjon & mobilitet': 'session.mobility', 'mobility & conditioning': 'session.mobility',
  'daglig rehab': 'session.daily_rehab', 'daily rehab': 'session.daily_rehab',
  'rehab': 'daytype.rehab',
};
function displaySessionType(raw) {
  if (!raw) return t('gym.session');
  const key = _SESSION_TYPE_KEYS[raw.trim().toLowerCase()];
  return key ? t(key) : raw;
}

// A6: bygg dag-pills dynamisk fra gymDays + legg-til-knapp.
function renderDayPills() {
  const wrap = document.getElementById('dayPills');
  if (!wrap) return;
  const sorted = [...gymDays].sort((a, b) => (a.sort_order ?? 99) - (b.sort_order ?? 99));
  wrap.innerHTML = sorted.map(d => {
    const active = d.day_key === activeDay ? ' active' : '';
    const del = d.is_protected ? '' :
      `<span class="day-pill-del" title="${t('gym.delete_day')}"
         onclick="event.stopPropagation();deleteDay('${escHtml(d.day_key)}')">×</span>`;
    return `<button class="day-pill${active}" data-day="${escHtml(d.day_key)}"
      onclick="setDay('${escHtml(d.day_key)}')">${escHtml(dayLabel(d))}${del}</button>`;
  }).join('') +
    `<button class="day-add-pill" onclick="openDayDialog()" data-i18n="gym.add_day">+ Dag</button>`;
}

// A6: tilgjengelige dag-typer (i18n-nøkler). NULL = ingen type.
const DAY_TYPES = [
  'daytype.strength', 'daytype.strength_capacity', 'daytype.strength_power',
  'daytype.power', 'daytype.mobility', 'daytype.conditioning', 'daytype.rest',
