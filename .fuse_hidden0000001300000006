<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#050506">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Dashboard">
  <title>Dashboard</title>
  <link rel="stylesheet" href="styles.css">
  <style>
    .ai-page {
      display: flex; flex-direction: column; gap: 0;
      max-width: 820px; margin: 0 auto;
      padding: 24px 16px 60px;
      position: relative; z-index: 1;
      height: calc(100vh - 48px);
    }

    /* ── Header ── */
    .ai-header { padding-bottom: 18px; flex-shrink: 0; display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; }
    .ai-title {
      font-size: 24px; font-weight: 700; letter-spacing: -0.03em;
      background: linear-gradient(135deg, #fff 0%, #c8c5be 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 4px;
    }
    .ai-subtitle {
      font-size: 10px; font-family: var(--font-mono); letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--text-tertiary);
    }
    .ai-subtitle span { color: rgba(91,164,245,0.7); }

    /* ── Chat card ── */
    .chat-card {
      flex: 1; min-height: 0;
      background: var(--card-bg);
      border-radius: var(--card-radius);
      border: 1px solid rgba(255,255,255,0.06);
      border-top: 2px solid rgba(91,164,245,0.28);
      backdrop-filter: blur(24px) saturate(1.2);
      -webkit-backdrop-filter: blur(24px) saturate(1.2);
      display: flex; flex-direction: column;
      overflow: hidden;
    }

    /* ── Chat history ── */
    .chat-history {
      flex: 1; overflow-y: auto;
      padding: 20px; display: flex; flex-direction: column;
      gap: 16px; scroll-behavior: smooth;
    }
    .chat-history::-webkit-scrollbar { width: 4px; }
    .chat-history::-webkit-scrollbar-track { background: transparent; }
    .chat-history::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

    /* ── Messages ── */
    .msg { display: flex; flex-direction: column; max-width: 86%; gap: 4px; }
    .msg-user { align-self: flex-end; align-items: flex-end; }
    .msg-ai   { align-self: flex-start; align-items: flex-start; }

    .msg-label {
      font-size: 9px; font-family: var(--font-mono); letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--text-tertiary);
    }

    .msg-bubble {
      padding: 12px 14px; border-radius: 14px;
      font-size: 13px; line-height: 1.65; word-break: break-word;
    }
    .msg-user .msg-bubble {
      background: rgba(91,164,245,0.15);
      border: 1px solid rgba(91,164,245,0.25);
      border-bottom-right-radius: 4px;
      color: var(--text-primary);
    }
    .msg-ai .msg-bubble {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-bottom-left-radius: 4px;
      color: var(--text-secondary);
    }
    .msg-ai .msg-bubble strong { color: var(--text-primary); font-weight: 600; }
    .msg-ai .msg-bubble code {
      font-family: var(--font-mono); font-size: 11px;
      background: rgba(255,255,255,0.07); border-radius: 4px;
      padding: 1px 5px;
    }
    .msg-ai .msg-bubble ul, .msg-ai .msg-bubble ol {
      margin: 6px 0 6px 18px;
    }
    .msg-ai .msg-bubble li { margin-bottom: 3px; }

    /* ── Loading ── */
    .msg-loading .msg-bubble {
      display: flex; align-items: center; gap: 5px; padding: 14px 16px;
    }
    .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--text-tertiary);
      animation: pulse 1.2s ease-in-out infinite;
    }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes pulse {
      0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
      40%           { opacity: 1;   transform: scale(1.1); }
    }

    /* ── Error message ── */
    .msg-error .msg-bubble {
      background: rgba(255,107,107,0.08);
      border-color: rgba(255,107,107,0.2);
      color: var(--danger);
    }

    /* ── Empty state ── */
    .chat-empty {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 10px;
      color: var(--text-tertiary); text-align: center; padding: 20px;
    }
    .chat-empty-icon {
      font-size: 36px; opacity: 0.4; margin-bottom: 4px;
    }
    .chat-empty-title {
      font-size: 13px; font-weight: 600; color: var(--text-secondary);
    }
    .chat-empty-sub {
      font-size: 11px; font-family: var(--font-mono);
      color: var(--text-tertiary); line-height: 1.5;
    }

    /* ── Input area ── */
    .chat-input-area {
      flex-shrink: 0;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 14px 16px;
      background: rgba(255,255,255,0.02);
    }
    .chat-input-row {
      display: flex; align-items: flex-end; gap: 10px;
    }
    .chat-textarea {
      flex: 1; resize: none; min-height: 42px; max-height: 120px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px; padding: 10px 14px;
      font-size: 13px; font-family: var(--font-sans);
      color: var(--text-primary); outline: none;
      transition: border-color 0.15s;
      line-height: 1.5; overflow-y: auto;
    }
    .chat-textarea::placeholder { color: var(--text-tertiary); }
    .chat-textarea:focus { border-color: rgba(91,164,245,0.35); }
    .chat-textarea:disabled { opacity: 0.5; cursor: not-allowed; }

    .chat-send {
      flex-shrink: 0; width: 42px; height: 42px;
      background: rgba(91,164,245,0.18);
      border: 1px solid rgba(91,164,245,0.3);
      border-radius: 10px; color: var(--accent-blue);
      font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s, opacity 0.15s;
    }
    .chat-send:hover:not(:disabled) { background: rgba(91,164,245,0.28); }
    .chat-send:disabled { opacity: 0.4; cursor: not-allowed; }

    .chat-hint {
      margin-top: 8px;
      font-size: 9px; font-family: var(--font-mono); color: var(--text-tertiary);
      text-align: center; letter-spacing: 0.08em;
    }

    /* ── Quick prompts ── */
    .quick-prompts {
      display: flex; flex-wrap: wrap; gap: 6px;
      padding: 12px 16px 0;
      flex-shrink: 0;
    }
    .qp-btn {
      font-size: 10px; font-family: var(--font-mono);
      padding: 5px 10px; border-radius: 6px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      color: var(--text-tertiary); cursor: pointer;
      transition: all 0.15s; white-space: nowrap;
      letter-spacing: 0.04em;
    }
    .qp-btn:hover { background: rgba(255,255,255,0.08); color: var(--text-secondary); }
    /* B5 — ukentlig oppsummering */
    .ws-card {
      background: linear-gradient(135deg, rgba(177,151,252,0.07), rgba(91,164,245,0.04));
      border: 1px solid rgba(177,151,252,0.2); border-radius: 12px;
      padding: 13px 15px; margin-bottom: 12px;
    }
    .ws-card.saturday { border-color: rgba(177,151,252,0.45); box-shadow: 0 0 24px rgba(177,151,252,0.1); }
    .ws-hd { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
    .ws-title { font-size: 13px; font-weight: 700; color: var(--text-primary); }
    .ws-btn {
      font-size: 11px; font-family: var(--font-mono); padding: 5px 12px; border-radius: 7px;
      background: rgba(177,151,252,0.14); border: 1px solid rgba(177,151,252,0.3);
      color: #B197FC; cursor: pointer; transition: all 0.15s; white-space: nowrap;
    }
    .ws-btn:hover { background: rgba(177,151,252,0.24); }
    .ws-btn:disabled { opacity: 0.5; cursor: default; }
    .ws-body { margin-top: 10px; font-size: 13px; line-height: 1.6; color: var(--text-secondary); white-space: pre-wrap; }
    .ws-body:empty { display: none; }
    .ws-hint { font-size: 10px; font-family: var(--font-mono); color: #B197FC; margin-top: 6px; opacity: 0.85; }
  </style>
</head>
