<script>
let db;
document.querySelector('[data-p="ai"]').classList.add('active');
applyLang();

// ── Markdown → HTML (minimal) ────────────────────────────────────────────────
function mdToHtml(text) {
  return text
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/^### (.+)$/gm, '<strong style="font-size:12px;letter-spacing:0.06em;text-transform:uppercase;color:var(--text-tertiary)">$1</strong>')
    .replace(/^## (.+)$/gm, '<strong style="font-size:14px">$1</strong>')
    .replace(/^# (.+)$/gm, '<strong style="font-size:15px">$1</strong>')
    .replace(/^[-*] (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>)/gs, '<ul>$1</ul>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>');
}

// ── Message rendering ─────────────────────────────────────────────────────────
let messageCount = 0;

function appendMessage(role, content, isError = false) {
  const history = document.getElementById('chatHistory');
  const empty = document.getElementById('chatEmpty');
  if (empty) empty.remove();

  const id = `msg-${++messageCount}`;
  const div = document.createElement('div');
  div.className = `msg msg-${role}${isError ? ' msg-error' : ''}`;
  div.id = id;

  if (role === 'user') {
    div.innerHTML = `
      <div class="msg-label">${t('ai.you')}</div>
      <div class="msg-bubble">${content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>')}</div>`;
  } else {
    div.innerHTML = `
      <div class="msg-label">${t('ai.title')}</div>
      <div class="msg-bubble"><p>${mdToHtml(content)}</p></div>`;
  }

  history.appendChild(div);
  history.scrollTop = history.scrollHeight;
  return id;
}

function showLoading() {
  const history = document.getElementById('chatHistory');
  const empty = document.getElementById('chatEmpty');
  if (empty) empty.remove();

  const div = document.createElement('div');
  div.className = 'msg msg-ai msg-loading';
  div.id = 'loadingMsg';
  div.innerHTML = `
    <div class="msg-label">AI Overseer</div>
    <div class="msg-bubble">
      <div class="dot"></div><div class="dot"></div><div class="dot"></div>
    </div>`;
  history.appendChild(div);
  history.scrollTop = history.scrollHeight;
}

function hideLoading() {
  document.getElementById('loadingMsg')?.remove();
}

// ── Chat history (session-scoped, cleared on page load) ──────────────────────
let isSending = false;
let chatHistory = []; // {role:'user'|'assistant', content:string}[]

async function saveHistory() {
  localStorage.setItem('ai_chat_history', JSON.stringify(chatHistory));
  // Persist last user+assistant pair to Supabase (fire-and-forget)
  try {
    const { data: { session } } = await db.auth.getSession();
    if (!session) return;
    const lastTwo = chatHistory.slice(-2);
    if (lastTwo.length === 2 && lastTwo[0].role === 'user' && lastTwo[1].role === 'assistant') {
      await db.from('ai_chat_history').insert(lastTwo.map(m => ({
        user_id: session.user.id,
        role: m.role,
        content: m.content,
      })));
    }
  } catch { /* silent — localStorage still valid */ }
}

// Live-sync: lytt på nye meldinger i ai_chat_history og vis dem på alle enheter.
// Dedupe: enheten som sendte meldingen viser den allerede lokalt, så vi hopper
// over hvis samme rolle+innhold allerede ligger i chatHistory.
let _chatChannel = null;
function subscribeChatRealtime(userId) {
  if (_chatChannel) { try { db.removeChannel(_chatChannel); } catch {} }
  _chatChannel = db
    .channel('ai_chat_' + userId)
    .on('postgres_changes',
      { event: 'INSERT', schema: 'public', table: 'ai_chat_history', filter: `user_id=eq.${userId}` },
      (payload) => {
        const m = payload.new;
        if (!m || (m.role !== 'user' && m.role !== 'assistant')) return;
        // Allerede vist lokalt? (samme rolle+innhold blant de siste meldingene)
        const dup = chatHistory.slice(-6).some(x => x.role === m.role && x.content === m.content);
        if (dup) return;
        chatHistory.push({ role: m.role, content: m.content });
        if (chatHistory.length > 10) chatHistory = chatHistory.slice(-10);
        localStorage.setItem('ai_chat_history', JSON.stringify(chatHistory));
        appendMessage(m.role === 'user' ? 'user' : 'ai', m.content);
      })
    .subscribe();
}

async function clearChat() {
  try {
    const { data: { session } } = await db.auth.getSession();
    if (session) {
      await db.from('ai_chat_history').delete().eq('user_id', session.user.id);
    }
  } catch { /* silent */ }
  chatHistory = [];
  localStorage.removeItem('ai_chat_history');
  document.getElementById('chatHistory').innerHTML = `
    <div class="chat-empty" id="chatEmpty">
      <div class="chat-empty-icon">🤖</div>
      <div class="chat-empty-title" data-i18n="ai.empty_title">${t('ai.empty_title')}</div>
      <div class="chat-empty-sub" data-i18n="ai.empty_sub">${t('ai.empty_sub').replace('\n', '<br>')}</div>
    </div>`;
  toast(t('ai.cleared'));
}

function historyForApi() {
  // Take last 9 stored messages so that + the new user message = 10 total.
  // Anthropic requires the array to start with a user turn.
  let msgs = chatHistory.slice(-9);
  while (msgs.length > 0 && msgs[0].role !== 'user') msgs = msgs.slice(1);
  return msgs;
}

// ── Send message ─────────────────────────────────────────────────────────────
async function sendMessage() {
  if (isSending) return;
  const input = document.getElementById('chatInput');
  const btn = document.getElementById('sendBtn');
  const msg = input.value.trim();
  if (!msg) return;

  isSending = true;
  input.disabled = true;
  btn.disabled = true;
  input.value = '';
  input.style.height = '';
  localStorage.removeItem('ai_draft');

  appendMessage('user', msg);
  showLoading();

  try {
    const { data: { session } } = await db.auth.getSession();
    if (!session) { window.location.href = 'login.html'; return; }

    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 30000);
    let res;
    try {
      res = await fetch('/api/ai-chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${session.access_token}`,
        },
        body: JSON.stringify({
          message: msg,
          history: historyForApi(),
          localDate: today(),                                   // brukerens lokale dato (YYYY-MM-DD), funker i USA
          tz: Intl.DateTimeFormat().resolvedOptions().timeZone, // brukerens tidssone
        }),
        signal: controller.signal,
      });
    } finally {
      clearTimeout(timeout);
    }

    hideLoading();

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      appendMessage('ai', err.error || t('ai.err_generic', { status: res.status }), true);
    } else {
      const { reply } = await res.json();
      appendMessage('ai', reply);
      chatHistory.push({ role: 'user', content: msg });
      chatHistory.push({ role: 'assistant', content: reply });
      if (chatHistory.length > 10) {
        const toRemove = chatHistory.length - 10;
        chatHistory = chatHistory.slice(-10);
        // Fjern tilsvarende DOM-elementer så DOM ikke vokser ubegrenset
        const history = document.getElementById('chatHistory');
        const msgs = history.querySelectorAll('.msg:not(.msg-loading)');
        for (let i = 0; i < toRemove && msgs[i]; i++) msgs[i].remove();
      }
      saveHistory();
    }
  } catch (e) {
    hideLoading();
    const msg = e.name === 'AbortError'
      ? t('ai.err_timeout')
      : t('ai.err_network');
    appendMessage('ai', msg, true);
  } finally {
    isSending = false;
    input.disabled = false;
    btn.disabled = false;
    input.focus();
  }
}

function quickPrompt(text) {
  const input = document.getElementById('chatInput');
  input.value = text;
  autoResize(input);
  input.focus();
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function autoResize(el) {
  el.style.height = '';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

// ── Init ─────────────────────────────────────────────────────────────────────
(async () => {
  try {
    const cfg = await getConfig();
    db = supabase.createClient(cfg.supabaseUrl, cfg.supabaseAnonKey);
    const { data: { session } } = await db.auth.getSession();
    if (!session) { window.location.href = 'login.html'; return; }

    // Rydd chat om annen bruker logger inn
    const storedUid = localStorage.getItem('ai_user_id');
    if (storedUid && storedUid !== session.user.id) {
      localStorage.removeItem('ai_chat_history');
      localStorage.removeItem('ai_draft');
    }
    localStorage.setItem('ai_user_id', session.user.id);

    // Load history: Supabase first, localStorage fallback
    try {
      const { data: sbData, error } = await db.from('ai_chat_history')
        .select('role, content')
        .eq('user_id', session.user.id)
        .order('created_at', { ascending: false })
        .limit(20);
      if (!error && sbData?.length) {
        // Hentet nyeste 20 i synkende rekkefølge — snu til kronologisk for visning
        chatHistory = sbData.reverse().map(m => ({ role: m.role, content: m.content }));
        chatHistory.forEach(m => appendMessage(m.role === 'user' ? 'user' : 'ai', m.content));
        localStorage.setItem('ai_chat_history', JSON.stringify(chatHistory));
      } else {
        const stored = localStorage.getItem('ai_chat_history');
        if (stored) {
          chatHistory = JSON.parse(stored);
          chatHistory.forEach(m => appendMessage(m.role === 'user' ? 'user' : 'ai', m.content));
        }
      }
    } catch {
      try {
        const stored = localStorage.getItem('ai_chat_history');
        if (stored) {
          chatHistory = JSON.parse(stored);
          chatHistory.forEach(m => appendMessage(m.role === 'user' ? 'user' : 'ai', m.content));
        }
      } catch { chatHistory = []; }
    }

    // Restore draft input
    const draft = localStorage.getItem('ai_draft');
    if (draft) {
      const inp = document.getElementById('chatInput');
      inp.value = draft;
      autoResize(inp);
    }

    applyLang();
    initWeeklySummary();   // B5
    subscribeChatRealtime(session.user.id);   // live-sync mac ↔ telefon
    document.getElementById('chatInput').focus();
  } catch (err) {
    document.querySelector('.chat-card').innerHTML =
      `<div style="padding:40px;text-align:center">
        <div style="color:var(--danger);font-family:var(--font-mono);font-size:13px">${err.message}</div>
        <div style="color:var(--text-tertiary);font-size:11px;margin-top:10px">
          Sett SUPABASE_URL og SUPABASE_ANON_KEY i Vercel.
        </div>
      </div>`;
  }
})();

// ── B5: Ukentlig oppsummering ───────────────────────────────────────
// Token-effektiv: genereres maks én gang per uke (cachet i localStorage per
// ISO-uke). Vises automatisk på lørdager hvis ikke allerede laget.
function isoWeek(d) {
  const date = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
  const dayNum = (date.getUTCDay() + 6) % 7;          // man=0..søn=6
  date.setUTCDate(date.getUTCDate() - dayNum + 3);    // torsdag i denne uka
  const firstThu = new Date(Date.UTC(date.getUTCFullYear(), 0, 4));
  const week = 1 + Math.round((date - firstThu) / 86400000 / 7);
  return `${date.getUTCFullYear()}-W${week}`;
}
function _wsKey() { return 'ws_summary_' + isoWeek(new Date()); }

function renderWeeklySummaryCard() {
  const card = document.getElementById('wsCard');
  const body = document.getElementById('wsBody');
  const btn  = document.getElementById('wsBtn');
  if (!card || !body || !btn) return;
  const isSat = new Date().getDay() === 6;
  card.classList.toggle('saturday', isSat);

  const cached = localStorage.getItem(_wsKey());
  if (cached) {
    body.innerHTML = mdToHtml(cached);
    btn.textContent = t('ws.regenerate');
  } else {
    body.innerHTML = isSat ? `<div class="ws-hint">${t('ws.saturday_hint')}</div>` : '';
    btn.textContent = t('ws.generate');
  }
}
function initWeeklySummary() { renderWeeklySummaryCard(); }

async function generateWeeklySummary() {
  const body = document.getElementById('wsBody');
  const btn  = document.getElementById('wsBtn');
  if (!body || !btn || isSending) return;
  btn.disabled = true;
  body.innerHTML = `<div class="ws-hint">${t('ws.generating')}</div>`;
  try {
    const { data: { session } } = await db.auth.getSession();
    if (!session) { window.location.href = 'login.html'; return; }
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 30000);
    let res;
    try {
      res = await fetch('/api/ai-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${session.access_token}` },
        body: JSON.stringify({
          message: t('ws.prompt'),
          history: [],
          localDate: today(),
          tz: Intl.DateTimeFormat().resolvedOptions().timeZone,
        }),
        signal: controller.signal,
      });
    } finally { clearTimeout(timeout); }
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      body.innerHTML = `<div class="ws-hint" style="color:var(--danger)">${err.error || t('ai.err_generic', { status: res.status })}</div>`;
    } else {
      const { reply } = await res.json();
      localStorage.setItem(_wsKey(), reply);
      renderWeeklySummaryCard();
    }
  } catch (e) {
    body.innerHTML = `<div class="ws-hint" style="color:var(--danger)">${e.name === 'AbortError' ? t('ai.err_timeout') : t('ai.err_network')}</div>`;
  } finally {
    btn.disabled = false;
  }
}

// ── Copy AI Health Report ────────────────────────────────────────────────────
// Bygger en ferdig "master prompt" på ENGELSK (skal limes inn i gratis-AI i USA)
// og kopierer til utklippstavla. Statisk bakgrunn er hardkodet; PB-er, plager,
// fysio-notater og siste 7 dager hentes LIVE fra Supabase så rapporten aldri
// blir utdatert. NB: rapport-teksten er bevisst engelsk-only (data, ikke UI) —
// knapp/toast er tospråklige via i18n.
async function writeClip(text) {
  try { await navigator.clipboard.writeText(text); return true; }
  catch (e) {
    try {
      const ta = document.createElement('textarea');
      ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
      document.body.appendChild(ta); ta.focus(); ta.select();
      const ok = document.execCommand('copy'); ta.remove(); return ok;
    } catch (_) { return false; }
  }
}

const _INJ_BODY_EN = { 'body.knee':'Knee','body.hamstring':'Hamstring','body.glute':'Glute',
  'body.hipflexor':'Hip flexor','body.hip':'Hip','body.shoulder':'Shoulder','body.back':'Back',
  'body.neck':'Neck','body.ankle':'Ankle','body.calf':'Calf','body.achilles':'Achilles',
  'body.foot':'Foot','body.other':'Other' };
const _INJ_SIDE_EN = { left:'left', right:'right', both:'both' };
const _INJ_STAT_EN = { active:'ACTIVE', improving:'IMPROVING', archived:'archived' };
const _INJ_SEV_EN  = { mild:'mild', moderate:'moderate', severe:'severe' };

function _isoDaysAgo(n) {
  const d = new Date(); d.setDate(d.getDate() - n);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}

async function copyHealthReport() {
  const btn = document.getElementById('copyReportBtn');
  if (btn) btn.disabled = true;
  toast(t('ai.report_building'));
  try {
    const cutoff = _isoDaysAgo(6); // siste 7 dager inkl. i dag
    const [health, knee, gym, sprint, activity, records, physio, injuries] = await Promise.all([
      db.from('health_data').select('date,sleep_score,hrv,rhr').gte('date', cutoff).order('date', { ascending: false }),
      db.from('knee_pain').select('date,before_score,during_score,after_score,day_after_score,notes').gte('date', cutoff).order('date', { ascending: false }),
      db.from('gym_log').select('date,session_type,rpe').gte('date', cutoff).order('date', { ascending: false }),
      db.from('sprint_log').select('date,distance,type,rpe').gte('date', cutoff).order('date', { ascending: false }),
      db.from('activity_log').select('date,activity_type,activity_label,duration_min,rpe').gte('date', cutoff).order('date', { ascending: false }),
      db.from('sprint_records').select('distance,best_time').order('distance', { ascending: true }),
      db.from('physio_notes').select('date,therapist,note').order('date', { ascending: false }).limit(3),
      db.from('injuries').select('body_part,side,status,severity,start_date,note').neq('status', 'archived').order('updated_at', { ascending: false }),
    ]);

    const H = health.data || [], K = knee.data || [], G = gym.data || [],
          S = sprint.data || [], A = activity.data || [], R = records.data || [],
          P = physio.data || [], I = injuries.data || [];

    // PB-linje — live fra sprint_records, fallback til kjente verdier
    const recMap = {};
    R.forEach(r => { if (r.best_time != null) recMap[r.distance] = Number(r.best_time).toFixed(2); });
    const pb100 = recMap['100m'] || '11.52';
    const pb200 = recMap['200m'] || '23.11';
    const otherPB = R.filter(r => !['100m','200m'].includes(r.distance) && r.best_time != null)
      .map(r => `${r.distance} (${Number(r.best_time).toFixed(2)}s)`);
    const eventsLine = `100m (${pb100}s) / 200m (${pb200}s)` + (otherPB.length ? ' / ' + otherPB.join(' / ') : '');

    // Aktive plager → engelsk
    const injLines = I.map(i => {
      const part = _INJ_BODY_EN[i.body_part] || i.body_part;
      const side = i.side && _INJ_SIDE_EN[i.side] ? ' ' + _INJ_SIDE_EN[i.side] : '';
      const meta = `${_INJ_STAT_EN[i.status] || i.status}, ${_INJ_SEV_EN[i.severity] || i.severity}${i.start_date ? ', since ' + i.start_date : ''}`;
      return `- ${part}${side} [${meta}]${i.note ? ': ' + i.note : ''}`;
    });
    const injBlock = injLines.length ? injLines.join('\n') : '- None currently logged (assume injury-free unless noted below).';

    // Fysio-notater
    const physioBlock = P.length
      ? P.map(p => `(${p.date}${p.therapist ? ', ' + p.therapist : ''}) ${p.note}`).join('\n\n')
      : 'No physio notes logged yet.';

    // Siste 7 dager — én linje per dag (i dag → bakover)
    const idx = (rows) => { const m = {}; rows.forEach(r => { (m[r.date] ||= []).push(r); }); return m; };
    const hM = {}; H.forEach(h => hM[h.date] = h);
    const kM = {}; K.forEach(k => kM[k.date] = k);
    const gM = idx(G), sM = idx(S), aM = idx(A);

    const dayLines = [];
    for (let n = 0; n < 7; n++) {
      const ds = _isoDaysAgo(n);
      const wd = new Date(ds + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'short' });
      const parts = [];
      const h = hM[ds];
      parts.push(`Sleep score: ${h && h.sleep_score != null ? h.sleep_score : '–'}`);
      if (h && (h.hrv != null || h.rhr != null)) parts.push(`HRV ${h.hrv ?? '–'} / RHR ${h.rhr ?? '–'}`);
      const k = kM[ds];
      parts.push(`Knee pain before/during/after/next-day: ${k ? `${k.before_score ?? '–'}/${k.during_score ?? '–'}/${k.after_score ?? '–'}/${k.day_after_score ?? '–'}` : 'not logged'}`);
      const sess = [];
      (gM[ds] || []).forEach(g => sess.push(`Strength${g.session_type ? ' (' + g.session_type + ')' : ''}${g.rpe != null ? ' RPE ' + g.rpe : ''}`));
      (sM[ds] || []).forEach(s => sess.push(`Sprint${s.distance ? ' ' + s.distance : ''}${s.type ? ' ' + s.type : ''}${s.rpe != null ? ' RPE ' + s.rpe : ''}`));
      (aM[ds] || []).forEach(a => sess.push(`${a.activity_type === 'Annet' && a.activity_label ? a.activity_label : a.activity_type}${a.duration_min ? ' ' + a.duration_min + 'min' : ''}${a.rpe != null ? ' RPE ' + a.rpe : ''}`));
      parts.push(`Sessions: ${sess.length ? sess.join('; ') : 'rest / none logged'}`);
      dayLines.push(`${ds} (${wd}): ${parts.join(' | ')}`);
    }

    const report =
`=== ATHLETE CONTEXT ===
Name: Filip Lund (born 2009) — competitive 100m/200m sprinter, Norway
Main Events: ${eventsLine}
Current Club: Norna-Salhus IL (Norway)
Coaching Team: Erlend Sæterstøl, Jørgen Homstad, Joakim Dang, Sondre Amundsen

=== MEDICAL & INJURY HISTORY ===
Diagnosis: Patellar tendinopathy (jumper's knee), left knee.
Onset: January 2026, following a rapid ramp-up in sprint training volume.
Current Status: Doing daily targeted rehab. Tolerating static/slow heavy loading well, but highly sensitive to high-velocity stretch-shortening cycles (like football and max sprinting).
Active issues (live from tracker):
${injBlock}
Latest Physio/Clinical Notes (live from tracker, newest first):
${physioBlock}

=== CURRENT ENVIRONMENT ===
Location: Fergus Falls, Minnesota (High School Exchange VG2 at Hillcrest).
Current Activities: Combining High School Soccer (2-3x week) with Sprint Training (1x week) and Strength/Rehab (2x week).

=== RECENT TRACKING DATA (LAST 7 DAYS) ===
${dayLines.join('\n')}

=== YOUR ROLE AS AN EXPERT SPRINT & REHAB COACH ===
Based strictly on sports science, tendon adaptation timelines, and my tracking data above:
1. Analyze if my knee pain trend indicates that my current soccer/sprint load is safe or causing regression.
2. Give me a concrete recommendation for my training load TOMORROW.
3. Highlight any red flags I need to watch out for in my upcoming sessions.`;

    const ok = await writeClip(report);
    toast(ok ? t('ai.report_copied') : t('ai.report_copy_fail'));
  } catch (e) {
    toast(t('ai.report_copy_fail'));
  } finally {
    if (btn) btn.disabled = false;
  }
}

// Refresh static text + message author labels when language toggles
onLangChange = () => {
  applyLang();
  document.querySelectorAll('.msg-user .msg-label').forEach(e => e.textContent = t('ai.you'));
  document.querySelectorAll('.msg-ai:not(.msg-loading) .msg-label').forEach(e => e.textContent = t('ai.title'));
  renderWeeklySummaryCard();   // B5: re-render (knapp-tekst + hint på nytt språk)
};
