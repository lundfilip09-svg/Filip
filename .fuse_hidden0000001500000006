<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#050506">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Dashboard">
  <title>Dashboard</title>
  <link rel="stylesheet" href="styles.css">
  <style>
    /* ── Nav slim ── */
    .nav-tab { padding: 10px 14px !important; }

    /* ── Root shell: sidebar + content ── */
    .gm-shell {
      display: grid;
      grid-template-columns: 220px 1fr;
      min-height: calc(100vh - 42px);
      max-width: 1400px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    /* ═══ SIDEBAR ═══════════════════════════════════════════ */
    .gm-sidebar {
      border-right: 1px solid rgba(255,255,255,0.05);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 42px;
      height: calc(100vh - 42px);
      overflow-y: auto;
    }

    .gm-sb-head {
      padding: 30px 20px 22px;
    }
    .gm-sb-title {
      display: block;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      margin-bottom: 3px;
    }
    .gm-sb-sub {
      font-size: 10px;
      font-family: var(--font-mono);
      color: var(--text-tertiary);
      letter-spacing: 0.04em;
    }

    .gm-sb-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      padding: 0 14px 22px;
    }
    .gm-ss {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 10px;
      padding: 12px 13px;
    }
    .gm-ss-val {
      font-size: 20px;
      font-weight: 700;
      font-family: var(--font-mono);
      letter-spacing: -0.04em;
      line-height: 1;
      margin-bottom: 4px;
      color: var(--text-primary);
    }
    .gm-ss-val.warning { color: var(--warning); }
    .gm-ss-lbl {
      font-size: 9px;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-tertiary);
    }

    .gm-sb-section {
      font-size: 9px;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--text-tertiary);
      padding: 0 20px 7px;
    }

    .gm-list-nav {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: 0 8px;
      overflow-y: auto;
      gap: 1px;
    }

    /* Rendered by JS */
    .gm-li {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-tertiary);
      transition: all 0.12s;
      user-select: none;
    }
    .gm-li:hover  { background: rgba(255,255,255,0.05); color: var(--text-secondary); }
    .gm-li.active { background: rgba(91,164,245,0.1);   color: var(--text-primary); }
    .gm-li-name { flex: 1; }
    .gm-li-count {
      font-size: 10px;
      font-family: var(--font-mono);
      color: var(--text-tertiary);
      background: rgba(255,255,255,0.06);
      padding: 1px 7px;
      border-radius: 8px;
      flex-shrink: 0;
      min-width: 22px;
      text-align: center;
    }
    .gm-li.active .gm-li-count { background: rgba(91,164,245,0.15); color: #5BA4F5; }
    .gm-li-del, .gm-li-edit {
      opacity: 0;
      background: none;
      border: none;
      color: var(--text-tertiary);
      cursor: pointer;
      font-size: 10px;
      padding: 2px 4px;
      border-radius: 4px;
      transition: all 0.12s;
      line-height: 1;
    }
    .gm-li:hover .gm-li-del, .gm-li:hover .gm-li-edit { opacity: 0.6; }
    .gm-li-del:hover { color: var(--danger) !important; opacity: 1 !important; }
    .gm-li-edit:hover { color: var(--text-secondary) !important; opacity: 1 !important; }
    @media (hover: none) { .gm-li-del, .gm-li-edit { opacity: 0.4; } } /* alltid synlig på touch */

    .gm-new-list-wrap {
      padding: 12px 8px 20px;
      border-top: 1px solid rgba(255,255,255,0.05);
      margin-top: 8px;
      display: flex;
      gap: 6px;
    }
    .gm-new-list-wrap input {
      flex: 1;
      font-size: 12px !important;
      padding: 6px 10px !important;
    }

    /* ═══ MAIN ═══════════════════════════════════════════════ */
    .gm-main {
      padding: 36px 52px 80px;
      display: flex;
      flex-direction: column;
      gap: 28px;
      min-width: 0;
    }

    /* Page header */
    .gm-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
    }
    .gm-page-title {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.035em;
      color: var(--text-primary);
      line-height: 1;
      margin-bottom: 6px;
    }
    .gm-page-sub {
      font-size: 11px;
      font-family: var(--font-mono);
      color: var(--text-tertiary);
    }
    .gm-header-date {
      font-size: 11px;
      font-family: var(--font-mono);
      color: var(--text-tertiary);
      text-align: right;
      flex-shrink: 0;
    }

    /* Stats overview */
    .gm-stat-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }
    .gm-sc {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      padding: 16px 18px;
    }
    .gm-sc-val {
      font-size: 28px;
      font-weight: 700;
      font-family: var(--font-mono);
      letter-spacing: -0.05em;
      line-height: 1;
      color: var(--text-primary);
      margin-bottom: 5px;
    }
    .gm-sc-val.blue    { color: var(--accent-blue); }
    .gm-sc-val.warning { color: var(--warning); }
    .gm-sc-val.success { color: var(--success); }
    .gm-sc-val.danger  { color: var(--danger); }
    .gm-sc-lbl {
      font-size: 9px;
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--text-tertiary);
    }

    /* Quick-add command panel */
    .gm-add-panel {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px;
      overflow: hidden;
      transition: border-color 0.18s, box-shadow 0.18s;
    }
    .gm-add-panel:focus-within {
      border-color: rgba(91,164,245,0.35);
      box-shadow: 0 0 0 3px rgba(91,164,245,0.07);
    }
    .gm-add-top {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 5px 18px;
    }
    .gm-add-ghost-cb {
      width: 20px;
      height: 20px;
      border-radius: 5px;
      border: 1.5px solid rgba(255,255,255,0.14);
      flex-shrink: 0;
    }
    .gm-add-top #todoTitle {
      flex: 1;
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      font-size: 15px !important;
      padding: 14px 4px !important;
      color: var(--text-primary) !important;
      outline: none !important;
      min-width: 0;
      width: auto !important;
    }
    .gm-add-top #todoTitle::placeholder { color: var(--text-tertiary); }
    .gm-add-bottom {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 18px;
      border-top: 1px solid rgba(255,255,255,0.06);
      background: rgba(255,255,255,0.015);
    }
    .gm-add-bottom #todoDue {
      width: 148px !important;
      flex: none;
      font-size: 12px !important;
      padding: 5px 10px !important;
    }
    .gm-add-spacer { flex: 1; }

    /* Task list */
    .gm-list-block { display: flex; flex-direction: column; }
    .gm-list-toolbar {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }
    .filter-row { display: flex; gap: 4px; flex: 1; }
    .filter-btn {
      font-size: 11px;
      font-family: var(--font-mono);
      padding: 5px 13px;
      border-radius: 8px;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      color: var(--text-tertiary);
      transition: all 0.12s;
    }
    .filter-btn.active {
      background: rgba(255,255,255,0.09);
      color: var(--text-primary);
      border-color: rgba(255,255,255,0.16);
    }
    .filter-btn:hover:not(.active) {
      background: rgba(255,255,255,0.06);
      color: var(--text-secondary);
    }
    .gm-count-text {
      font-size: 10px;
      font-family: var(--font-mono);
      color: var(--text-tertiary);
      flex-shrink: 0;
    }

    /* Redesigned todo rows */
    .todo-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 13px 16px;
      border-radius: 10px;
      margin-bottom: 4px;
      background: rgba(255,255,255,0.025);
      border-left: 2px solid transparent;
      transition: background 0.12s;
      min-height: 54px;
    }
    .todo-item:hover  { background: rgba(255,255,255,0.05); }
    .todo-item.important { border-left-color: var(--warning); }
    .todo-item.done   { opacity: 0.38; }

    .todo-cb {
      width: 20px; height: 20px;
      border-radius: 5px;
      border: 1.5px solid rgba(255,255,255,0.18);
      flex-shrink: 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s;
    }
    .todo-cb:hover { border-color: rgba(255,255,255,0.4); }
    .todo-cb.checked { background: var(--success); border-color: var(--success); }
    .todo-cb.checked::after { content: '✓'; font-size: 11px; color: #050506; font-weight: 700; }

    .todo-body { flex: 1; min-width: 0; }
    .todo-text {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-primary);
      line-height: 1.3;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .todo-text.done-text {
      text-decoration: line-through;
      color: var(--text-tertiary);
      font-weight: 400;
    }
    .todo-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 3px;
    }
    .todo-due {
      font-size: 10px;
      font-family: var(--font-mono);
      color: var(--text-tertiary);
    }
    .todo-due.overdue { color: var(--danger); }

    .todo-actions {
      display: flex;
      align-items: center;
      gap: 2px;
      flex-shrink: 0;
    }
    .star-btn {
      background: none; border: none;
      cursor: pointer; font-size: 16px;
      color: rgba(255,255,255,0.12);
      transition: color 0.12s;
      padding: 5px; line-height: 1;
    }
    .star-btn:hover { color: rgba(255,255,255,0.4); }
    .star-btn.active { color: var(--warning); }
    .todo-del {
      background: none; border: none;
      cursor: pointer; font-size: 12px;
      color: var(--text-tertiary);
      opacity: 0;
      transition: opacity 0.12s;
      padding: 5px 6px;
    }
    .todo-item:hover .todo-del { opacity: 0.6; }
    .todo-del:hover { color: var(--danger); opacity: 1 !important; }
    @media (hover: none) { .todo-del { opacity: 0.4; } } /* alltid synlig på touch */

    /* ── Drag & drop ── */
    .drag-handle {
      cursor: grab;
      color: rgba(255,255,255,0.18);
      font-size: 14px;
      flex-shrink: 0;
      padding: 0 3px;
      opacity: 0;
      transition: opacity 0.12s;
      user-select: none;
      line-height: 1;
    }
    .todo-item:hover .drag-handle { opacity: 1; }
    .drag-handle:active { cursor: grabbing; }
    .todo-item.dragging {
      opacity: 0.3;
      border-left-color: transparent !important;
    }
    .todo-item.drag-before {
      border-top: 2px solid rgba(91,164,245,0.65);
      margin-top: -1px;
    }
    .todo-item.drag-after {
      border-bottom: 2px solid rgba(91,164,245,0.65);
      margin-bottom: -1px;
    }

    /* ── Responsive ── */
    @media (max-width: 960px) {
      .gm-shell { grid-template-columns: 196px 1fr; }
      .gm-main  { padding: 28px 32px 60px; }
      .gm-stat-row { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 720px) {
      .gm-shell {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr;
      }
      .gm-sidebar {
        position: static;
        height: auto;
        border-right: none;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }
      .gm-sb-head    { padding: 20px 16px 10px; }
      .gm-sb-stats   { display: none; }
      .gm-sb-section { display: none; }
      .gm-list-nav {
        flex-direction: row;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding: 0 12px 10px;
        gap: 4px;
      }
      .gm-li { white-space: nowrap; flex-shrink: 0; padding: 6px 12px; }
      .gm-li-del, .gm-li-edit { display: none !important; }
      .gm-new-list-wrap { border-top: none; padding: 0 12px 10px; margin-top: 0; }
      .gm-main  { padding: 20px 16px 60px; }
      .gm-page-title { font-size: 22px; }
      .gm-stat-row { grid-template-columns: repeat(2, 1fr); gap: 8px; }
      .gm-add-bottom { flex-wrap: wrap; }
    }
    @media (max-width: 640px) {
      /* Pin "Ny liste" as a dim footer bar — out of the way, below all content */
      .gm-new-list-wrap {
        position: fixed;
        bottom: 0; left: 0; right: 0;
        padding: 8px 16px 14px;
        background: rgba(8, 8, 10, 0.96);
        border-top: 1px solid rgba(255,255,255,0.07);
        border-radius: 0;
        margin-top: 0;
        z-index: 100;
        opacity: 0.5;
        transition: opacity 0.2s;
      }
      .gm-new-list-wrap:hover,
      .gm-new-list-wrap:focus-within { opacity: 1; }
      .gm-new-list-wrap input {
        font-size: 11px !important;
        padding: 4px 8px !important;
      }
      .gm-new-list-wrap .btn {
        font-size: 11px !important;
        padding: 4px 10px !important;
      }
      /* Prevent todo list content hiding behind fixed bar */
      .gm-main { padding-bottom: 80px; }
    }
    @media (max-width: 480px) {
      .gm-stat-row { grid-template-columns: repeat(2, 1fr); }
      .gm-add-top  { padding: 4px 14px; }
      .gm-add-bottom { padding: 8px 14px; }
      .gm-page-title { font-size: 20px; }
    }

    /* ── Inline editing ── */
    .todo-text:not(.done-text) { cursor: text; }
    .todo-text:not(.done-text):hover {
      background: rgba(255,255,255,0.05);
      border-radius: 4px;
      padding: 1px 5px;
      margin: -1px -5px;
    }
    .todo-due { cursor: pointer; }
    .todo-due:hover {
      background: rgba(255,255,255,0.07);
      border-radius: 3px;
      padding: 1px 4px;
      margin: -1px -4px;
    }
    .todo-add-date {
      font-size: 10px;
      font-family: var(--font-mono);
      color: var(--text-tertiary);
      opacity: 0;
      cursor: pointer;
      transition: opacity 0.12s;
      padding: 1px 4px;
      border-radius: 3px;
    }
    .todo-item:hover .todo-add-date { opacity: 0.4; }
    .todo-add-date:hover { opacity: 1 !important; color: var(--accent-blue); }
    .todo-edit-input {
      background: rgba(255,255,255,0.06) !important;
      border: 1px solid rgba(91,164,245,0.35) !important;
      border-radius: 4px !important;
      color: var(--text-primary) !important;
      font-size: 14px !important;
      font-weight: 500 !important;
      font-family: inherit !important;
      padding: 2px 6px !important;
      outline: none !important;
      width: 100%;
      box-sizing: border-box;
      box-shadow: 0 0 0 2px rgba(91,164,245,0.08) !important;
    }
    .todo-edit-date {
      background: rgba(255,255,255,0.06) !important;
      border: 1px solid rgba(91,164,245,0.35) !important;
      border-radius: 3px !important;
      color: var(--text-tertiary) !important;
      font-size: 10px !important;
      font-family: var(--font-mono) !important;
      padding: 1px 5px !important;
      outline: none !important;
      box-shadow: 0 0 0 2px rgba(91,164,245,0.08) !important;
    }
  </style>
</head>
<body>

<nav class="main-nav">
  <div class="nav-inner">
    <div class="nav-tabs">
      <a href="ai.html"           class="nav-tab" data-p="ai"          data-i18n="nav.ai">AI</a>
      <a href="dashboard.html"    class="nav-tab" data-p="dashboard"   data-i18n="nav.dashboard">Dashboard</a>
      <a href="gym.html"          class="nav-tab" data-p="gym"         data-i18n="nav.gym">Gym</a>
      <a href="sprint.html"       class="nav-tab" data-p="sprint"      data-i18n="nav.sprint">Sprint</a>
      <a href="sovn.html"         class="nav-tab" data-p="sovn"        data-i18n="nav.sovn">Søvn</a>
      <a href="gjoremal.html"     class="nav-tab" data-p="gjoremal"    data-i18n="nav.gjoremal">Gjøremål</a>
      <a href="kalender.html"     class="nav-tab" data-p="kalender"    data-i18n="nav.kalender">Kalender</a>
      <a href="treningsplan.html" class="nav-tab" data-p="treningsplan" data-i18n="nav.treningsplan">Treningsoversikt</a>
    </div>
    <button id="langBtn" onclick="toggleLang()" class="btn btn-ghost btn-sm" style="font-size:14px;flex-shrink:0;padding:4px 8px">🇺🇸</button>
    <button onclick="signOut()" class="btn btn-ghost btn-sm" style="font-size:11px;flex-shrink:0;margin-left:4px" data-i18n="nav.logout">Logg ut</button>
  </div>
</nav>

<div class="gm-shell">

  <!-- ══ Sidebar ════════════════════════════════════════════ -->
  <aside class="gm-sidebar">

    <div class="gm-sb-head">
      <span class="gm-sb-title" data-i18n="gm.title">Gjøremål</span>
      <span class="gm-sb-sub" data-i18n="gm.sub">Oppgaver & mål</span>
    </div>

    <div class="gm-sb-stats">
      <div class="gm-ss">
        <div class="gm-ss-val" id="sbActive">–</div>
        <div class="gm-ss-lbl" data-i18n="gm.active">Aktive</div>
      </div>
      <div class="gm-ss">
        <div class="gm-ss-val warning" id="sbImportant">–</div>
        <div class="gm-ss-lbl" data-i18n="gm.important">Viktige</div>
      </div>
    </div>

    <div class="gm-sb-section" data-i18n="gm.lists">Lister</div>
    <div class="gm-list-nav" id="listsBar">
      <div class="loading" data-i18n="loading">Laster…</div>
    </div>

    <div class="gm-new-list-wrap">
      <input type="text" id="newListName" placeholder="Ny liste…"
             data-i18n-placeholder="gm.new_list"
             onkeydown="if(event.key==='Enter')addList()">
      <button class="btn btn-ghost btn-sm" onclick="addList()">+</button>
    </div>

  </aside>

  <!-- ══ Main content ════════════════════════════════════════ -->
  <main class="gm-main">

    <!-- Page header -->
    <div class="gm-header">
      <div>
        <h1 class="gm-page-title" id="listHeading">Generelt</h1>
        <p class="gm-page-sub" data-i18n="gm.sub_tasks">Gjøremål for i dag og fremover</p>
      </div>
      <div class="gm-header-date" id="headerDate"></div>
    </div>

    <!-- Stats overview -->
    <div class="gm-stat-row">
      <div class="gm-sc">
        <div class="gm-sc-val blue"    id="statActive">–</div>
        <div class="gm-sc-lbl" data-i18n="gm.stats_active">Aktive</div>
      </div>
      <div class="gm-sc">
        <div class="gm-sc-val warning" id="statImportant">–</div>
        <div class="gm-sc-lbl" data-i18n="gm.stats_important">Viktige</div>
      </div>
      <div class="gm-sc">
        <div class="gm-sc-val success" id="statDone">–</div>
        <div class="gm-sc-lbl" data-i18n="gm.stats_done">Fullført i dag</div>
      </div>
      <div class="gm-sc">
        <div class="gm-sc-val danger"  id="statOverdue">–</div>
        <div class="gm-sc-lbl" data-i18n="gm.stats_overdue">Forfalt</div>
      </div>
    </div>

    <!-- Quick-add command bar -->
    <div class="gm-add-panel">
      <div class="gm-add-top">
        <div class="gm-add-ghost-cb"></div>
        <input type="text" id="todoTitle" placeholder="Legg til gjøremål…" data-i18n-placeholder="gjoremal.add_ph"
               data-i18n-placeholder="gm.add_placeholder"
               onkeydown="if(event.key==='Enter')addTodo()"
               oninput="localStorage.setItem('gm_draft_title', JSON.stringify({t:this.value,ts:Date.now()}))">
      </div>
      <div class="gm-add-bottom">
        <input type="date" id="todoDue">
        <button class="star-btn" id="newImportant" onclick="toggleNewImportant()" data-i18n-title="gm.important_btn" title="Viktig">☆</button>
        <div class="gm-add-spacer"></div>
        <button class="btn btn-primary btn-sm" onclick="addTodo()" data-i18n="gm.add_btn">Legg til</button>
      </div>
    </div>

    <!-- Filter + task list -->
    <div class="gm-list-block">
      <div class="gm-list-toolbar">
        <div class="filter-row">
          <button class="filter-btn active" data-filter="active"    onclick="setFilter('active')"    data-i18n="gm.filter_active">Aktive</button>
          <button class="filter-btn"        data-filter="all"       onclick="setFilter('all')"       data-i18n="gm.filter_all">Alle</button>
          <button class="filter-btn"        data-filter="important" onclick="setFilter('important')" data-i18n="gm.filter_important">Viktige</button>
          <button class="filter-btn"        data-filter="done"      onclick="setFilter('done')"      data-i18n="gm.filter_done">Fullførte</button>
        </div>
        <span class="gm-count-text" id="todoCount"></span>
      </div>
      <div id="todoList"><div class="empty" data-i18n="gm.no_todos_empty">Ingen gjøremål</div></div>
    </div>

  </main>
</div>

<div class="toast" id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<script src="utils.js"></script>
<script>
let db;
document.querySelector('[data-p="gjoremal"]').classList.add('active');

// Set header date
(function() {
  const el = document.getElementById('headerDate');
  if (el) el.textContent = new Date().toLocaleDateString(fmtLocale(), { weekday: 'long', day: 'numeric', month: 'long' });
})();

// ── State ─────────────────────────────────────────────────────────────────
let lists        = ['Generelt'];
let activeList   = 'Generelt';
let allTodos     = [];
let filter       = 'active';
let newImportant = false;

// ── Drag & drop state ─────────────────────────────────────────────────────
let _dragId = null;
let _dragEl = null;

function getOrder(ln) {
  try { return JSON.parse(localStorage.getItem('gm_order_' + ln) || 'null') || null; } catch(e) { return null; }
}
function saveOrder(ln, ids) {
  localStorage.setItem('gm_order_' + ln, JSON.stringify(ids));
  // Persist to Supabase so order survives cross-device (fire-and-forget)
  Promise.all(ids.map((id, index) =>
    db.from('todos').update({ sort_order: index }).eq('id', id)
  )).catch(() => {});
}
function applyOrder(container, ln) {
  const order = getOrder(ln);
  if (!order || !order.length) return;
  const items = [...container.querySelectorAll('.todo-item[data-id]')];
  if (!items.length) return;
  const idSet = new Set(order);
  const ordered = order.map(id => items.find(el => el.dataset.id === id)).filter(Boolean);
  const extra   = items.filter(el => !idSet.has(el.dataset.id));
  [...ordered, ...extra].forEach(el => container.appendChild(el));
}
function clearDragClasses() {
  document.querySelectorAll('.drag-before,.drag-after').forEach(el => el.classList.remove('drag-before','drag-after'));
}
function onDragStart(e, id) {
  _dragId = id; _dragEl = e.currentTarget;
  e.dataTransfer.effectAllowed = 'move';
  setTimeout(() => _dragEl && _dragEl.classList.add('dragging'), 0);
}
function onDragEnd() {
  if (_dragEl) _dragEl.classList.remove('dragging');
  clearDragClasses();
  _dragId = null; _dragEl = null;
}

// ── Auto-clean (max once per day) ────────────────────────────────────────
async function autoClean() {
  const key = 'ac_' + today();
  if (localStorage.getItem(key)) return;
  localStorage.setItem(key, '1');
  await db.from('todos').delete().eq('completed', true).lt('completed_at', today() + 'T00:00:00.000Z');
}

// ── Stats ─────────────────────────────────────────────────────────────────
function updateStats() {
  const todayStr = today();
  const set = (id, val) => { const e = document.getElementById(id); if (e) e.textContent = val; };

  // Sidebar: global across all lists
  set('sbActive',    allTodos.filter(t => !t.completed).length);
  set('sbImportant', allTodos.filter(t => t.important && !t.completed).length);

  // Main row: current list only
  const lt = allTodos.filter(t => t.list_name === activeList);
  set('statActive',    lt.filter(t => !t.completed).length);
  set('statImportant', lt.filter(t => t.important && !t.completed).length);
  set('statDone',      lt.filter(t => t.completed && t.completed_at && t.completed_at.slice(0,10) === todayStr).length);
  set('statOverdue',   lt.filter(t => !t.completed && t.due_date && t.due_date < todayStr).length);
}

// Re-render dynamic (JS-generert) innhold ved språkbytte. toggleLang() i utils.js kaller denne.
function onLangChange() {
  applyLang();
  renderListsBar();
  renderTodos();
  updateStats();
}

// ── Lists ─────────────────────────────────────────────────────────────────
async function loadLists() {
  const { data } = await db.from('todos').select('list_name');
  const fromDb = [...new Set((data || []).map(t => t.list_name))];
  const hidden = JSON.parse(localStorage.getItem('gm_hidden_defaults') || '[]');
  const defaultLists = ['Generelt', 'Trening', 'Skole'].filter(d => !hidden.includes(d));
  lists = [...new Set([...defaultLists, ...fromDb])];
  const savedTab = localStorage.getItem('gjoremal_active_tab');
  if (savedTab && lists.includes(savedTab)) {
    activeList = savedTab;
    const h = document.getElementById('listHeading');
    if (h) h.textContent = activeList;
  }
  renderListsBar();
}

function renderListsBar() {
  const bar = document.getElementById('listsBar');
  bar.innerHTML = lists.map(l => {
    const cnt = allTodos.filter(t => t.list_name === l && !t.completed).length;
    return `<div class="gm-li ${l===activeList?'active':''}" data-list="${escHtml(l)}" onclick="selectList(this.dataset.list)">
      <span class="gm-li-name">${escHtml(l)}</span>
      ${cnt > 0 ? `<span class="gm-li-count">${cnt}</span>` : ''}
      <button class="gm-li-edit" data-list="${escHtml(l)}" onclick="event.stopPropagation();renameList(this.dataset.list)" title="${t('gm.rename')}">✎</button>
      <button class="gm-li-del" data-list="${escHtml(l)}" onclick="event.stopPropagation();deleteList(this.dataset.list)" title="${t('delete')}" style="${l==='Generelt'?'visibility:hidden;pointer-events:none':''}">✕</button>
    </div>`;
  }).join('');
}

function selectList(name) {
  activeList = name;
  try { localStorage.setItem('gjoremal_active_tab', name); } catch {}
  renderListsBar();
  document.getElementById('listHeading').textContent = name;
  renderTodos();
}

async function renameList(oldName) {
  const newName = (prompt(t('gm.rename_prompt'), oldName) || '').trim();
  if (!newName || newName === oldName) return;
  if (lists.includes(newName)) { toast(t('gm.list_exists'), 'err'); return; }
  const { error } = await db.from('todos').update({ list_name: newName }).eq('list_name', oldName);
  if (error) { toast(t('gm.save_error'), 'err'); return; }
  // Hvis en default-liste døpes om, skjul den så den ikke re-injiseres ved neste lasting
  if (['Generelt','Trening','Skole'].includes(oldName)) {
    const hidden = JSON.parse(localStorage.getItem('gm_hidden_defaults') || '[]');
    if (!hidden.includes(oldName)) { hidden.push(oldName); localStorage.setItem('gm_hidden_defaults', JSON.stringify(hidden)); }
  }
  lists = lists.map(l => l === oldName ? newName : l);
  allTodos.forEach(td => { if (td.list_name === oldName) td.list_name = newName; });
  if (activeList === oldName) { activeList = newName; try { localStorage.setItem('gjoremal_active_tab', newName); } catch {} }
  renderListsBar();
  const h = document.getElementById('listHeading'); if (h) h.textContent = activeList;
  renderTodos();
  toast(t('gm.list_renamed'));
}

async function addList() {
  const name = document.getElementById('newListName').value.trim();
  if (!name || lists.includes(name)) return;
  lists.push(name);
  document.getElementById('newListName').value = '';
  selectList(name);
}

async function deleteList(name) {
  if (!confirm(t('gm.delete_list', {n: name}))) return;
  await db.from('todos').delete().eq('list_name', name);
  localStorage.removeItem('gm_order_' + name);
  lists = lists.filter(l => l !== name);
  if (activeList === name) activeList = lists[0] || 'Generelt';
  renderListsBar();
  await loadTodos();
  toast(t('gm.list_deleted', {n: name}));
}

// ── Todos ─────────────────────────────────────────────────────────────────
async function loadTodos() {
  let { data, error } = await db.from('todos')
    .select('*').order('important', { ascending: false })
    .order('sort_order', { ascending: true, nullsLast: true })
    .order('due_date', { ascending: true, nullsLast: true })
    .order('created_at', { ascending: false });
  if (error) {
    // sort_order column missing (migration 010 not yet run) — fall back
    const fb = await db.from('todos')
      .select('*').order('important', { ascending: false })
      .order('due_date', { ascending: true, nullsLast: true })
      .order('created_at', { ascending: false });
    data = fb.data;
  }
  allTodos = data || [];
  // Seed localStorage from DB sort_order so order works cross-device
  const byList = {};
  for (const td of allTodos) {
    (byList[td.list_name] = byList[td.list_name] || []).push(String(td.id));
  }
  for (const [ln, ids] of Object.entries(byList)) {
    localStorage.setItem('gm_order_' + ln, JSON.stringify(ids));
  }
  renderTodos();
}

function renderTodos() {
  const el   = document.getElementById('todoList');
  let items  = allTodos.filter(t => t.list_name === activeList);

  if (filter === 'active')    items = items.filter(t => !t.completed);
  else if (filter === 'done') items = items.filter(t => t.completed);
  else if (filter === 'important') items = items.filter(t => t.important && !t.completed);

  const activeCount = items.filter(t => !t.completed).length;
  document.getElementById('todoCount').textContent =
    items.length ? t('gm.active_count', {n: activeCount}) : '';

  if (!items.length) {
    el.innerHTML = `<div class="empty">${t('gm.no_todos')}</div>`;
  } else {
    el.innerHTML = items.map(todo => {
      const due = todo.due_date ? new Date(todo.due_date + 'T12:00:00') : null;
      const isOverdue = due && due < new Date() && !todo.completed;
      return `<div class="todo-item ${todo.important?'important':''} ${todo.completed?'done':''}"
          data-id="${todo.id}" draggable="true"
          ondragstart="onDragStart(event,'${todo.id}')" ondragend="onDragEnd()">
        <span class="drag-handle">⠿</span>
        <div class="todo-cb ${todo.completed?'checked':''}" onclick="toggleTodo('${todo.id}',${todo.completed})"></div>
        <div class="todo-body">
          <div class="todo-text ${todo.completed?'done-text':''}"${!todo.completed?` onclick="startEditTitle('${todo.id}')" title="${t('gm.click_edit')}"`:''}>${escHtml(todo.title)}</div>
          <div class="todo-meta">
            ${todo.due_date
              ? `<span class="todo-due ${isOverdue?'overdue':''}" onclick="startEditDue('${todo.id}')" title="${t('gm.change_date')}">${isOverdue?t('gm.overdue_prefix'):''}${fmtDate(todo.due_date)}</span>`
              : `<span class="todo-add-date" onclick="startEditDue('${todo.id}')">${t('gm.add_date')}</span>`
            }
          </div>
        </div>
        <div class="todo-actions">
          <button class="star-btn ${todo.important?'active':''}" onclick="toggleImportant('${todo.id}',${todo.important})" title="${t('gm.important_btn')}">
            ${todo.important ? '★' : '☆'}
          </button>
          <button class="todo-del" onclick="deleteTodo('${todo.id}')">✕</button>
        </div>
      </div>`;
    }).join('');
    applyOrder(el, activeList);
  }

  renderListsBar();
  updateStats();
}

// ── Filter ────────────────────────────────────────────────────────────────
function setFilter(f) {
  filter = f;
  document.querySelectorAll('.filter-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.filter === f);
  });
  renderTodos();
}

// ── Add todo ──────────────────────────────────────────────────────────────
function toggleNewImportant() {
  newImportant = !newImportant;
  const btn = document.getElementById('newImportant');
  btn.textContent = newImportant ? '★' : '☆';
  btn.style.color = newImportant ? 'var(--warning)' : '';
}

async function addTodo() {
  const title = document.getElementById('todoTitle').value.trim();
  const due   = document.getElementById('todoDue').value || null;
  if (!title) return;

  const { data, error } = await db.from('todos').insert({
    title, list_name: activeList, due_date: due, important: newImportant,
  }).select().single();
  if (error) { toast(t('gm.save_error'), 'err'); return; }

  allTodos.unshift(data);
  const _ord = getOrder(activeList) || [];
  saveOrder(activeList, [String(data.id), ..._ord]);
  document.getElementById('todoTitle').value = '';
  document.getElementById('todoDue').value   = '';
  localStorage.removeItem('gm_draft_title');
  newImportant = false;
  document.getElementById('newImportant').textContent = '☆';
  document.getElementById('newImportant').style.color = '';
  renderTodos();
  toast(t('gm.added'));
}

// ── Toggle complete ───────────────────────────────────────────────────────
async function toggleTodo(id, isDone) {
  const newDone = !isDone;
  const { error } = await db.from('todos').update({
    completed: newDone,
    completed_at: newDone ? new Date().toISOString() : null,
  }).eq('id', id);
  if (error) { toast(t('gm.update_error'), 'err'); return; }
  const td = allTodos.find(x => x.id === id);
  if (td) { td.completed = newDone; td.completed_at = newDone ? new Date().toISOString() : null; }
  renderTodos();
}

// ── Toggle important ──────────────────────────────────────────────────────
async function toggleImportant(id, isImportant) {
  const { error } = await db.from('todos').update({ important: !isImportant }).eq('id', id);
  if (error) { toast(t('gm.update_error'), 'err'); return; }
  const td = allTodos.find(x => x.id === id);
  if (td) td.important = !isImportant;
  renderTodos();
}

// ── Delete ────────────────────────────────────────────────────────────────
async function deleteTodo(id) {
  const { error } = await db.from('todos').delete().eq('id', id);
  if (error) { toast(t('gm.delete_error'), 'err'); return; }
  allTodos = allTodos.filter(x => x.id !== id);
  renderTodos();
  toast(t('gm.deleted'));
}

// ── Inline edit: title ────────────────────────────────────────────────────
function startEditTitle(todoId) {
  const item = document.querySelector(`.todo-item[data-id="${todoId}"]`);
  if (!item) return;
  const textEl = item.querySelector('.todo-text');
  const todo = allTodos.find(t => String(t.id) === String(todoId));
  if (!todo || todo.completed || !textEl) return;

  item.setAttribute('draggable', 'false');
  const input = document.createElement('input');
  input.type = 'text';
  input.value = todo.title;
  input.className = 'todo-edit-input';

  let saved = false;
  const save = async () => {
    if (saved) return;
    saved = true;
    const newTitle = input.value.trim();
    if (newTitle && newTitle !== todo.title) {
      const { error } = await db.from('todos').update({ title: newTitle }).eq('id', todoId);
      if (!error) { todo.title = newTitle; toast(t('gm.saved')); }
      else toast(t('gm.save_error'), 'err');
    }
    renderTodos();
  };

  input.addEventListener('keydown', e => {
    if (e.key === 'Enter')  { e.preventDefault(); input.blur(); }
    if (e.key === 'Escape') { saved = true; renderTodos(); }
  });
  input.addEventListener('blur', save);

  textEl.replaceWith(input);
  input.focus();
  input.select();
}

// ── Inline edit: due date ─────────────────────────────────────────────────
function startEditDue(todoId) {
  const item = document.querySelector(`.todo-item[data-id="${todoId}"]`);
  if (!item) return;
  const todo = allTodos.find(t => String(t.id) === String(todoId));
  if (!todo) return;

  item.setAttribute('draggable', 'false');
  const input = document.createElement('input');
  input.type = 'date';
  input.value = todo.due_date || '';
  input.className = 'todo-edit-date';

  let saved = false;
  const save = async () => {
    if (saved) return;
    saved = true;
    const newDate = input.value || null;
    if (newDate !== todo.due_date) {
      const { error } = await db.from('todos').update({ due_date: newDate }).eq('id', todoId);
      if (!error) { todo.due_date = newDate; toast(t('gm.saved')); }
      else toast(t('gm.save_error'), 'err');
    }
    renderTodos();
  };

  input.addEventListener('change', () => { input.blur(); });
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter')  { e.preventDefault(); input.blur(); }
    if (e.key === 'Escape') { saved = true; renderTodos(); }
  });
  input.addEventListener('blur', save);

  const target = item.querySelector('.todo-due') || item.querySelector('.todo-add-date');
  if (target) target.replaceWith(input);
  input.focus();
  try { input.showPicker(); } catch(e) {}
}

// ── Container drag listeners ──────────────────────────────────────────────
(function() {
  const container = document.getElementById('todoList');
  container.addEventListener('dragover', e => {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    const target = e.target.closest('.todo-item[data-id]');
    clearDragClasses();
    if (!target || target === _dragEl) return;
    const r = target.getBoundingClientRect();
    target.classList.add(e.clientY < r.top + r.height / 2 ? 'drag-before' : 'drag-after');
  });
  container.addEventListener('dragleave', e => {
    if (!container.contains(e.relatedTarget)) clearDragClasses();
  });
  container.addEventListener('drop', e => {
    e.preventDefault();
    const target = e.target.closest('.todo-item[data-id]');
    clearDragClasses();
    if (!target || !_dragEl || target === _dragEl) return;
    const r = target.getBoundingClientRect();
    if (e.clientY < r.top + r.height / 2) container.insertBefore(_dragEl, target);
    else container.insertBefore(_dragEl, target.nextSibling);
    const ids = [...container.querySelectorAll('.todo-item[data-id]')].map(el => el.dataset.id);
    if (ids.length > 0) saveOrder(activeList, ids);
  });
})();


// ── Init ──────────────────────────────────────────────────────────────────
(async () => {
  try {
    const cfg = await getConfig();
    db = supabase.createClient(cfg.supabaseUrl, cfg.supabaseAnonKey);
    const { data: { session } } = await db.auth.getSession();
    if (!session) { window.location.href = 'login.html'; return; }
  } catch (err) {
    document.querySelector('.gm-shell').innerHTML =
      `<div class="card" style="text-align:center;padding:40px;grid-column:1/-1">
        <div style="color:var(--danger);font-family:var(--font-mono);font-size:13px">${err.message}</div>
        <div style="color:var(--text-tertiary);font-size:11px;margin-top:10px">
          Sett SUPABASE_URL og SUPABASE_ANON_KEY som miljøvariabler i Vercel.
        </div>
      </div>`;
    return;
  }
  applyLang();
  await Promise.all([autoClean(), loadLists()]);
  await loadTodos();

  // Gjenopprett draft-tekst (maks 24 timer gammel)
  try {
    const raw = localStorage.getItem('gm_draft_title');
    if (raw) {
      const { t, ts } = JSON.parse(raw);
      if (t && Date.now() - ts < 86400000) document.getElementById('todoTitle').value = t;
      else localStorage.removeItem('gm_draft_title');
    }
  } catch { localStorage.removeItem('gm_draft_title'); }
})();
</script>
</body>
</html>
